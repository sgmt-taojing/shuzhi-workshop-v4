<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>数造工坊 · 管理后台</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --primary: #2563eb; --primary-dark: #1d4ed8; --bg: #f0f2f5;
    --card: #fff; --border: #e5e7eb; --text: #1f2937; --text2: #6b7280;
    --success: #10b981; --warning: #f59e0b; --danger: #ef4444; --info: #3b82f6;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); }

  /* Login */
  .login-wrap { display: flex; align-items: center; justify-content: center; height: 100vh; }
  .login-card { background: var(--card); padding: 40px; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.08); width: 360px; }
  .login-card h2 { text-align: center; margin-bottom: 24px; font-size: 20px; }
  .login-card input { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; margin-bottom: 12px; }
  .login-card button { width: 100%; padding: 10px; background: var(--primary); color: #fff; border: none; border-radius: 8px; font-size: 15px; cursor: pointer; }
  .login-card button:hover { background: var(--primary-dark); }
  .login-error { color: var(--danger); font-size: 13px; text-align: center; margin-top: 8px; display: none; }

  /* Layout */
  .app { display: none; }
  .app.active { display: flex; height: 100vh; }
  .sidebar { width: 220px; background: #0a1628; color: #fff; flex-shrink: 0; display: flex; flex-direction: column; }
  .sidebar-brand { padding: 20px; font-size: 18px; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,.1); }
  .sidebar-nav { flex: 1; padding: 12px 0; overflow-y: auto; }
  .nav-item { display: block; padding: 10px 20px; color: rgba(255,255,255,.65); cursor: pointer; font-size: 14px; text-decoration: none; transition: all .2s; }
  .nav-item:hover, .nav-item.active { color: #fff; background: rgba(255,255,255,.1); }
  .main { flex: 1; overflow-y: auto; padding: 24px; }
  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .header h1 { font-size: 22px; }
  .btn { padding: 8px 16px; border: none; border-radius: 8px; cursor: pointer; font-size: 13px; transition: all .2s; }
  .btn-primary { background: var(--primary); color: #fff; }
  .btn-sm { padding: 4px 10px; font-size: 12px; }
  .btn-success { background: var(--success); color: #fff; }
  .btn-warning { background: var(--warning); color: #fff; }
  .btn-danger { background: var(--danger); color: #fff; }
  .btn-info { background: var(--info); color: #fff; }
  .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text2); }

  /* Cards */
  .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .stat-card { background: var(--card); padding: 20px; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  .stat-card .label { font-size: 13px; color: var(--text2); }
  .stat-card .value { font-size: 28px; font-weight: 700; margin-top: 4px; }
  .stat-card.pending .value { color: var(--warning); }
  .stat-card.info .value { color: var(--info); }

  /* Table */
  .card { background: var(--card); border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06); overflow: hidden; margin-bottom: 24px; }
  .card-header { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .card-body { padding: 0; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 12px 16px; text-align: left; font-size: 13px; border-bottom: 1px solid var(--border); }
  th { background: #f9fafb; color: var(--text2); font-weight: 600; }
  tr:hover td { background: #f9fafb; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 99px; font-size: 11px; font-weight: 600; }
  .badge-pending { background: #fef3c7; color: #92400e; }
  .badge-contacted { background: #dbeafe; color: #1e40af; }
  .badge-approved { background: #d1fae5; color: #065f46; }
  .badge-rejected { background: #fee2e2; color: #991b1b; }
  .badge-default { background: #f3f4f6; color: #374151; }
  .badge-info { background: #dbeafe; color: #1e40af; }

  /* Tab */
  .tabs { display: flex; gap: 8px; margin-bottom: 20px; }
  .tab { padding: 6px 14px; border-radius: 99px; cursor: pointer; font-size: 13px; background: var(--card); border: 1px solid var(--border); }
  .tab.active { background: var(--primary); color: #fff; border-color: var(--primary); }

  /* Modal */
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.4); z-index: 100; align-items: center; justify-content: center; }
  .modal-overlay.active { display: flex; }
  .modal { background: var(--card); border-radius: 12px; padding: 24px; width: 560px; max-height: 80vh; overflow-y: auto; }
  .modal.modal-lg { width: 700px; }
  .modal h3 { margin-bottom: 16px; }
  .form-group { margin-bottom: 12px; }
  .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px; }
  .form-group textarea { min-height: 80px; resize: vertical; }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }

  .empty { text-align: center; padding: 40px; color: var(--text2); }

  /* Follow status */
  .follow-mutual { color: var(--success); font-weight: 600; }
  .follow-oneway { color: var(--warning); }
  .follow-none { color: var(--text2); }
</style>
</head>
<body>

<!-- Login -->
<div class="login-wrap" id="loginPage">
  <div class="login-card">
    <h2>数造工坊 · 管理后台</h2>
    <input type="text" id="loginUser" placeholder="用户名" value="admin">
    <input type="password" id="loginPass" placeholder="密码" value="admin123">
    <button onclick="doLogin()">登 录</button>
    <div class="login-error" id="loginError">用户名或密码错误</div>
  </div>
</div>

<!-- App -->
<div class="app" id="app">
  <div class="sidebar">
    <div class="sidebar-brand">🏭 数造工坊</div>
    <nav class="sidebar-nav">
      <a class="nav-item active" data-page="dashboard">📊 仪表盘</a>
      <a class="nav-item" data-page="analytics-dashboard">📈 数据分析</a>
      <a class="nav-item" data-page="contacts">📞 咨询管理</a>
      <a class="nav-item" data-page="leads-pipeline">🔧 线索管线</a>
      <a class="nav-item" data-page="onboardings">🤝 入驻管理</a>
      <a class="nav-item" data-page="products">📦 产品管理</a>
      <a class="nav-item" data-page="client-products">🏢 甲方产品</a>
      <a class="nav-item" data-page="clients">🏗️ 甲方企业</a>
      <a class="nav-item" data-page="orders">🛒 订单管理</a>
      <a class="nav-item" data-page="articles">📝 文章管理</a>
      <a class="nav-item" data-page="reviews">⭐ 评价管理</a>
      <a class="nav-item" data-page="crm-customers">🏢 客户管理</a>
      <a class="nav-item" data-page="crm-projects">📁 项目管理</a>
      <a class="nav-item" data-page="crm-leads">🎯 商机管理</a>
      <a class="nav-item" data-page="crm-finance">💰 财务管理</a>
      <a class="nav-item" data-page="crm-team">👥 团队管理</a>
      <a class="nav-item" data-page="crm-reports">📝 日报审核</a>
      <a class="nav-item" data-page="crm-quote">💼 报价工具</a>
      <a class="nav-item" data-page="crm-kb">📚 内部知识库</a>
      <a class="nav-item" data-page="users">👥 用户管理</a>
      <a class="nav-item" data-page="wechat-accounts">📱 公众号管理</a>
      <a class="nav-item" data-page="push-history">📤 推送管理</a>
      <a class="nav-item" data-page="template-msg">📣 模板消息</a>
      <a class="nav-item" data-page="reports">📊 运营报告</a>
      <a class="nav-item" data-page="assessments">📋 数字化评估</a>
      <a class="nav-item" data-page="audit-logs">🔒 审计日志</a>
      <a class="nav-item" data-page="scheduler">⏰ 定时任务</a>
      <a class="nav-item" data-page="quotes">🧮 报价查询</a>
      <a class="nav-item" data-page="service-tracker">🛠️ 服务追踪</a>
      <a class="nav-item" data-page="banners">🖼️ Banner管理</a>
      <a class="nav-item" data-page="faqs">❓ 帮助中心</a>
      <a class="nav-item" data-page="invoices">🧾 发票管理</a>
      <a class="nav-item" data-page="tickets">🎫 售后工单</a>
      <a class="nav-item" data-page="partners">🤝 合作伙伴</a>
      <a class="nav-item" data-page="chatbot">🤖 智能客服</a>
      <a class="nav-item" data-page="contracts">📄 合同管理</a>
      <a class="nav-item" data-page="campaigns">🎉 营销活动</a>
      <a class="nav-item" data-page="policies">📜 政策追踪</a>
      <a class="nav-item" onclick="window.open('/admin/screen.html','_blank')" style="color:#00d4ff">📺 运营大屏</a>
    </nav>
    <a class="nav-item" onclick="doLogout()" style="border-top:1px solid rgba(255,255,255,.1)">退出登录</a>
  </div>
  <div class="main" id="mainContent"></div>
</div>

<!-- Modal -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal" id="modalContent"></div>
</div>

<script>
const API = '/api';
let token = localStorage.getItem('dt_token') || '';
let currentPage = 'dashboard';

// --- Auth ---
async function doLogin() {
  const username = document.getElementById('loginUser').value;
  const password = document.getElementById('loginPass').value;
  try {
    const r = await fetch(API + '/admin/login', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, password })
    });
    const d = await r.json();
    if (d.token) {
      token = d.token;
      localStorage.setItem('dt_token', token);
      showApp();
    } else throw new Error();
  } catch {
    document.getElementById('loginError').style.display = 'block';
  }
}

function doLogout() {
  token = '';
  localStorage.removeItem('dt_token');
  document.getElementById('app').classList.remove('active');
  document.getElementById('loginPage').style.display = 'flex';
}

function showApp() {
  document.getElementById('loginPage').style.display = 'none';
  document.getElementById('app').classList.add('active');
  loadPage('dashboard');
}

async function api(path, opts = {}) {
  const headers = { 'Content-Type': 'application/json' };
  if (token) headers['Authorization'] = 'Bearer ' + token;
  const r = await fetch(API + path, { ...opts, headers: { ...headers, ...(opts.headers || {}) } });
  return r.json();
}

// --- Nav ---
document.querySelectorAll('.nav-item[data-page]').forEach(el => {
  el.addEventListener('click', () => {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    el.classList.add('active');
    loadPage(el.dataset.page);
  });
});

function loadPage(page) {
  currentPage = page;
  const loaders = {
    dashboard: loadDashboard,
    'analytics-dashboard': loadAnalyticsDashboard,
    contacts: loadContacts,
    onboardings: loadOnboardings,
    products: loadProducts,
    'client-products': loadClientProducts,
    clients: loadClients,
    orders: loadOrders,
    articles: loadArticles,
    'wechat-accounts': loadWechatAccounts,
    'push-history': loadPushHistory,
    'template-msg': loadTemplateMsg,
    'users': loadUsers,
    'reviews': loadReviews,
    'crm-customers': loadCrmCustomers,
    'crm-projects': loadCrmProjects,
    'crm-leads': loadCrmLeads,
    'crm-finance': loadCrmFinance,
    'crm-team': loadCrmTeam,
    'crm-reports': loadCrmReports,
    'crm-quote': loadCrmQuote,
    'crm-kb': loadCrmKb,
    'reports': loadReports,
    'assessments': loadAssessments,
    'leads-pipeline': loadLeadsPipeline,
    'audit-logs': loadAuditLogs,
    'quotes': loadQuotes,
    'scheduler': loadScheduler,
    'service-tracker': loadServiceTracker,
    'banners': loadBanners,
    'faqs': loadFaqs,
    'invoices': loadInvoices,
    'tickets': loadTickets,
    'partners': loadPartners,
    'chatbot': loadChatbot,
    'contracts': loadContracts,
    'campaigns': loadCampaigns,
    'policies': loadPolicies
  if (loaders[page]) loaders[page]();
}

// --- Dashboard ---
async function loadDashboard() {
  const d = await api('/admin/dashboard');
  // 加载最近订单
  let recentOrdersHtml = '<tr><td colspan="6" style="text-align:center;color:#999">加载中...</td></tr>';
  try {
    const orders = await api('/admin/orders');
    const st = {pending:'待支付',paid:'已支付',shipped:'已发货',completed:'已完成',cancelled:'已取消'};
    const sc = {pending:'#fbbf24',paid:'#60a5fa',shipped:'#a78bfa',completed:'#34d399',cancelled:'#f87171'};
    recentOrdersHtml = orders.slice(0, 5).map(o => `<tr><td style="font-size:12px">${o.order_no}</td><td>${o.product_title}</td><td>¥${o.amount}</td><td>${o.buyer_name}</td><td style="color:${sc[o.status]||''}">${st[o.status]||o.status}</td><td style="font-size:12px">${(o.created_at||'').slice(5,16)}</td></tr>`).join('') || '<tr><td colspan="6" style="text-align:center;color:#999">暂无订单</td></tr>';
  } catch(e) { recentOrdersHtml = '<tr><td colspan="6" style="text-align:center;color:#999">加载失败</td></tr>'; }
  // 获取微信运营数据
  let wechatStats = { total: 0, mutual: 0, weekPushes: 0, recentPush: '-' };
  try {
    const accounts = await api('/wechat/accounts');
    wechatStats.total = accounts.length;
    wechatStats.mutual = accounts.filter(a => a.follow_status === '互关').length;
  } catch(e) {}
  try {
    const ph = await api('/wechat/push-history');
    const weekAgo = Date.now() - 7*24*3600*1000;
    wechatStats.weekPushes = ph.filter(p => new Date(p.pushed_at).getTime() > weekAgo).length;
    if (ph.length > 0) {
      const recent = ph.sort((a,b) => new Date(b.pushed_at) - new Date(a.pushed_at))[0];
      wechatStats.recentPush = recent.article_title || '-';
    }
  } catch(e) {}

  const tmBadge = d.tmEnabled ? '<span style="background:#d1fae5;color:#065f46;padding:2px 8px;border-radius:99px;font-size:11px;margin-left:6px">已启用</span>' : '<span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:99px;font-size:11px;margin-left:6px">未配置</span>';
  document.getElementById('mainContent').innerHTML = `
    <div class="header"><h1>仪表盘</h1><span style="color:var(--text2);font-size:13px">${new Date().toLocaleDateString('zh-CN')}</span></div>
    <div class="stats">
      <div class="stat-card"><div class="label">咨询总数</div><div class="value">${d.contacts}</div></div>
      <div class="stat-card pending"><div class="label">待处理咨询</div><div class="value">${d.pendingContacts}</div></div>
      <div class="stat-card"><div class="label">入驻申请</div><div class="value">${d.onboardings}</div></div>
      <div class="stat-card pending"><div class="label">待审核入驻</div><div class="value">${d.pendingOnboardings}</div></div>
      <div class="stat-card"><div class="label">产品数</div><div class="value">${d.products}</div></div>
      <div class="stat-card"><div class="label">文章数</div><div class="value">${d.articles}</div></div>
      <div class="stat-card"><div class="label">甲方产品</div><div class="value">${d.clientProducts}</div></div>
      <div class="stat-card"><div class="label">甲方企业</div><div class="value">${d.clients || 0}</div></div>
      <div class="stat-card pending"><div class="label">待处理订单</div><div class="value">${d.pendingOrders || 0}</div></div>
    </div>
    <div class="header" style="margin-top:32px"><h1 style="font-size:18px">📣 模板消息（线索通知）</h1>${tmBadge}</div>
    <div class="stats">
      <div class="stat-card info"><div class="label">发送总数</div><div class="value">${d.tmTotal || 0}</div></div>
      <div class="stat-card"><div class="label">成功</div><div class="value" style="color:var(--success)">${d.tmSuccess || 0}</div></div>
      <div class="stat-card"><div class="label">失败</div><div class="value" style="color:var(--danger)">${d.tmFailed || 0}</div></div>
    </div>
    <div class="header" style="margin-top:32px"><h1 style="font-size:18px">微信运营数据</h1></div>
    <div class="stats">
      <div class="stat-card info"><div class="label">公众号总数</div><div class="value">${wechatStats.total}</div></div>
      <div class="stat-card info"><div class="label">互关公众号数</div><div class="value">${wechatStats.mutual}</div></div>
      <div class="stat-card info"><div class="label">本周推送次数</div><div class="value">${wechatStats.weekPushes}</div></div>
      <div class="stat-card"><div class="label">最近推送文章</div><div class="value" style="font-size:16px">${wechatStats.recentPush}</div></div>
    </div>
    <div class="header" style="margin-top:32px"><h1 style="font-size:18px">最近订单</h1></div>
    <table><thead><tr><th>订单号</th><th>产品</th><th>金额</th><th>买家</th><th>状态</th><th>时间</th></tr></thead><tbody>${recentOrdersHtml}</tbody></table>`;
}

// --- Analytics Dashboard ---
async function loadAnalyticsDashboard() {
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>📈 数据分析中心</h1><span style="color:var(--text2);font-size:13px" id="adTime">加载中...</span></div>
    <div id="adContent"><div style="text-align:center;padding:60px;color:#999">正在加载分析数据...</div></div>
  `;
  document.getElementById('adTime').textContent = new Date().toLocaleString('zh-CN');

  try {
    const [overview, trend, hotProducts, leadSource, cpPerformance, realtime] = await Promise.all([
      api('/admin/dashboard'),
      api('/analytics/orders/trend?days=30').catch(() => []),
      api('/analytics/products/hot?limit=10').catch(() => []),
      api('/analytics/contacts/source').catch(() => ({ byIndustry: [], byStatus: {}, recent7Days: [] })),
      api('/analytics/client-products/performance').catch(() => []),
      api('/analytics/realtime').catch(() => ({}))
    ]);

    // ===== KPI Cards =====
    const todayRev = realtime.orders ? (realtime.orders.revenue || 0) : 0;
    const todayOrders = realtime.orders ? realtime.orders.total : 0;
    const todayLeads = realtime.contacts ? realtime.contacts.total : 0;
    const todayMsgs = realtime.messages ? realtime.messages.total : 0;

    // ===== Revenue Trend (Line Chart) =====
    const trendData = trend.map(t => ({ date: t.date.slice(5), revenue: t.revenue || 0, count: t.count || 0 }));
    const maxRev = Math.max(...trendData.map(t => t.revenue), 1);
    const maxCnt = Math.max(...trendData.map(t => t.count), 1);
    const chartW = 720, chartH = 260, padL = 50, padR = 20, padT = 30, padB = 40;
    const innerW = chartW - padL - padR, innerH = chartH - padT - padB;
    const stepX = trendData.length > 1 ? innerW / (trendData.length - 1) : innerW;

    // Build SVG path for revenue line
    let revPath = '', revArea = '';
    const revPoints = trendData.map((t, i) => {
      const x = padL + i * stepX;
      const y = padT + innerH - (t.revenue / maxRev) * innerH;
      return { x, y, ...t };
    });
    if (revPoints.length > 0) {
      revPath = revPoints.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
      revArea = `M ${padL} ${padT + innerH} ` + revPoints.map(p => `L ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ') + ` L ${(padL + (trendData.length - 1) * stepX).toFixed(1)} ${padT + innerH} Z`;
    }

    // Y axis labels for revenue
    const yLabels = [0, 0.25, 0.5, 0.75, 1].map(ratio => {
      const val = Math.round(maxRev * ratio);
      const y = padT + innerH - ratio * innerH;
      return `<text x="${padL - 8}" y="${y + 4}" text-anchor="end" font-size="10" fill="#9ca3af">¥${val >= 10000 ? (val / 10000).toFixed(1) + '万' : val}</text><line x1="${padL}" y1="${y}" x2="${chartW - padR}" y2="${y}" stroke="#f0f0f0" stroke-width="1"/>`;
    }).join('');

    // X axis labels (every 5th day)
    const xLabels = trendData.filter((_, i) => i % 5 === 0 || i === trendData.length - 1).map(t => {
      const idx = trendData.indexOf(t);
      const x = padL + idx * stepX;
      return `<text x="${x}" y="${padT + innerH + 18}" text-anchor="middle" font-size="10" fill="#9ca3af">${t.date}</text>`;
    }).join('');

    // Revenue dots
    const revDots = revPoints.map(p => `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3" fill="#2563eb" opacity="0.7"><title>${t.date} ¥${p.revenue.toFixed(0)}</title></circle>`).join('');

    // ===== Order Status Donut =====
    const ordStatus = overview.orders || {};
    const ordTotal = (ordStatus.total || 0);
    const ordPending = ordStatus.pending || 0;
    const ordPaid = ordStatus.paid || 0;
    const ordCompleted = ordStatus.completed || 0;
    const ordCancelled = (ordTotal - ordPending - ordPaid - ordCompleted);
    const donutData = [
      { label: '已支付', value: ordPaid, color: '#60a5fa' },
      { label: '已完成', value: ordCompleted, color: '#34d399' },
      { label: '待支付', value: ordPending, color: '#fbbf24' },
      { label: '已取消', value: Math.max(0, ordCancelled), color: '#f87171' }
    ].filter(d => d.value > 0);
    const donutTotal = donutData.reduce((s, d) => s + d.value, 0) || 1;
    const donutR = 70, donutCx = 90, donutCy = 90, donutStroke = 24;
    const donutCircumference = 2 * Math.PI * donutR;
    let donutOffset = 0;
    const donutSegments = donutData.map(d => {
      const fraction = d.value / donutTotal;
      const dashLen = fraction * donutCircumference;
      const seg = `<circle cx="${donutCx}" cy="${donutCy}" r="${donutR}" fill="none" stroke="${d.color}" stroke-width="${donutStroke}" stroke-dasharray="${dashLen} ${donutCircumference - dashLen}" stroke-dashoffset="${-donutOffset}" transform="rotate(-90 ${donutCx} ${donutCy})"><title>${d.label}: ${d.value}</title></circle>`;
      donutOffset += dashLen;
      return seg;
    }).join('');
    const donutLegend = donutData.map(d => `<div style="display:flex;align-items:center;gap:6px;margin:4px 0"><span style="width:10px;height:10px;border-radius:50%;background:${d.color};display:inline-block"></span><span style="font-size:12px;color:var(--text2)">${d.label}: <strong style="color:var(--text)">${d.value}</strong></span></div>`).join('');

    // ===== Lead Source Bar Chart =====
    const leadIndustries = (leadSource.byIndustry || []).slice(0, 8);
    const maxLead = Math.max(...leadIndustries.map(i => i.count), 1);
    const barH = 28, barGap = 8, barAreaH = leadIndustries.length * (barH + barGap);
    const barMaxW = 200;
    const leadBars = leadIndustries.map((ind, i) => {
      const w = (ind.count / maxLead) * barMaxW;
      const y = i * (barH + barGap);
      return `<g><text x="0" y="${y + 18}" font-size="12" fill="var(--text2)">${ind.name.length > 6 ? ind.name.slice(0, 6) + '…' : ind.name}</text><rect x="80" y="${y + 4}" width="${barMaxW}" height="${barH}" fill="#f0f2f5" rx="4"/><rect x="80" y="${y + 4}" width="${w}" height="${barH}" fill="#3b82f6" rx="4" opacity="0.8"><title>${ind.name}: ${ind.count}</title></rect><text x="${80 + w + 8}" y="${y + 22}" font-size="12" fill="var(--text)" font-weight="600">${ind.count}</text></g>`;
    }).join('');

    // ===== Lead 7-day trend (mini bars) =====
    const lead7 = leadSource.recent7Days || [];
    const maxLead7 = Math.max(...lead7.map(d => d.count), 1);
    const lead7W = 280, lead7H = 80, lead7BarW = lead7.length > 0 ? (lead7W - 20) / lead7.length : 0;
    const lead7Bars = lead7.map((d, i) => {
      const h = (d.count / maxLead7) * (lead7H - 20);
      const x = 10 + i * lead7BarW;
      const y = lead7H - 10 - h;
      return `<rect x="${x + 2}" y="${y}" width="${lead7BarW - 4}" height="${h}" fill="#f59e0b" rx="2" opacity="0.8"><title>${d.date}: ${d.count}</title></rect><text x="${x + lead7BarW / 2}" y="${lead7H}" text-anchor="middle" font-size="8" fill="#9ca3af">${d.date.slice(5)}</text>`;
    }).join('');

    // ===== Hot Products =====
    const hotList = (hotProducts || []).slice(0, 8).map((p, i) => {
      const rank = i + 1;
      const rankColor = rank === 1 ? '#f59e0b' : rank === 2 ? '#9ca3af' : rank === 3 ? '#d97706' : '#e5e7eb';
      const maxCnt2 = Math.max(...(hotProducts || []).map(p => p.orderCount), 1);
      const barW2 = (p.orderCount / maxCnt2) * 140;
      return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #f3f4f6">
        <span style="width:22px;height:22px;border-radius:50%;background:${rankColor};color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0">${rank}</span>
        <span style="font-size:18px">${p.icon || '📦'}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.title}</div>
          <div style="font-size:11px;color:var(--text2)">${p.category || ''} · ¥${p.price || 0}</div>
        </div>
        <div style="width:140px;flex-shrink:0"><div style="background:#dbeafe;height:6px;border-radius:3px;overflow:hidden"><div style="width:${barW2}px;height:100%;background:#3b82f6;border-radius:3px"></div></div></div>
        <span style="font-size:13px;font-weight:600;color:#3b82f6;min-width:50px;text-align:right">${p.orderCount}单</span>
      </div>`;
    }).join('');

    // ===== Client Product Performance =====
    const cpList = (cpPerformance || []).slice(0, 5).map((cp, i) => {
      return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #f3f4f6">
        <span style="font-size:11px;color:var(--text2);width:20px">#${i+1}</span>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${cp.title}</div>
          <div style="font-size:11px;color:var(--text2)">${cp.clientName} · ${cp.type === 'service' ? '服务' : '产品'}</div>
        </div>
        <span style="font-size:13px;font-weight:600;color:var(--success)">¥${(cp.revenue || 0).toFixed(0)}</span>
        <span style="font-size:11px;color:var(--text2);min-width:40px;text-align:right">${cp.orderCount}单</span>
      </div>`;
    }).join('');

    // ===== Render =====
    document.getElementById('adContent').innerHTML = `
      <!-- KPI Cards Row -->
      <div class="stats" style="margin-bottom:20px">
        <div class="stat-card" style="border-left:3px solid #3b82f6">
          <div class="label">今日收入</div>
          <div class="value" style="color:#3b82f6">¥${todayRev.toFixed(0)}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:4px">${todayOrders} 笔订单</div>
        </div>
        <div class="stat-card" style="border-left:3px solid #f59e0b">
          <div class="label">今日线索</div>
          <div class="value" style="color:#f59e0b">${todayLeads}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:4px">${realtime.contacts ? realtime.contacts.pending : 0} 待处理</div>
        </div>
        <div class="stat-card" style="border-left:3px solid #10b981">
          <div class="label">今日消息</div>
          <div class="value" style="color:#10b981">${todayMsgs}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:4px">${realtime.messages ? realtime.messages.inbound : 0} 入站</div>
        </div>
        <div class="stat-card" style="border-left:3px solid #8b5cf6">
          <div class="label">总收入</div>
          <div class="value" style="color:#8b5cf6">¥${(ordStatus.totalRevenue || 0).toFixed(0)}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:4px">${ordTotal} 总订单</div>
        </div>
        <div class="stat-card" style="border-left:3px solid #ec4899">
          <div class="label">产品数</div>
          <div class="value" style="color:#ec4899">${overview.products || 0}</div>
          <div style="font-size:11px;color:var(--text2);margin-top:4px">${overview.clientProducts || 0} 甲方产品</div>
        </div>
      </div>

      <!-- Revenue Trend + Order Donut -->
      <div style="display:grid;grid-template-columns:1fr 280px;gap:16px;margin-bottom:20px">
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">💰 30天收入趋势</div>
          <svg width="${chartW}" height="${chartH}" style="width:100%;height:auto" viewBox="0 0 ${chartW} ${chartH}">
            <defs><linearGradient id="revGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"/><stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/></linearGradient></defs>
            ${yLabels}
            ${xLabels}
            ${revArea ? `<path d="${revArea}" fill="url(#revGrad)"/>` : ''}
            ${revPath ? `<path d="${revPath}" fill="none" stroke="#2563eb" stroke-width="2" stroke-linejoin="round"/>` : ''}
            ${revDots}
          </svg>
        </div>
        <div class="card" style="padding:20px;display:flex;flex-direction:column;align-items:center">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px;align-self:flex-start">🛒 订单状态</div>
          <svg width="180" height="180" viewBox="0 0 180 180">
            ${donutSegments}
            <text x="90" y="85" text-anchor="middle" font-size="28" font-weight="700" fill="var(--text)">${donutTotal}</text>
            <text x="90" y="105" text-anchor="middle" font-size="11" fill="var(--text2)">总订单</text>
          </svg>
          <div style="margin-top:8px">${donutLegend}</div>
        </div>
      </div>

      <!-- Lead Source + Lead 7-day + Hot Products -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px">
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">📞 线索行业分布</div>
          ${leadIndustries.length > 0 ? `<svg width="300" height="${Math.max(barAreaH, 40)}" style="width:100%;height:auto" viewBox="0 0 300 ${Math.max(barAreaH, 40)}">${leadBars}</svg>` : '<div class="empty">暂无线索数据</div>'}
        </div>
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">📊 近7天线索趋势</div>
          ${lead7.length > 0 ? `<svg width="${lead7W}" height="${lead7H}" style="width:100%;height:auto" viewBox="0 0 ${lead7W} ${lead7H}">${lead7Bars}</svg>` : '<div class="empty">暂无数据</div>'}
          <div style="margin-top:12px;display:flex;gap:12px;flex-wrap:wrap">
            <span style="font-size:12px;color:var(--text2)">待处理: <strong style="color:#f59e0b">${(leadSource.byStatus || {}).pending || 0}</strong></span>
            <span style="font-size:12px;color:var(--text2)">已联系: <strong style="color:#3b82f6">${(leadSource.byStatus || {}).processing || 0}</strong></span>
            <span style="font-size:12px;color:var(--text2)">已转化: <strong style="color:#10b981">${(leadSource.byStatus || {}).converted || 0}</strong></span>
            <span style="font-size:12px;color:var(--text2)">已关闭: <strong style="color:var(--text2)">${(leadSource.byStatus || {}).closed || 0}</strong></span>
          </div>
        </div>
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">🔥 热门产品 TOP 8</div>
          ${hotList || '<div class="empty">暂无数据</div>'}
        </div>
      </div>

      <!-- Client Product Performance + Lead Status -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">🏆 甲方产品表现 TOP 5</div>
          ${cpList || '<div class="empty">暂无数据</div>'}
        </div>
        <div class="card" style="padding:20px">
          <div style="font-size:15px;font-weight:600;margin-bottom:12px">📋 线索转化漏斗</div>
          ${(() => {
            const ls = leadSource.byStatus || {};
            const stages = [
              { name: '新线索', value: ls.pending || 0, color: '#fbbf24' },
              { name: '已联系', value: ls.processing || 0, color: '#60a5fa' },
              { name: '已转化', value: ls.converted || 0, color: '#34d399' },
              { name: '已关闭', value: ls.closed || 0, color: '#9ca3af' }
            ];
            const maxVal = Math.max(...stages.map(s => s.value), 1);
            const funnelW = 300;
            return stages.map((s, i) => {
              const w = (s.value / maxVal) * funnelW;
              const pct = s.value > 0 ? ((s.value / (stages[0].value || 1)) * 100).toFixed(0) : 0;
              return `<div style="margin-bottom:10px">
                <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span style="color:var(--text2)">${s.name}</span><span><strong style="color:${s.color}">${s.value}</strong> <span style="color:#d1d5db;font-size:11px">(${pct}%)</span></span></div>
                <div style="background:#f0f2f5;height:20px;border-radius:4px;overflow:hidden"><div style="width:${w}px;height:100%;background:${s.color};border-radius:4px;opacity:0.85;transition:width .5s"></div></div>
              </div>`;
            }).join('');
          })()}
          <div style="margin-top:16px;padding-top:12px;border-top:1px solid #f3f4f6;font-size:12px;color:var(--text2)">
            转化率: <strong style="color:var(--success)">${(() => {
              const ls = leadSource.byStatus || {};
              const total = (ls.pending || 0) + (ls.processing || 0) + (ls.converted || 0) + (ls.closed || 0);
              return total > 0 ? ((ls.converted || 0) / total * 100).toFixed(1) + '%' : '0%';
            })()}</strong>
          </div>
        </div>
      </div>
    `;
  } catch (err) {
    console.error('加载分析数据失败', err);
    document.getElementById('adContent').innerHTML = `<div class="empty">加载失败: ${err.message}</div>`;
  }
}

// --- Contacts ---
async function loadContacts(status = '') {
  const rows = await api('/contact' + (status ? '?status=' + status : ''));
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>咨询管理</h1></div>
    <div class="tabs">
      <span class="tab ${!status?'active':''}" onclick="loadContacts()">全部</span>
      <span class="tab ${status==='pending'?'active':''}" onclick="loadContacts('pending')">待处理</span>
      <span class="tab ${status==='contacted'?'active':''}" onclick="loadContacts('contacted')">已联系</span>
      <span class="tab ${status==='closed'?'active':''}" onclick="loadContacts('closed')">已关闭</span>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>姓名</th><th>公司</th><th>电话</th><th>行业</th><th>需求</th><th>状态</th><th>时间</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.name}</td><td>${r.company||'-'}</td><td>${r.phone}</td><td>${r.industry||'-'}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.demand}</td>
      <td><span class="badge badge-${r.status}">${statusLabel(r.status)}</span></td>
      <td>${r.created_at?.slice(0,16)||''}</td>
      <td><button class="btn btn-sm btn-success" onclick="updateContact(${r.id},'contacted')">已联系</button>
          <button class="btn btn-sm btn-outline" onclick="updateContact(${r.id},'closed')">关闭</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无咨询记录</div>'}
    </div></div>`;
}

function statusLabel(s) { return {pending:'待处理',contacted:'已联系',approved:'已通过',rejected:'已拒绝',closed:'已关闭'}[s]||s; }

async function updateContact(id, status) {
  await api('/contact/' + id, { method: 'PUT', body: JSON.stringify({ status }) });
  loadContacts();
}

// --- Onboardings ---
async function loadOnboardings(status = '') {
  const rows = await api('/onboarding' + (status ? '?status=' + status : ''));
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>入驻管理</h1></div>
    <div class="tabs">
      <span class="tab ${!status?'active':''}" onclick="loadOnboardings()">全部</span>
      <span class="tab ${status==='pending'?'active':''}" onclick="loadOnboardings('pending')">待审核</span>
      <span class="tab ${status==='approved'?'active':''}" onclick="loadOnboardings('approved')">已通过</span>
      <span class="tab ${status==='rejected'?'active':''}" onclick="loadOnboardings('rejected')">已拒绝</span>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>公司</th><th>联系人</th><th>电话</th><th>产品</th><th>类型</th><th>状态</th><th>时间</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.company_name}</td><td>${r.contact_name}</td><td>${r.contact_phone}</td>
      <td>${r.product_title}</td><td>${r.product_type}</td>
      <td><span class="badge badge-${r.status}">${statusLabel(r.status)}</span></td>
      <td>${r.created_at?.slice(0,16)||''}</td>
      <td><button class="btn btn-sm btn-success" onclick="updateOnboarding(${r.id},'approved')">通过</button>
          <button class="btn btn-sm btn-danger" onclick="updateOnboarding(${r.id},'rejected')">拒绝</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无入驻申请</div>'}
    </div></div>`;
}

async function updateOnboarding(id, status) {
  await api('/onboarding/' + id, { method: 'PUT', body: JSON.stringify({ status }) });
  loadOnboardings();
}

// --- Products ---
async function loadProducts() {
  const rows = await api('/admin/products');
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>产品管理</h1><button class="btn btn-primary" onclick="openProductModal()">+ 新增产品</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>图标</th><th>名称</th><th>分类</th><th>价格</th><th>排序</th><th>状态</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.icon}</td><td>${r.title}</td><td>${r.category}</td><td>¥${r.price}${r.unit}</td>
      <td>${r.sort_order}</td>
      <td><span class="badge ${r.published?'badge-approved':'badge-pending'}">${r.published?'已发布':'草稿'}</span></td>
      <td><button class="btn btn-sm btn-outline" onclick="openProductModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteProduct(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无产品，点击右上角新增</div>'}
    </div></div>`;
}

function openProductModal(id) {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑产品' : '新增产品'}</h3>
    <div class="form-group"><label>名称</label><input id="p_title"></div>
    <div class="form-group"><label>副标题</label><input id="p_subtitle"></div>
    <div class="form-group"><label>分类</label><input id="p_category"></div>
    <div class="form-group"><label>痛点</label><input id="p_pain"></div>
    <div class="form-group"><label>价格</label><input id="p_price" type="number"></div>
    <div class="form-group"><label>单位</label><input id="p_unit" value="起"></div>
    <div class="form-group"><label>图标</label><input id="p_icon"></div>
    <div class="form-group"><label>描述</label><textarea id="p_description"></textarea></div>
    <div class="form-group"><label>标签（逗号分隔）</label><input id="p_tags"></div>
    <div class="form-group"><label>亮点（逗号分隔）</label><textarea id="p_highlights"></textarea></div>
    <div class="form-group"><label>案例（逗号分隔）</label><input id="p_cases"></div>
    <div class="form-group"><label>排序</label><input id="p_sort" type="number" value="0"></div>
    <div class="form-group"><label><input id="p_published" type="checkbox" checked> 发布</label></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveProduct(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/admin/products').then(rows => {
      const p = rows.find(r => r.id === id);
      if (!p) return;
      document.getElementById('p_title').value = p.title || '';
      document.getElementById('p_subtitle').value = p.subtitle || '';
      document.getElementById('p_category').value = p.category || '';
      document.getElementById('p_pain').value = p.pain || '';
      document.getElementById('p_price').value = p.price || 0;
      document.getElementById('p_unit').value = p.unit || '';
      document.getElementById('p_icon').value = p.icon || '';
      document.getElementById('p_description').value = p.description || '';
      document.getElementById('p_tags').value = (p.tags||[]).join(',');
      document.getElementById('p_highlights').value = (p.highlights||[]).join('\n');
      document.getElementById('p_cases').value = (p.cases||[]).join(',');
      document.getElementById('p_sort').value = p.sort_order || 0;
      document.getElementById('p_published').checked = !!p.published;
    });
  }
  openModal();
}

async function saveProduct(id) {
  const body = {
    title: document.getElementById('p_title').value,
    subtitle: document.getElementById('p_subtitle').value,
    category: document.getElementById('p_category').value,
    pain: document.getElementById('p_pain').value,
    price: Number(document.getElementById('p_price').value),
    unit: document.getElementById('p_unit').value,
    icon: document.getElementById('p_icon').value,
    description: document.getElementById('p_description').value,
    tags: document.getElementById('p_tags').value.split(',').map(s=>s.trim()).filter(Boolean),
    highlights: document.getElementById('p_highlights').value.split('\n').map(s=>s.trim()).filter(Boolean),
    cases: document.getElementById('p_cases').value.split(',').map(s=>s.trim()).filter(Boolean),
    sort_order: Number(document.getElementById('p_sort').value),
    published: document.getElementById('p_published').checked ? 1 : 0
  };
  if (id) await api('/admin/products/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/admin/products', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadProducts();
}

async function deleteProduct(id) {
  if (!confirm('确定删除此产品？')) return;
  await api('/admin/products/' + id, { method: 'DELETE' });
  loadProducts();
}

// --- Client Products ---
async function loadClientProducts() {
  const rows = await api('/admin/client-products');
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>甲方产品管理</h1><button class="btn btn-primary" onclick="openClientProductModal()">+ 新增甲方产品</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>客户</th><th>产品</th><th>类型</th><th>价格</th><th>状态</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.client_name}</td><td>${r.title}</td><td>${r.type_name}</td>
      <td>${r.price ? '¥'+r.price+r.unit : '面议'}</td>
      <td><span class="badge ${r.published?'badge-approved':'badge-pending'}">${r.published?'已发布':'草稿'}</span></td>
      <td><button class="btn btn-sm btn-outline" onclick="openClientProductModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteClientProduct(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无甲方产品</div>'}
    </div></div>`;
}

function openClientProductModal(id) {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑甲方产品' : '新增甲方产品'}</h3>
    <div class="form-group"><label>客户名称</label><input id="cp_client_name"></div>
    <div class="form-group"><label>客户行业</label><input id="cp_client_industry"></div>
    <div class="form-group"><label>类型</label><select id="cp_type"><option value="product">实体产品</option><option value="service">工程服务</option></select></div>
    <div class="form-group"><label>产品/服务名称</label><input id="cp_title"></div>
    <div class="form-group"><label>副标题</label><input id="cp_subtitle"></div>
    <div class="form-group"><label>价格</label><input id="cp_price" type="number"></div>
    <div class="form-group"><label>单位</label><input id="cp_unit"></div>
    <div class="form-group"><label>描述</label><textarea id="cp_description"></textarea></div>
    <div class="form-group"><label>联系方式</label><input id="cp_contact"></div>
    <div class="form-group"><label><input id="cp_published" type="checkbox" checked> 发布</label></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveClientProduct(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/admin/client-products').then(rows => {
      const p = rows.find(r => r.id === id);
      if (!p) return;
      document.getElementById('cp_client_name').value = p.client_name || '';
      document.getElementById('cp_client_industry').value = p.client_industry || '';
      document.getElementById('cp_type').value = p.type || 'product';
      document.getElementById('cp_title').value = p.title || '';
      document.getElementById('cp_subtitle').value = p.subtitle || '';
      document.getElementById('cp_price').value = p.price || '';
      document.getElementById('cp_unit').value = p.unit || '';
      document.getElementById('cp_description').value = p.description || '';
      document.getElementById('cp_contact').value = p.contact || '';
      document.getElementById('cp_published').checked = !!p.published;
    });
  }
  openModal();
}

async function saveClientProduct(id) {
  const typeVal = document.getElementById('cp_type').value;
  const body = {
    client_name: document.getElementById('cp_client_name').value,
    client_industry: document.getElementById('cp_client_industry').value,
    type: typeVal,
    type_name: typeVal === 'product' ? '实体产品' : '工程服务',
    title: document.getElementById('cp_title').value,
    subtitle: document.getElementById('cp_subtitle').value,
    price: document.getElementById('cp_price').value ? Number(document.getElementById('cp_price').value) : null,
    unit: document.getElementById('cp_unit').value,
    description: document.getElementById('cp_description').value,
    contact: document.getElementById('cp_contact').value,
    published: document.getElementById('cp_published').checked ? 1 : 0
  };
  if (id) await api('/admin/client-products/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/admin/client-products', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadClientProducts();
}

async function deleteClientProduct(id) {
  if (!confirm('确定删除？')) return;
  await api('/admin/client-products/' + id, { method: 'DELETE' });
  loadClientProducts();
}

// --- Articles ---
async function loadArticles() {
  const rows = await api('/admin/articles');
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>文章管理</h1><button class="btn btn-primary" onclick="openArticleModal()">+ 新增文章</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>标题</th><th>分类</th><th>标签</th><th>状态</th><th>时间</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.title}</td>
      <td>${r.category||'-'}</td><td>${r.tag||'-'}</td>
      <td><span class="badge ${r.published?'badge-approved':'badge-pending'}">${r.published?'已发布':'草稿'}</span></td>
      <td>${r.created_at?.slice(0,10)||''}</td>
      <td>
        <button class="btn btn-sm btn-outline" onclick="openArticleModal(${r.id})">编辑</button>
        <button class="btn btn-sm btn-info" onclick="openPushModal(${r.id},'${encodeURIComponent(r.title)}')">推送</button>
        <button class="btn btn-sm btn-danger" onclick="deleteArticle(${r.id})">删除</button>
      </td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无文章</div>'}
    </div></div>`;
}

function openArticleModal(id) {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑文章' : '新增文章'}</h3>
    <div class="form-group"><label>标题</label><input id="a_title"></div>
    <div class="form-group"><label>摘要</label><textarea id="a_summary"></textarea></div>
    <div class="form-group"><label>分类</label><input id="a_category"></div>
    <div class="form-group"><label>标签</label><input id="a_tag"></div>
    <div class="form-group"><label>正文（Markdown）</label><textarea id="a_content" style="min-height:200px"></textarea></div>
    <div class="form-group"><label>封面图URL</label><input id="a_image"></div>
    <div class="form-group"><label><input id="a_published" type="checkbox"> 发布</label></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveArticle(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/admin/articles').then(rows => {
      const a = rows.find(r => r.id === id);
      if (!a) return;
      document.getElementById('a_title').value = a.title || '';
      document.getElementById('a_summary').value = a.summary || '';
      document.getElementById('a_category').value = a.category || '';
      document.getElementById('a_tag').value = a.tag || '';
      document.getElementById('a_content').value = a.content || '';
      document.getElementById('a_image').value = a.image || '';
      document.getElementById('a_published').checked = !!a.published;
    });
  }
  openModal();
}

async function saveArticle(id) {
  const body = {
    title: document.getElementById('a_title').value,
    summary: document.getElementById('a_summary').value,
    category: document.getElementById('a_category').value,
    tag: document.getElementById('a_tag').value,
    content: document.getElementById('a_content').value,
    image: document.getElementById('a_image').value,
    published: document.getElementById('a_published').checked ? 1 : 0
  };
  if (id) await api('/admin/articles/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/admin/articles', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadArticles();
}

async function deleteArticle(id) {
  if (!confirm('确定删除？')) return;
  await api('/admin/articles/' + id, { method: 'DELETE' });
  loadArticles();
}

// --- Push Article ---
async function openPushModal(articleId, articleTitle) {
  const accounts = await api('/wechat/accounts');
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>推送文章</h3>
    <p style="margin-bottom:16px;color:var(--text2);font-size:13px">文章: ${decodeURIComponent(articleTitle)}</p>
    <div class="form-group">
      <label>选择目标公众号</label>
      <select id="push_account_id" style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px">
        <option value="">-- 请选择 --</option>
        ${accounts.map(a => `<option value="${a.id}">${a.name} (${a.wechat_id})</option>`).join('')}
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="confirmPush(${articleId})">确认推送</button>
    </div>`;
  openModal();
}

async function confirmPush(articleId) {
  const accountId = document.getElementById('push_account_id').value;
  if (!accountId) { alert('请选择目标公众号'); return; }
  await api('/wechat/push-article', {
    method: 'POST',
    body: JSON.stringify({ article_id: articleId, account_id: Number(accountId) })
  });
  closeModal();
  alert('推送成功！');
}

// --- WeChat Accounts Management ---
async function loadWechatAccounts() {
  const rows = await api('/wechat/accounts');
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>公众号管理</h1><button class="btn btn-primary" onclick="openWechatAccountModal()">+ 新增公众号</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>名称</th><th>微信号</th><th>类型</th><th>关联客户</th><th>互关状态</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.name}</td>
      <td>${r.wechat_id}</td>
      <td><span class="badge ${r.type==='我方'?'badge-info':'badge-default'}">${r.type}</span></td>
      <td>${r.client_name||'-'}</td>
      <td class="${r.follow_status==='互关'?'follow-mutual':r.follow_status==='单向'?'follow-oneway':'follow-none'}">${r.follow_status||'未关联'}</td>
      <td>
        <button class="btn btn-sm btn-outline" onclick="openWechatAccountModal(${r.id})">编辑</button>
        <button class="btn btn-sm btn-warning" onclick="openFollowModal(${r.id},'${encodeURIComponent(r.name)}','${r.type}')">互关</button>
        <button class="btn btn-sm btn-danger" onclick="deleteWechatAccount(${r.id})">删除</button>
      </td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无公众号，点击右上角新增</div>'}
    </div></div>`;
}

function openWechatAccountModal(id) {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑公众号' : '新增公众号'}</h3>
    <div class="form-group"><label>名称</label><input id="wa_name"></div>
    <div class="form-group"><label>微信号</label><input id="wa_wechat_id"></div>
    <div class="form-group"><label>类型</label><select id="wa_type"><option value="我方">我方</option><option value="甲方">甲方</option></select></div>
    <div class="form-group"><label>关联客户</label><input id="wa_client_name" placeholder="甲方类型时填写"></div>
    <div class="form-group"><label>描述</label><textarea id="wa_description"></textarea></div>
    <div class="form-group"><label>二维码URL</label><input id="wa_qrcode_url"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveWechatAccount(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/wechat/accounts').then(rows => {
      const a = rows.find(r => r.id === id);
      if (!a) return;
      document.getElementById('wa_name').value = a.name || '';
      document.getElementById('wa_wechat_id').value = a.wechat_id || '';
      document.getElementById('wa_type').value = a.type || '我方';
      document.getElementById('wa_client_name').value = a.client_name || '';
      document.getElementById('wa_description').value = a.description || '';
      document.getElementById('wa_qrcode_url').value = a.qrcode_url || '';
    });
  }
  openModal();
}

async function saveWechatAccount(id) {
  const body = {
    name: document.getElementById('wa_name').value,
    wechat_id: document.getElementById('wa_wechat_id').value,
    type: document.getElementById('wa_type').value,
    client_name: document.getElementById('wa_client_name').value,
    description: document.getElementById('wa_description').value,
    qrcode_url: document.getElementById('wa_qrcode_url').value
  };
  if (id) await api('/wechat/accounts/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/wechat/accounts', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadWechatAccounts();
}

async function deleteWechatAccount(id) {
  if (!confirm('确定删除此公众号？')) return;
  await api('/wechat/accounts/' + id, { method: 'DELETE' });
  loadWechatAccounts();
}

// --- Follow Management ---
function openFollowModal(accountId, accountName, accountType) {
  // 只能为我方公众号设置互关状态，选择甲方公众号进行关联
  if (accountType !== '我方') { alert('只能为我方公众号设置互关状态'); return; }
  api('/wechat/accounts').then(rows => {
    const clientAccounts = rows.filter(r => r.type === '甲方');
    const m = document.getElementById('modalContent');
    m.innerHTML = `
      <h3>互关管理 - ${decodeURIComponent(accountName)}</h3>
      <div class="form-group">
        <label>选择甲方公众号</label>
        <select id="follow_client_account_id" style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px">
          <option value="">-- 请选择 --</option>
          ${clientAccounts.map(a => `<option value="${a.id}">${a.name} (${a.wechat_id})</option>`).join('')}
        </select>
      </div>
      <div class="form-group">
        <label>互关状态</label>
        <select id="follow_status" style="width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px">
          <option value="互关">互关</option>
          <option value="单向">单向（我方关注甲方）</option>
          <option value="未关联">未关联</option>
        </select>
      </div>
      <div class="modal-actions">
        <button class="btn btn-outline" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="confirmFollow(${accountId})">确认</button>
      </div>`;
    openModal();
  });
}

async function confirmFollow(myAccountId) {
  const clientAccountId = document.getElementById('follow_client_account_id').value;
  const status = document.getElementById('follow_status').value;
  if (!clientAccountId) { alert('请选择甲方公众号'); return; }
  await api('/wechat/follow', {
    method: 'POST',
    body: JSON.stringify({ my_account_id: myAccountId, client_account_id: Number(clientAccountId), status })
  });
  closeModal(); loadWechatAccounts();
}

// --- Push History Management ---
async function loadPushHistory() {
  const rows = await api('/wechat/push-history');
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>推送管理</h1></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>文章标题</th><th>推送公众号</th><th>推送时间</th><th>状态</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.article_title}</td>
      <td>${r.account_name} (${r.account_wechat_id})</td>
      <td>${r.pushed_at?.slice(0,16)||'-'}</td>
      <td><span class="badge badge-${r.status==='success'?'approved':'rejected'}">${r.status==='success'?'成功':'失败'}</span></td>
      <td><button class="btn btn-sm btn-outline" onclick="deletePushHistory(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无推送记录</div>'}
    </div></div>`;
}

async function deletePushHistory(id) {
  if (!confirm('确定删除此推送记录？')) return;
  await api('/wechat/push-history/' + id, { method: 'DELETE' });
  loadPushHistory();
}

// --- 模板消息管理 ---
async function loadTemplateMsg() {
  const [cfg, stats, logs] = await Promise.all([
    api('/template-msg/config'),
    api('/template-msg/stats'),
    api('/template-msg/logs')
  ]);

  const cfgStatus = cfg.enabled
    ? '<span style="background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:99px;font-size:12px">已启用</span>'
    : '<span style="background:#fef3c7;color:#92400e;padding:3px 10px;border-radius:99px;font-size:12px">未配置</span>';

  const logsHtml = logs.data.length
    ? logs.data.map(r => {
        const sc = {success:'#10b981',failed:'#ef4444',error:'#ef4444',mock:'#6b7280'};
        const lb = {success:'成功',failed:'失败',error:'异常',mock:'MOCK'};
        const req = r.request || {};
        return `<tr>
          <td>${r.id}</td>
          <td><span style="color:${sc[r.status]}">${lb[r.status]||r.status}</span></td>
          <td>${req.name || '-'}</td>
          <td>${req.phone || '-'}</td>
          <td>${req.industry || '-'}</td>
          <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${req.demand || '-'}</td>
          <td style="font-size:12px;color:var(--text2)">${r.created_at?.slice(0,16)||''}</td>
          <td>${r.error ? `<span title="${r.error}" style="color:var(--danger);cursor:pointer">❗</span>` : '-'}</td>
        </tr>`;
      }).join('')
    : '<tr><td colspan="8" style="text-align:center;color:#999">暂无发送记录</td></tr>';

  document.getElementById('mainContent').innerHTML = `
    <div class="header"><h1>📣 模板消息（线索通知）</h1>${cfgStatus}</div>
    <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:10px;padding:16px 20px;margin-bottom:20px;font-size:13px;line-height:1.8">
      <strong>功能说明</strong>：用户在小程序提交联系表单后，系统自动通过公众号模板消息通知管理员。<br>
      <strong>配置方式</strong>：在 <code>.env</code> 中设置以下变量：<br>
      &nbsp;&nbsp;· <code>WECHAT_TEMPLATE_ID</code> — 从公众号后台获取的模板ID<br>
      &nbsp;&nbsp;· <code>WECHAT_ADMIN_OPENID</code> — 管理员微信号对应的 OpenID<br>
      &nbsp;&nbsp;· <code>WECHAT_TEMPLATE_LEAD_URL</code>（可选）— 点击消息跳转的页面<br>
      <strong>未配置时</strong>：自动进入 MOCK 模式，记录发送请求但不真实推送。
    </div>
    <div class="stats">
      <div class="stat-card info"><div class="label">发送总数</div><div class="value">${stats.total}</div></div>
      <div class="stat-card"><div class="label">成功</div><div class="value" style="color:var(--success)">${stats.success}</div></div>
      <div class="stat-card"><div class="label">失败</div><div class="value" style="color:var(--danger)">${stats.failed}</div></div>
      <div class="stat-card"><div class="label">MOCK 记录</div><div class="value" style="color:var(--text2)">${stats.mock}</div></div>
    </div>
    <div class="card">
      <div class="card-header"><h3>发送记录</h3></div>
      <div class="card-body">
        <table>
          <thead><tr><th>ID</th><th>状态</th><th>姓名</th><th>电话</th><th>行业</th><th>需求</th><th>时间</th><th>错误</th></tr></thead>
          <tbody>${logsHtml}</tbody>
        </table>
      </div>
    </div>`;
}

// --- Modal ---

// --- 用户管理 ---
async function loadUsers() {
  const [usersData, ordersData] = await Promise.all([
    api('/auth/admin/users'),
    api('/admin/orders')
  ]);
  const users = usersData.list || [];
  const orders = ordersData || [];

  // 统计每个用户的订单数
  const orderCountMap = {};
  orders.forEach(o => {
    const key = o.buyer_openid || '';
    orderCountMap[key] = (orderCountMap[key] || 0) + 1;
  });

  const rowsHtml = users.length
    ? users.map(u => {
        const phoneDisplay = u.phone || '未绑定';
        const orderCount = orderCountMap[u.openid] || 0;
        const disabled = u.disabled;
        const isAdmin = u.is_admin;
        return `<tr>
          <td>${u.id}</td>
          <td>${u.nickname || '<span style="color:#999">未设置</span>'}</td>
          <td>${phoneDisplay}</td>
          <td>${u.openid ? u.openid.slice(0, 16) + '…' : '-'}</td>
          <td>${orderCount}</td>
          <td>${u.last_login ? u.last_login.slice(0, 16) : '-'}</td>
          <td>${u.created_at ? u.created_at.slice(0, 10) : '-'}</td>
          <td>
            <span class="badge ${isAdmin ? 'badge-info' : disabled ? 'badge-pending' : 'badge-approved'}">
              ${isAdmin ? '管理员' : disabled ? '已禁用' : '正常'}
            </span>
          </td>
          <td>
            <button class="btn btn-sm btn-outline" onclick="openUserModal(${u.id})">详情</button>
            ${!isAdmin ? `<button class="btn btn-sm ${disabled ? 'btn-success' : 'btn-warning'}" onclick="toggleUserStatus(${u.id}, ${disabled})">${disabled ? '启用' : '禁用'}</button>` : ''}
          </td>
        </tr>`;
      }).join('')
    : '<tr><td colspan="9" style="text-align:center;color:#999">暂无用户数据</td></tr>';

  document.getElementById('mainContent').innerHTML = `
    <div class="header"><h1>👥 用户管理</h1><span style="color:var(--text2);font-size:13px">共 ${usersData.total || 0} 位用户</span></div>
    <div class="card"><div class="card-body">
    <table>
      <thead><tr>
        <th>ID</th><th>昵称</th><th>手机</th><th>OpenID</th><th>订单数</th>
        <th>最近登录</th><th>注册时间</th><th>状态</th><th>操作</th>
      </tr></thead>
      <tbody>${rowsHtml}</tbody>
    </table>
    </div></div>`;
}

async function openUserModal(userId) {
  const usersData = await api('/auth/admin/users');
  const u = (usersData.list || []).find(x => x.id === userId);
  if (!u) return alert('用户不存在');

  const ordersData = await api('/admin/orders?openid=' + encodeURIComponent(u.openid || ''));
  const orders = Array.isArray(ordersData) ? ordersData : [];
  const orderRows = orders.length
    ? orders.map(o => {
        const st = {pending:'待支付',paid:'已支付',shipped:'已发货',completed:'已完成',cancelled:'已取消'};
        const sc = {pending:'#fbbf24',paid:'#60a5fa',shipped:'#a78bfa',completed:'#34d399',cancelled:'#f87171'};
        return `<tr><td>${o.order_no}</td><td>${o.product_title||'-'}</td><td>¥${o.amount}</td><td style="color:${sc[o.status]||''}">${st[o.status]||o.status}</td><td>${o.created_at?.slice(0,10)||''}</td></tr>`;
      }).join('')
    : '<tr><td colspan="5" style="text-align:center;color:#999">暂无订单</td></tr>';

  const disabled = u.disabled;
  const isAdmin = u.is_admin;
  document.getElementById('modalContent').innerHTML = `
    <h3>用户详情</h3>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
      <div class="form-group"><label>用户ID</label><div style="padding:8px 0;color:var(--text2)">${u.id}</div></div>
      <div class="form-group"><label>状态</label><div style="padding:8px 0">
        <span class="badge ${isAdmin ? 'badge-info' : disabled ? 'badge-pending' : 'badge-approved'}">
          ${isAdmin ? '管理员' : disabled ? '已禁用' : '正常'}
        </span>
      </div></div>
      <div class="form-group"><label>昵称</label><div style="padding:8px 0">${u.nickname || '<span style="color:#999">未设置</span>'}</div></div>
      <div class="form-group"><label>手机号</label><div style="padding:8px 0">${u.phone || '未绑定'}</div></div>
      <div class="form-group" style="grid-column:1/-1"><label>OpenID</label><div style="padding:8px 0;font-size:12px;color:var(--text2);word-break:break-all">${u.openid||'-'}</div></div>
      <div class="form-group"><label>注册时间</label><div style="padding:8px 0;color:var(--text2)">${u.created_at||'-'}</div></div>
      <div class="form-group"><label>最近登录</label><div style="padding:8px 0;color:var(--text2)">${u.last_login||'-'}</div></div>
    </div>
    <div class="card-header" style="padding:12px 0;border:none"><h3 style="font-size:15px">📋 订单记录（${orders.length} 笔）</h3></div>
    <table style="font-size:12px">
      <thead><tr><th>订单号</th><th>产品</th><th>金额</th><th>状态</th><th>时间</th></tr></thead>
      <tbody>${orderRows}</tbody>
    </table>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">关闭</button>
      ${!isAdmin ? `<button class="btn ${disabled ? 'btn-success' : 'btn-warning'}" onclick="toggleUserStatus(${u.id}, ${disabled}); closeModal()">${disabled ? '启用用户' : '禁用用户'}</button>` : ''}
    </div>`;
  openModal();
}

async function toggleUserStatus(userId, currentlyDisabled) {
  const usersData = await api('/auth/admin/users');
  const u = (usersData.list || []).find(x => x.id === userId);
  if (!u) return;
  await api('/auth/admin/users/' + userId, {
    method: 'PUT',
    body: JSON.stringify({ disabled: !currentlyDisabled })
  });
  loadUsers();
}

// --- 评价管理 ---
async function loadReviews() {
  const rows = await api('/reviews/admin/list');
  const reviews = rows.list || [];
  const mc = document.getElementById('mainContent');

  const statusBadge = (r) => {
    if (r.status === 'published') return '<span class="badge badge-approved">已审核</span>';
    if (r.status === 'pending') return '<span class="badge badge-pending">待审核</span>';
    return '<span class="badge badge-rejected">已拒绝</span>';
  };

  const imageBadge = (imgs) => {
    if (!imgs || !imgs.length) return '-';
    return `<span style="background:#dbeafe;color:#1e40af;padding:2px 8px;border-radius:99px;font-size:11px">${imgs.length}张</span>`;
  };

  const rowsHtml = reviews.length
    ? reviews.map(r => `
      <tr>
        <td>${r.id}</td>
        <td>${r.reviewer_name || '匿名用户'}</td>
        <td>${r.product_title || '-'}</td>
        <td>
          <div style="color:${r.rating >= 4 ? '#10b981' : r.rating >= 3 ? '#f59e0b' : '#ef4444'}">
            ${'★'.repeat(r.rating || 0)}${'☆'.repeat(5 - (r.rating || 0))}
          </div>
        </td>
        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.content || '-'}</td>
        <td>${imageBadge(r.images)}</td>
        <td>${statusBadge(r)}</td>
        <td>${r.created_at?.slice(0, 10) || '-'}</td>
        <td>
          <button class="btn btn-sm btn-success" onclick="approveReview(${r.id}, 'published')">通过</button>
          <button class="btn btn-sm btn-danger" onclick="approveReview(${r.id}, 'rejected')">拒绝</button>
          <button class="btn btn-sm btn-outline" onclick="viewReview(${r.id})">查看</button>
        </td>
      </tr>`).join('')
    : '<tr><td colspan="9" style="text-align:center;color:#999">暂无评价记录</td></tr>';

  const pending = reviews.filter(r => !r.status || r.status === 'pending').length;
  mc.innerHTML = `
    <div class="header">
      <h1>⭐ 评价管理</h1>
      <span style="color:var(--text2);font-size:13px">
        共 ${reviews.length} 条 |
        <span style="color:var(--warning)">待审核 ${pending} 条</span> |
        已通过 ${reviews.filter(r=>r.status==='published').length} 条
      </span>
    </div>
    <div class="card"><div class="card-body">
    <table>
      <thead><tr>
        <th>ID</th><th>用户</th><th>产品</th><th>评分</th><th>内容</th><th>图片</th><th>状态</th><th>时间</th><th>操作</th>
      </tr></thead>
      <tbody>${rowsHtml}</tbody>
    </table>
    </div></div>`;
}

async function approveReview(id, status) {
  await api('/reviews/admin/' + id, {
    method: 'PUT',
    body: JSON.stringify({ status })
  });
  loadReviews();
}

async function viewReview(id) {
  const rowsData = await api('/reviews/admin/list');
  const r = (rowsData.list || []).find(x => x.id === id);
  if (!r) return;

  const imgsHtml = (r.images || []).map(img =>
    `<img src="${img}" style="width:120px;height:120px;object-fit:cover;border-radius:8px;margin-right:8px;cursor:pointer" onclick="window.open('${img}')" onerror="this.style.display='none'">`
  ).join('') || '<span style="color:#999">无图片</span>';

  document.getElementById('modalContent').innerHTML = `
    <h3>评价详情</h3>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;font-size:13px">
      <div><strong>用户：</strong>${r.user_nickname || r.buyer_name || '匿名用户'}</div>
      <div><strong>产品：</strong>${r.product_title || '-'}</div>
      <div><strong>评分：</strong><span style="color:#f59e0b">${'★'.repeat(r.rating||0)}${'☆'.repeat(5-(r.rating||0))}</span></div>
      <div><strong>时间：</strong>${r.created_at?.slice(0,16)||'-'}</div>
    </div>
    <div class="form-group"><label>评价内容</label><div style="padding:8px;background:#f9fafb;border-radius:8px;line-height:1.6">${r.content||'无文字内容'}</div></div>
    <div class="form-group"><label>评价图片（点击放大）</label><div style="padding:8px 0">${imgsHtml}</div></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">关闭</button>
      ${r.approved !== 1 ? `<button class="btn btn-success" onclick="approveReview(${r.id},1); closeModal()">通过审核</button>` : ''}
      ${r.approved !== 0 && r.approved !== null ? `<button class="btn btn-danger" onclick="approveReview(${r.id},0); closeModal()">拒绝</button>` : ''}
    </div>`;
  openModal();
}

// --- 甲方企业管理 ---
async function loadClients() {
  const rows = await api('/admin/clients');
  main.innerHTML = `<h2>🏗️ 甲方企业管理 <button class="btn btn-primary" onclick="openClientEditModal()">+ 新增甲方</button></h2>
  <table><thead><tr><th>ID</th><th>名称</th><th>行业</th><th>规模</th><th>成立</th><th>状态</th><th>操作</th></tr></thead><tbody>
  ${rows.map(r => `<tr><td>${r.id}</td><td>${r.short_name || r.name}</td><td>${r.industry||''}</td><td>${r.team_size||''}</td><td>${r.founded||''}</td><td>${r.published ? '✅ 上线' : '⏸️ 下线'}</td>
  <td><button class="btn btn-sm" onclick="openClientEditModal(${r.id})">编辑</button> <button class="btn btn-sm btn-danger" onclick="deleteClient(${r.id})">删除</button></td></tr>`).join('')}
  </tbody></table>`;
}

async function openClientEditModal(id) {
  let c = {};
  if (id) {
    const rows = await api('/admin/clients');
    c = rows.find(r => r.id === id) || {};
  }
  document.getElementById('modalTitle').textContent = (c.id ? '编辑' : '新增') + '甲方企业';
  const fields = ['name','short_name','industry','avatar','description','team_size','founded','contact_phone','contact_email','address','website','wechat_account_id'];
  const labels = {name:'全称',short_name:'简称',industry:'行业',avatar:'头像emoji',description:'简介',team_size:'团队规模',founded:'成立年份',contact_phone:'联系电话',contact_email:'邮箱',address:'地址',website:'官网',wechat_account_id:'公众号ID'};
  document.getElementById('modalBody').innerHTML = fields.map(f => `<div class="form-group"><label>${labels[f]||f}</label>${f==='description'?`<textarea id="mf_${f}" rows="3">${c[f]||''}</textarea>`:`<input id="mf_${f}" value="${c[f]||''}"/>`}</div>`).join('') +
    `<div class="form-group"><label>上线</label><select id="mf_published"><option value="1" ${c.published!==0?'selected':''}>上线</option><option value="0" ${c.published===0?'selected':''}>下线</option></select></div>`;
  document.getElementById('modalSave').style.display = '';
  document.getElementById('modalSave').onclick = async () => {
    const body = {};
    fields.forEach(f => { body[f] = document.getElementById('mf_'+f).value; });
    body.published = Number(document.getElementById('mf_published').value);
    if (c.id) await api('/admin/clients/'+c.id, {method:'PUT', body:JSON.stringify(body)});
    else await api('/admin/clients', {method:'POST', body:JSON.stringify(body)});
    closeModal(); loadClients();
  };
  openModal();
}

async function deleteClient(id) {
  if (!confirm('确认删除？')) return;
  await api('/admin/clients/'+id, {method:'DELETE'});
  loadClients();
}

// --- 订单管理 ---
async function loadOrders() {
  const rows = await api('/admin/orders');
  const statusText = {pending:'待支付',paid:'已支付',shipped:'已发货',completed:'已完成',cancelled:'已取消'};
  const statusColor = {pending:'#fbbf24',paid:'#60a5fa',shipped:'#a78bfa',completed:'#34d399',cancelled:'#f87171'};
  main.innerHTML = `<h2>🛒 订单管理 <span style="font-size:14px;color:#888">共 ${rows.length} 笔</span></h2>
  <table><thead><tr><th>订单号</th><th>产品</th><th>金额</th><th>买家</th><th>状态</th><th>下单时间</th><th>操作</th></tr></thead><tbody>
  ${rows.map(r => `<tr><td style="font-size:12px">${r.order_no}</td><td>${r.product_title}</td><td>¥${r.amount}</td><td>${r.buyer_name}<br><small>${r.buyer_phone}</small></td>
  <td><span style="color:${statusColor[r.status]||''}">${statusText[r.status]||r.status}</span></td><td style="font-size:12px">${(r.created_at||'').slice(0,16)}</td>
  <td><button class="btn btn-sm" onclick="openOrderAction(${r.id},'${r.status}')">操作</button></td></tr>`).join('')}
  </tbody></table>`;
}

function openOrderAction(id, status) {
  const actions = [];
  if (status === 'pending') actions.push({label:'标记已支付',value:'paid'});
  if (status === 'paid') actions.push({label:'标记已发货',value:'shipped'});
  if (status === 'shipped') actions.push({label:'确认完成',value:'completed'});
  actions.push({label:'取消订单',value:'cancelled'});
  let html = '<h3>订单 #' + id + ' 操作</h3>';
  actions.forEach(a => { html += `<button class="btn btn-sm" style="margin:4px" onclick="updateOrder(${id},'${a.value}')">${a.label}</button>`; });
  if (status === 'paid') html += `<div class="form-group" style="margin-top:12px"><label>物流公司</label><input id="tracking_co"/></div><div class="form-group"><label>物流单号</label><input id="tracking_no"/></div>`;
  document.getElementById('modalTitle').textContent = '订单操作';
  document.getElementById('modalBody').innerHTML = html;
  document.getElementById('modalSave').style.display = 'none';
  openModal();
}

async function updateOrder(id, status) {
  const body = {status};
  if (status === 'shipped') {
    const co = document.getElementById('tracking_co');
    const no = document.getElementById('tracking_no');
    if (co) body.tracking_company = co.value;
    if (no) body.tracking_number = no.value;
  }
  await api('/admin/orders/'+id, {method:'PUT', body:JSON.stringify(body)});
  closeModal(); loadOrders();
}

function openModal() { document.getElementById('modalOverlay').classList.add('active'); }
function closeModal() { document.getElementById('modalOverlay').classList.remove('active'); }

// ==================== CRM 客户管理 ====================
async function loadCrmCustomers() {
  const rows = await api('/crm/customers');
  const mc = document.getElementById('mainContent');
  const statusBadge = (s) => {
    const map = {'跟进中':'badge-pending','已签约':'badge-approved','已流失':'badge-rejected','需求确认':'badge-info','实施中':'badge-contacted'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>🏢 客户管理</h1>
      <div style="display:flex;gap:8px;align-items:center">
        <input id="crmCustSearch" placeholder="搜索公司/联系人/电话" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')loadCrmCustomersSearch()">
        <button class="btn btn-primary" onclick="openCrmCustomerModal()">+ 新增客户</button>
      </div>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>公司名称</th><th>行业</th><th>规模</th><th>联系人</th><th>电话</th><th>状态</th><th>项目经理</th><th>地区</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.company_name||''}</td><td>${r.industry||''}</td><td>${r.scale||''}</td>
      <td>${r.contact_name||''}</td><td>${r.contact_phone||''}</td>
      <td>${statusBadge(r.status)}</td><td>${r.project_manager||''}</td><td>${r.region||''}</td>
      <td><button class="btn btn-sm btn-outline" onclick="openCrmCustomerModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCrmCustomer(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无客户，点击右上角新增</div>'}
    </div></div>`;
}

async function loadCrmCustomersSearch() {
  const kw = document.getElementById('crmCustSearch').value;
  const rows = await api('/crm/customers?search=' + encodeURIComponent(kw));
  const mc = document.getElementById('mainContent');
  const statusBadge = (s) => {
    const map = {'跟进中':'badge-pending','已签约':'badge-approved','已流失':'badge-rejected','需求确认':'badge-info','实施中':'badge-contacted'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>🏢 客户管理</h1>
      <div style="display:flex;gap:8px;align-items:center">
        <input id="crmCustSearch" value="${kw||''}" placeholder="搜索公司/联系人/电话" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')loadCrmCustomersSearch()">
        <button class="btn btn-primary" onclick="openCrmCustomerModal()">+ 新增客户</button>
      </div>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>公司名称</th><th>行业</th><th>规模</th><th>联系人</th><th>电话</th><th>状态</th><th>项目经理</th><th>地区</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.company_name||''}</td><td>${r.industry||''}</td><td>${r.scale||''}</td>
      <td>${r.contact_name||''}</td><td>${r.contact_phone||''}</td>
      <td>${statusBadge(r.status)}</td><td>${r.project_manager||''}</td><td>${r.region||''}</td>
      <td><button class="btn btn-sm btn-outline" onclick="openCrmCustomerModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCrmCustomer(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">未找到匹配客户</div>'}
    </div></div>`;
}

function openCrmCustomerModal(id) {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑客户' : '新增客户'}</h3>
    <div class="form-group"><label>公司名称 *</label><input id="cc_company"></div>
    <div class="form-group"><label>行业</label><input id="cc_industry" placeholder="如：制造业/医药/零售"></div>
    <div class="form-group"><label>规模</label><input id="cc_scale" placeholder="如：小型/中型/大型"></div>
    <div class="form-group"><label>联系人</label><input id="cc_contact_name"></div>
    <div class="form-group"><label>联系电话</label><input id="cc_contact_phone"></div>
    <div class="form-group"><label>状态</label><select id="cc_status">
      <option value="跟进中">跟进中</option><option value="需求确认">需求确认</option>
      <option value="实施中">实施中</option><option value="已签约">已签约</option>
      <option value="已流失">已流失</option>
    </select></div>
    <div class="form-group"><label>签约日期</label><input id="cc_contract_date" type="date"></div>
    <div class="form-group"><label>项目阶段</label><input id="cc_project_phase" placeholder="如：需求调研/开发中/上线运营"></div>
    <div class="form-group"><label>项目经理</label><input id="cc_project_manager"></div>
    <div class="form-group"><label>地区</label><input id="cc_region" placeholder="如：宁夏/山东/广东"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveCrmCustomer(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/crm/customers/' + id).then(r => {
      if (!r) return;
      document.getElementById('cc_company').value = r.company_name || '';
      document.getElementById('cc_industry').value = r.industry || '';
      document.getElementById('cc_scale').value = r.scale || '';
      document.getElementById('cc_contact_name').value = r.contact_name || '';
      document.getElementById('cc_contact_phone').value = r.contact_phone || '';
      document.getElementById('cc_status').value = r.status || '跟进中';
      document.getElementById('cc_contract_date').value = (r.contract_date||'').slice(0,10);
      document.getElementById('cc_project_phase').value = r.project_phase || '';
      document.getElementById('cc_project_manager').value = r.project_manager || '';
      document.getElementById('cc_region').value = r.region || '';
    });
  }
  openModal();
}

async function saveCrmCustomer(id) {
  const body = {
    company_name: document.getElementById('cc_company').value,
    industry: document.getElementById('cc_industry').value,
    scale: document.getElementById('cc_scale').value,
    contact_name: document.getElementById('cc_contact_name').value,
    contact_phone: document.getElementById('cc_contact_phone').value,
    status: document.getElementById('cc_status').value,
    contract_date: document.getElementById('cc_contract_date').value,
    project_phase: document.getElementById('cc_project_phase').value,
    project_manager: document.getElementById('cc_project_manager').value,
    region: document.getElementById('cc_region').value
  };
  if (!body.company_name) return alert('公司名称必填');
  if (id) await api('/crm/customers/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/crm/customers', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmCustomers();
}

async function deleteCrmCustomer(id) {
  if (!confirm('确定删除此客户？相关项目和财务记录也会受影响。')) return;
  await api('/crm/customers/' + id, { method: 'DELETE' });
  loadCrmCustomers();
}

// ==================== CRM 项目管理 ====================
async function loadCrmProjects() {
  const rows = await api('/crm/projects');
  const mc = document.getElementById('mainContent');
  const priColor = {'高':'#ef4444','中':'#f59e0b','低':'#6b7280'};
  const stBadge = (s) => {
    const map = {'需求确认':'badge-info','开发中':'badge-pending','测试中':'badge-contacted','已交付':'badge-approved','已暂停':'badge-rejected'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>📁 项目管理</h1>
      <div style="display:flex;gap:8px;align-items:center">
        <input id="crmProjSearch" placeholder="搜索项目/需求/客户" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')loadCrmProjectsSearch()">
        <button class="btn btn-primary" onclick="openCrmProjectModal()">+ 新增项目</button>
      </div>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>项目名称</th><th>客户</th><th>需求</th><th>模块</th><th>优先级</th><th>状态</th><th>预计工时</th><th>起止日期</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.project_name||r.requirement?.slice(0,20)||'-'}</td><td>${r.customer_name||'-'}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis">${(r.requirement||'').slice(0,40)}</td>
      <td>${r.modules||'-'}</td>
      <td style="color:${priColor[r.priority]||''}">${r.priority||'中'}</td>
      <td>${stBadge(r.status)}</td><td>${r.estimated_hours||0}h</td>
      <td style="font-size:12px">${r.start_date||'?'} ~ ${r.end_date||'?'}</td>
      <td><button class="btn btn-sm btn-outline" onclick="openCrmProjectModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCrmProject(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无项目，点击右上角新增</div>'}
    </div></div>`;
}

async function loadCrmProjectsSearch() {
  const kw = document.getElementById('crmProjSearch').value;
  const rows = await api('/crm/projects?search=' + encodeURIComponent(kw));
  const mc = document.getElementById('mainContent');
  const priColor = {'高':'#ef4444','中':'#f59e0b','低':'#6b7280'};
  const stBadge = (s) => {
    const map = {'需求确认':'badge-info','开发中':'badge-pending','测试中':'badge-contacted','已交付':'badge-approved','已暂停':'badge-rejected'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>📁 项目管理</h1>
      <div style="display:flex;gap:8px;align-items:center">
        <input id="crmProjSearch" value="${kw||''}" placeholder="搜索项目/需求/客户" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')loadCrmProjectsSearch()">
        <button class="btn btn-primary" onclick="openCrmProjectModal()">+ 新增项目</button>
      </div>
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>项目名称</th><th>客户</th><th>需求</th><th>模块</th><th>优先级</th><th>状态</th><th>预计工时</th><th>起止日期</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.project_name||r.requirement?.slice(0,20)||'-'}</td><td>${r.customer_name||'-'}</td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis">${(r.requirement||'').slice(0,40)}</td>
      <td>${r.modules||'-'}</td>
      <td style="color:${priColor[r.priority]||''}">${r.priority||'中'}</td>
      <td>${stBadge(r.status)}</td><td>${r.estimated_hours||0}h</td>
      <td style="font-size:12px">${r.start_date||'?'} ~ ${r.end_date||'?'}</td>
      <td><button class="btn btn-sm btn-outline" onclick="openCrmProjectModal(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCrmProject(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">未找到匹配项目</div>'}
    </div></div>`;
}

async function openCrmProjectModal(id) {
  // 先加载客户列表
  const customers = await api('/crm/customers');
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${id ? '编辑项目' : '新增项目'}</h3>
    <div class="form-group"><label>客户</label><select id="cp_customer_id"><option value="0">-- 选择客户 --</option>${customers.map(c=>`<option value="${c.id}">${c.company_name}</option>`).join('')}</select></div>
    <div class="form-group"><label>项目名称</label><input id="cp_project_name"></div>
    <div class="form-group"><label>需求描述</label><textarea id="cp_requirement"></textarea></div>
    <div class="form-group"><label>模块</label><input id="cp_modules" placeholder="如：ERP、MES、WMS"></div>
    <div class="form-group"><label>优先级</label><select id="cp_priority"><option value="高">高</option><option value="中" selected>中</option><option value="低">低</option></select></div>
    <div class="form-group"><label>状态</label><select id="cp_status">
      <option value="需求确认">需求确认</option><option value="开发中">开发中</option>
      <option value="测试中">测试中</option><option value="已交付">已交付</option><option value="已暂停">已暂停</option>
    </select></div>
    <div class="form-group"><label>预计工时</label><input id="cp_estimated_hours" type="number" value="0"></div>
    <div class="form-group"><label>开始日期</label><input id="cp_start_date" type="date"></div>
    <div class="form-group"><label>结束日期</label><input id="cp_end_date" type="date"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveCrmProject(${id||0})">保存</button>
    </div>`;
  if (id) {
    api('/crm/projects/' + id).then(r => {
      if (!r) return;
      document.getElementById('cp_customer_id').value = r.customer_id || 0;
      document.getElementById('cp_project_name').value = r.project_name || '';
      document.getElementById('cp_requirement').value = r.requirement || '';
      document.getElementById('cp_modules').value = r.modules || '';
      document.getElementById('cp_priority').value = r.priority || '中';
      document.getElementById('cp_status').value = r.status || '需求确认';
      document.getElementById('cp_estimated_hours').value = r.estimated_hours || 0;
      document.getElementById('cp_start_date').value = (r.start_date||'').slice(0,10);
      document.getElementById('cp_end_date').value = (r.end_date||'').slice(0,10);
    });
  }
  openModal();
}

async function saveCrmProject(id) {
  const body = {
    customer_id: Number(document.getElementById('cp_customer_id').value),
    project_name: document.getElementById('cp_project_name').value,
    requirement: document.getElementById('cp_requirement').value,
    modules: document.getElementById('cp_modules').value,
    priority: document.getElementById('cp_priority').value,
    status: document.getElementById('cp_status').value,
    estimated_hours: Number(document.getElementById('cp_estimated_hours').value),
    start_date: document.getElementById('cp_start_date').value,
    end_date: document.getElementById('cp_end_date').value
  };
  if (id) await api('/crm/projects/' + id, { method: 'PUT', body: JSON.stringify(body) });
  else await api('/crm/projects', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmProjects();
}

async function deleteCrmProject(id) {
  if (!confirm('确定删除此项目？')) return;
  await api('/crm/projects/' + id, { method: 'DELETE' });
  loadCrmProjects();
}

// ==================== CRM 商机管理 ====================
async function loadCrmLeads() {
  const rows = await api('/crm/leads');
  const mc = document.getElementById('mainContent');
  const lvlColor = {'A':'#ef4444','B':'#f59e0b','C':'#6b7280'};
  const stBadge = (s) => {
    const map = {'线索':'badge-info','跟进中':'badge-pending','已成交':'badge-approved','已流失':'badge-rejected'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>🎯 商机管理</h1><button class="btn btn-primary" onclick="openCrmLeadModal()">+ 新增商机</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>公司名称</th><th>来源</th><th>联系人</th><th>电话</th><th>意向等级</th><th>预计金额</th><th>状态</th><th>下次跟进</th><th>负责人</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.company_name||''}</td><td>${r.source||''}</td>
      <td>${r.contact_name||''}</td><td>${r.contact_phone||''}</td>
      <td style="color:${lvlColor[r.intention_level]||''};font-weight:600">${r.intention_level||'B'}</td>
      <td>¥${(r.estimated_amount||0).toLocaleString()}</td>
      <td>${stBadge(r.status)}</td><td>${r.next_followup||'-'}</td><td>${r.owner||'-'}</td>
      <td><button class="btn btn-sm btn-outline" onclick="editCrmLead(${r.id})">编辑</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCrmLead(${r.id})">删除</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无商机，点击右上角新增</div>'}
    </div></div>`;
}

function openCrmLeadModal() {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>新增商机</h3>
    <div class="form-group"><label>公司名称 *</label><input id="cl_company_name"></div>
    <div class="form-group"><label>来源</label><input id="cl_source" placeholder="如：线上/转介绍/展会"></div>
    <div class="form-group"><label>联系人</label><input id="cl_contact_name"></div>
    <div class="form-group"><label>联系电话</label><input id="cl_contact_phone"></div>
    <div class="form-group"><label>意向等级</label><select id="cl_intention_level"><option value="A">A（高）</option><option value="B" selected>B（中）</option><option value="C">C（低）</option></select></div>
    <div class="form-group"><label>预计金额</label><input id="cl_estimated_amount" type="number" value="0"></div>
    <div class="form-group"><label>状态</label><select id="cl_status"><option value="线索">线索</option><option value="跟进中">跟进中</option><option value="已成交">已成交</option><option value="已流失">已流失</option></select></div>
    <div class="form-group"><label>下次跟进</label><input id="cl_next_followup" type="date"></div>
    <div class="form-group"><label>负责人</label><input id="cl_owner"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveCrmLead()">保存</button>
    </div>`;
  openModal();
}

async function saveCrmLead() {
  const body = {
    company_name: document.getElementById('cl_company_name').value,
    source: document.getElementById('cl_source').value,
    contact_name: document.getElementById('cl_contact_name').value,
    contact_phone: document.getElementById('cl_contact_phone').value,
    intention_level: document.getElementById('cl_intention_level').value,
    estimated_amount: Number(document.getElementById('cl_estimated_amount').value),
    status: document.getElementById('cl_status').value,
    next_followup: document.getElementById('cl_next_followup').value,
    owner: document.getElementById('cl_owner').value
  };
  if (!body.company_name) return alert('公司名称必填');
  await api('/crm/leads', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmLeads();
}

async function editCrmLead(id) {
  const rows = await api('/crm/leads');
  const r = rows.find(x => x.id === id);
  if (!r) return;
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>编辑商机</h3>
    <div class="form-group"><label>公司名称 *</label><input id="cl_company_name" value="${r.company_name||''}"></div>
    <div class="form-group"><label>来源</label><input id="cl_source" value="${r.source||''}"></div>
    <div class="form-group"><label>联系人</label><input id="cl_contact_name" value="${r.contact_name||''}"></div>
    <div class="form-group"><label>联系电话</label><input id="cl_contact_phone" value="${r.contact_phone||''}"></div>
    <div class="form-group"><label>意向等级</label><select id="cl_intention_level"><option value="A" ${r.intention_level==='A'?'selected':''}>A（高）</option><option value="B" ${r.intention_level==='B'?'selected':''}>B（中）</option><option value="C" ${r.intention_level==='C'?'selected':''}>C（低）</option></select></div>
    <div class="form-group"><label>预计金额</label><input id="cl_estimated_amount" type="number" value="${r.estimated_amount||0}"></div>
    <div class="form-group"><label>状态</label><select id="cl_status"><option value="线索" ${r.status==='线索'?'selected':''}>线索</option><option value="跟进中" ${r.status==='跟进中'?'selected':''}>跟进中</option><option value="已成交" ${r.status==='已成交'?'selected':''}>已成交</option><option value="已流失" ${r.status==='已流失'?'selected':''}>已流失</option></select></div>
    <div class="form-group"><label>下次跟进</label><input id="cl_next_followup" type="date" value="${(r.next_followup||'').slice(0,10)}"></div>
    <div class="form-group"><label>负责人</label><input id="cl_owner" value="${r.owner||''}"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="updateCrmLead(${id})">保存</button>
    </div>`;
  openModal();
}

async function updateCrmLead(id) {
  const body = {
    company_name: document.getElementById('cl_company_name').value,
    source: document.getElementById('cl_source').value,
    contact_name: document.getElementById('cl_contact_name').value,
    contact_phone: document.getElementById('cl_contact_phone').value,
    intention_level: document.getElementById('cl_intention_level').value,
    estimated_amount: Number(document.getElementById('cl_estimated_amount').value),
    status: document.getElementById('cl_status').value,
    next_followup: document.getElementById('cl_next_followup').value,
    owner: document.getElementById('cl_owner').value
  };
  await api('/crm/leads/' + id, { method: 'PUT', body: JSON.stringify(body) });
  closeModal(); loadCrmLeads();
}

async function deleteCrmLead(id) {
  if (!confirm('确定删除此商机？')) return;
  await api('/crm/leads/' + id, { method: 'DELETE' });
  loadCrmLeads();
}

// ==================== CRM 财务管理 ====================
async function loadCrmFinance() {
  const rows = await api('/crm/finance');
  const mc = document.getElementById('mainContent');
  const stBadge = (s) => {
    const map = {'待收款':'badge-pending','已收款':'badge-approved','已逾期':'badge-rejected','部分收款':'badge-info'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>💰 财务管理</h1><button class="btn btn-primary" onclick="openCrmFinanceModal()">+ 新增记录</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>客户</th><th>项目</th><th>发票号</th><th>金额</th><th>类型</th><th>状态</th><th>到期日</th><th>实际收款日</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.customer_name||'-'}</td><td>${r.project_name||'-'}</td>
      <td>${r.invoice_no||'-'}</td><td>¥${(r.amount||0).toLocaleString()}</td>
      <td>${r.type||'-'}</td><td>${stBadge(r.status)}</td>
      <td>${r.due_date||'-'}</td><td>${r.actual_date||'-'}</td>
      <td><button class="btn btn-sm btn-outline" onclick="editCrmFinance(${r.id})">编辑</button></td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无财务记录</div>'}
    </div></div>`;
}

async function openCrmFinanceModal() {
  const customers = await api('/crm/customers');
  const projects = await api('/crm/projects');
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>新增财务记录</h3>
    <div class="form-group"><label>客户</label><select id="cf_customer_id"><option value="0">--</option>${customers.map(c=>`<option value="${c.id}">${c.company_name}</option>`).join('')}</select></div>
    <div class="form-group"><label>项目</label><select id="cf_project_id"><option value="0">--</option>${projects.map(p=>`<option value="${p.id}">${p.project_name||p.requirement?.slice(0,20)||'项目#'+p.id}</option>`).join('')}</select></div>
    <div class="form-group"><label>发票号</label><input id="cf_invoice_no"></div>
    <div class="form-group"><label>金额</label><input id="cf_amount" type="number" value="0"></div>
    <div class="form-group"><label>类型</label><select id="cf_type"><option value="应收款">应收款</option><option value="已收款">已收款</option><option value="退款">退款</option></select></div>
    <div class="form-group"><label>状态</label><select id="cf_status"><option value="待收款">待收款</option><option value="已收款">已收款</option><option value="已逾期">已逾期</option><option value="部分收款">部分收款</option></select></div>
    <div class="form-group"><label>到期日</label><input id="cf_due_date" type="date"></div>
    <div class="form-group"><label>实际收款日</label><input id="cf_actual_date" type="date"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="saveCrmFinance()">保存</button>
    </div>`;
  openModal();
}

async function saveCrmFinance() {
  const body = {
    customer_id: Number(document.getElementById('cf_customer_id').value),
    project_id: Number(document.getElementById('cf_project_id').value),
    invoice_no: document.getElementById('cf_invoice_no').value,
    amount: Number(document.getElementById('cf_amount').value),
    type: document.getElementById('cf_type').value,
    status: document.getElementById('cf_status').value,
    due_date: document.getElementById('cf_due_date').value,
    actual_date: document.getElementById('cf_actual_date').value
  };
  await api('/crm/finance', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmFinance();
}

async function editCrmFinance(id) {
  const rows = await api('/crm/finance');
  const r = rows.find(x => x.id === id);
  if (!r) return;
  const customers = await api('/crm/customers');
  const projects = await api('/crm/projects');
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>编辑财务记录</h3>
    <div class="form-group"><label>客户</label><select id="cf_customer_id"><option value="0">--</option>${customers.map(c=>`<option value="${c.id}" ${r.customer_id===c.id?'selected':''}>${c.company_name}</option>`).join('')}</select></div>
    <div class="form-group"><label>项目</label><select id="cf_project_id"><option value="0">--</option>${projects.map(p=>`<option value="${p.id}" ${r.project_id===p.id?'selected':''}>${p.project_name||p.requirement?.slice(0,20)||'项目#'+p.id}</option>`).join('')}</select></div>
    <div class="form-group"><label>发票号</label><input id="cf_invoice_no" value="${r.invoice_no||''}"></div>
    <div class="form-group"><label>金额</label><input id="cf_amount" type="number" value="${r.amount||0}"></div>
    <div class="form-group"><label>类型</label><select id="cf_type"><option value="应收款" ${r.type==='应收款'?'selected':''}>应收款</option><option value="已收款" ${r.type==='已收款'?'selected':''}>已收款</option><option value="退款" ${r.type==='退款'?'selected':''}>退款</option></select></div>
    <div class="form-group"><label>状态</label><select id="cf_status"><option value="待收款" ${r.status==='待收款'?'selected':''}>待收款</option><option value="已收款" ${r.status==='已收款'?'selected':''}>已收款</option><option value="已逾期" ${r.status==='已逾期'?'selected':''}>已逾期</option><option value="部分收款" ${r.status==='部分收款'?'selected':''}>部分收款</option></select></div>
    <div class="form-group"><label>到期日</label><input id="cf_due_date" type="date" value="${(r.due_date||'').slice(0,10)}"></div>
    <div class="form-group"><label>实际收款日</label><input id="cf_actual_date" type="date" value="${(r.actual_date||'').slice(0,10)}"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">取消</button>
      <button class="btn btn-primary" onclick="updateCrmFinance(${id})">保存</button>
    </div>`;
  openModal();
}

async function updateCrmFinance(id) {
  const body = {
    customer_id: Number(document.getElementById('cf_customer_id').value),
    project_id: Number(document.getElementById('cf_project_id').value),
    invoice_no: document.getElementById('cf_invoice_no').value,
    amount: Number(document.getElementById('cf_amount').value),
    type: document.getElementById('cf_type').value,
    status: document.getElementById('cf_status').value,
    due_date: document.getElementById('cf_due_date').value,
    actual_date: document.getElementById('cf_actual_date').value
  };
  await api('/crm/finance/' + id, { method: 'PUT', body: JSON.stringify(body) });
  closeModal(); loadCrmFinance();
}

// ==================== CRM 团队管理 ====================
async function loadCrmTeam() {
  const [employees, timeLogs, performance] = await Promise.all([
    api('/crm/employees'),
    api('/crm/time-logs'),
    api('/crm/performance')
  ]);
  const mc = document.getElementById('mainContent');
  const empStats = {};
  timeLogs.forEach(t => {
    if (!empStats[t.employee_id]) empStats[t.employee_id] = { hours: 0, logs: 0 };
    empStats[t.employee_id].hours += t.hours || 0;
    empStats[t.employee_id].logs++;
  });
  mc.innerHTML = `
    <div class="header"><h1>👥 团队管理</h1>
      <div style="display:flex;gap:8px">
        <button class="btn btn-primary" onclick="openCrmEmployeeModal()">+ 新增员工</button>
        <button class="btn btn-info" onclick="openCrmTimeLogModal()">+ 记工时</button>
        <button class="btn btn-success" onclick="openCrmPerformanceModal()">+ 录入绩效</button>
      </div>
    </div>
    <div class="stats">
      <div class="stat-card"><div class="label">总人数</div><div class="value">${employees.length}</div></div>
      <div class="stat-card info"><div class="label">总工时记录</div><div class="value">${timeLogs.length}</div></div>
      <div class="stat-card"><div class="label">绩效记录</div><div class="value">${performance.length}</div></div>
    </div>
    <div class="card"><div class="card-body">
      ${employees.length ? `<table><tr><th>ID</th><th>姓名</th><th>角色</th><th>部门</th><th>时薪</th><th>总工时</th><th>工时记录数</th><th>操作</th></tr>
      ${employees.map(r => `<tr>
        <td>${r.id}</td><td>${r.name||''}</td><td>${r.role||''}</td><td>${r.department||''}</td>
        <td>¥${r.hourly_rate||0}/h</td><td>${(empStats[r.id]?.hours||0).toFixed(1)}h</td><td>${empStats[r.id]?.logs||0}</td>
        <td><button class="btn btn-sm btn-outline" onclick="editCrmEmployee(${r.id})">编辑</button></td>
      </tr>`).join('')}</table>` : '<div class="empty">暂无员工</div>'}
    </div></div>
    <h3 style="margin:20px 0 12px">📋 最近工时记录</h3>
    <div class="card"><div class="card-body">
      ${timeLogs.length ? `<table><tr><th>员工</th><th>项目</th><th>日期</th><th>工时</th><th>描述</th></tr>
      ${timeLogs.slice(0,10).map(r => `<tr>
        <td>${r.employee_name||'-'}</td><td>${r.project_name||'-'}</td><td>${r.work_date||'-'}</td>
        <td>${r.hours||0}h</td><td>${(r.description||'').slice(0,50)}</td>
      </tr>`).join('')}</table>` : '<div class="empty">暂无工时记录</div>'}
    </div></div>`;
}

function openCrmEmployeeModal() {
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>新增员工</h3>
    <div class="form-group"><label>姓名 *</label><input id="ce_name"></div>
    <div class="form-group"><label>角色</label><input id="ce_role" placeholder="如：开发工程师/设计师/项目经理"></div>
    <div class="form-group"><label>部门</label><input id="ce_department" placeholder="如：技术部/设计部/销售部"></div>
    <div class="form-group"><label>时薪</label><input id="ce_hourly_rate" type="number" value="0"></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">取消</button><button class="btn btn-primary" onclick="saveCrmEmployee()">保存</button></div>`;
  openModal();
}

async function saveCrmEmployee() {
  const body = {
    name: document.getElementById('ce_name').value,
    role: document.getElementById('ce_role').value,
    department: document.getElementById('ce_department').value,
    hourly_rate: Number(document.getElementById('ce_hourly_rate').value)
  };
  if (!body.name) return alert('姓名必填');
  await api('/crm/employees', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmTeam();
}

async function editCrmEmployee(id) {
  const rows = await api('/crm/employees');
  const r = rows.find(x => x.id === id);
  if (!r) return;
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>编辑员工</h3>
    <div class="form-group"><label>姓名 *</label><input id="ce_name" value="${r.name||''}"></div>
    <div class="form-group"><label>角色</label><input id="ce_role" value="${r.role||''}"></div>
    <div class="form-group"><label>部门</label><input id="ce_department" value="${r.department||''}"></div>
    <div class="form-group"><label>时薪</label><input id="ce_hourly_rate" type="number" value="${r.hourly_rate||0}"></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">取消</button><button class="btn btn-primary" onclick="updateCrmEmployee(${id})">保存</button></div>`;
  openModal();
}

async function updateCrmEmployee(id) {
  const body = {
    name: document.getElementById('ce_name').value,
    role: document.getElementById('ce_role').value,
    department: document.getElementById('ce_department').value,
    hourly_rate: Number(document.getElementById('ce_hourly_rate').value)
  };
  await api('/crm/employees/' + id, { method: 'PUT', body: JSON.stringify(body) });
  closeModal(); loadCrmTeam();
}

async function openCrmTimeLogModal() {
  const [employees, projects] = await Promise.all([api('/crm/employees'), api('/crm/projects')]);
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>记录工时</h3>
    <div class="form-group"><label>员工</label><select id="ct_employee_id">${employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}</select></div>
    <div class="form-group"><label>项目</label><select id="ct_project_id"><option value="0">--</option>${projects.map(p=>`<option value="${p.id}">${p.project_name||p.requirement?.slice(0,20)||'项目#'+p.id}</option>`).join('')}</select></div>
    <div class="form-group"><label>工作日期</label><input id="ct_work_date" type="date" value="${new Date().toISOString().slice(0,10)}"></div>
    <div class="form-group"><label>工时</label><input id="ct_hours" type="number" step="0.5" value="8"></div>
    <div class="form-group"><label>工作描述</label><textarea id="ct_description"></textarea></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">取消</button><button class="btn btn-primary" onclick="saveCrmTimeLog()">保存</button></div>`;
  openModal();
}

async function saveCrmTimeLog() {
  const body = {
    employee_id: Number(document.getElementById('ct_employee_id').value),
    project_id: Number(document.getElementById('ct_project_id').value),
    work_date: document.getElementById('ct_work_date').value,
    hours: Number(document.getElementById('ct_hours').value),
    description: document.getElementById('ct_description').value
  };
  await api('/crm/time-logs', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmTeam();
}

async function openCrmPerformanceModal() {
  const employees = await api('/crm/employees');
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>录入绩效</h3>
    <div class="form-group"><label>员工</label><select id="cpf_employee_id">${employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}</select></div>
    <div class="form-group"><label>评估日期</label><input id="cpf_evaluation_date" type="date" value="${new Date().toISOString().slice(0,10)}"></div>
    <div class="form-group"><label>工时得分 (0-100)</label><input id="cpf_work_hours_score" type="number" value="80"></div>
    <div class="form-group"><label>质量得分 (0-100)</label><input id="cpf_quality_score" type="number" value="80"></div>
    <div class="form-group"><label>进度得分 (0-100)</label><input id="cpf_progress_score" type="number" value="80"></div>
    <div class="form-group"><label>改进得分 (0-100)</label><input id="cpf_improvement_score" type="number" value="80"></div>
    <div class="form-group"><label>反馈</label><textarea id="cpf_feedback"></textarea></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">取消</button><button class="btn btn-primary" onclick="saveCrmPerformance()">保存</button></div>`;
  openModal();
}

async function saveCrmPerformance() {
  const wh = Number(document.getElementById('cpf_work_hours_score').value);
  const q = Number(document.getElementById('cpf_quality_score').value);
  const p = Number(document.getElementById('cpf_progress_score').value);
  const i = Number(document.getElementById('cpf_improvement_score').value);
  const body = {
    employee_id: Number(document.getElementById('cpf_employee_id').value),
    evaluation_date: document.getElementById('cpf_evaluation_date').value,
    work_hours_score: wh, quality_score: q, progress_score: p, improvement_score: i,
    total_score: ((wh+q+p+i)/4).toFixed(1),
    feedback: document.getElementById('cpf_feedback').value
  };
  await api('/crm/performance', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmTeam();
}

// ==================== CRM 日报审核 ====================
async function loadCrmReports() {
  const rows = await api('/crm/progress-reports');
  const mc = document.getElementById('mainContent');
  const stBadge = (s) => {
    const map = {'待审核':'badge-pending','已通过':'badge-approved','已驳回':'badge-rejected'};
    return `<span class="badge ${map[s]||'badge-default'}">${s||'-'}</span>`;
  };
  mc.innerHTML = `
    <div class="header"><h1>📝 日报审核</h1><button class="btn btn-primary" onclick="openCrmReportModal()">+ 提交日报</button></div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>ID</th><th>员工</th><th>项目</th><th>日期</th><th>进度</th><th>问题</th><th>解决方案</th><th>下一步</th><th>状态</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td>${r.id}</td><td>${r.employee_name||'-'}</td><td>${r.project_name||'-'}</td>
      <td>${r.report_date||'-'}</td><td>${r.progress_percent||0}%</td>
      <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis">${(r.issues||'').slice(0,40)}</td>
      <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis">${(r.solutions||'').slice(0,40)}</td>
      <td style="max-width:150px;overflow:hidden;text-overflow:ellipsis">${(r.next_plan||'').slice(0,40)}</td>
      <td>${stBadge(r.status)}</td>
      <td>${r.status==='待审核' ? `<button class="btn btn-sm btn-success" onclick="approveCrmReport(${r.id})">通过</button><button class="btn btn-sm btn-danger" onclick="rejectCrmReport(${r.id})">驳回</button>` : '-'}</td>
    </tr>`).join('')}</table>` : '<div class="empty">暂无日报</div>'}
    </div></div>`;
}

async function openCrmReportModal() {
  const [employees, projects] = await Promise.all([api('/crm/employees'), api('/crm/projects')]);
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>提交日报</h3>
    <div class="form-group"><label>员工</label><select id="cr_employee_id">${employees.map(e=>`<option value="${e.id}">${e.name}</option>`).join('')}</select></div>
    <div class="form-group"><label>项目</label><select id="cr_project_id"><option value="0">--</option>${projects.map(p=>`<option value="${p.id}">${p.project_name||p.requirement?.slice(0,20)||'项目#'+p.id}</option>`).join('')}</select></div>
    <div class="form-group"><label>日期</label><input id="cr_report_date" type="date" value="${new Date().toISOString().slice(0,10)}"></div>
    <div class="form-group"><label>进度 (%)</label><input id="cr_progress_percent" type="number" value="0" min="0" max="100"></div>
    <div class="form-group"><label>遇到的问题</label><textarea id="cr_issues"></textarea></div>
    <div class="form-group"><label>解决方案</label><textarea id="cr_solutions"></textarea></div>
    <div class="form-group"><label>下一步计划</label><textarea id="cr_next_plan"></textarea></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">取消</button><button class="btn btn-primary" onclick="saveCrmReport()">保存</button></div>`;
  openModal();
}

async function saveCrmReport() {
  const body = {
    employee_id: Number(document.getElementById('cr_employee_id').value),
    project_id: Number(document.getElementById('cr_project_id').value),
    report_date: document.getElementById('cr_report_date').value,
    progress_percent: Number(document.getElementById('cr_progress_percent').value),
    issues: document.getElementById('cr_issues').value,
    solutions: document.getElementById('cr_solutions').value,
    next_plan: document.getElementById('cr_next_plan').value
  };
  await api('/crm/progress-reports', { method: 'POST', body: JSON.stringify(body) });
  closeModal(); loadCrmReports();
}

async function approveCrmReport(id) {
  await api('/crm/progress-reports/' + id, { method: 'PUT', body: JSON.stringify({ status: '已通过' }) });
  loadCrmReports();
}

async function rejectCrmReport(id) {
  await api('/crm/progress-reports/' + id, { method: 'PUT', body: JSON.stringify({ status: '已驳回' }) });
  loadCrmReports();
}

// ==================== CRM 报价工具 ====================
async function loadCrmQuote() {
  const [modules, packages] = await Promise.all([api('/crm/price-modules'), api('/crm/price-packages')]);
  const mc = document.getElementById('mainContent');
  // 按category分组模块
  const categories = {};
  modules.forEach(m => {
    const cat = m.category || '其他';
    if (!categories[cat]) categories[cat] = [];
    categories[cat].push(m);
  });
  mc.innerHTML = `
    <div class="header"><h1>💼 报价工具</h1></div>
    <div class="tabs">
      <span class="tab active" onclick="document.getElementById('quoteModules').style.display='block';document.getElementById('quotePackages').style.display='none';this.classList.add('active');this.nextElementSibling.classList.remove('active')">模块库</span>
      <span class="tab" onclick="document.getElementById('quoteModules').style.display='none';document.getElementById('quotePackages').style.display='block';this.classList.add('active');this.previousElementSibling.classList.remove('active')">套餐方案</span>
    </div>
    <div id="quoteModules">
      ${Object.entries(categories).map(([cat, mods]) => `
        <div class="card"><div class="card-header"><h3>${cat}</h3></div><div class="card-body">
        <table><tr><th>模块</th><th>推荐</th><th>规模</th><th>功能</th><th>价格范围</th><th>备注</th></tr>
        ${mods.map(m => `<tr>
          <td><strong>${m.module_name}</strong></td><td>${m.recommend||''}</td><td>${m.scale||''}</td>
          <td style="max-width:300px;font-size:12px">${m.features||''}</td>
          <td><strong>${m.price_range||''}</strong>${m.price_high?'<br><small>高端：'+m.price_high+'</small>':''}</td>
          <td style="font-size:12px">${m.notes||''}</td>
        </tr>`).join('')}</table>
        </div></div>
      `).join('')}
    </div>
    <div id="quotePackages" style="display:none">
      <div class="stats">
        ${packages.map(p => `
          <div class="stat-card" style="cursor:pointer" onclick="viewCrmPackage(${p.id})">
            <div style="font-size:32px">${p.pkg_emoji||'📦'}</div>
            <div class="label" style="margin-top:8px;font-size:15px;font-weight:700">${p.pkg_name}</div>
            <div style="font-size:12px;color:#888;margin-top:4px">${p.target||''}</div>
            <div style="font-size:20px;font-weight:700;margin-top:8px;color:var(--primary)">${p.total_fee||'面议'}</div>
          </div>
        `).join('')}
      </div>
    </div>
  `;
  // Store packages globally for detail view
  window._crmPackages = packages;
}

function viewCrmPackage(id) {
  const p = window._crmPackages?.find(x => x.id === id);
  if (!p) return;
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>${p.pkg_emoji||'📦'} ${p.pkg_name}</h3>
    <div class="form-group"><label>目标客户</label><p>${p.target||'-'}</p></div>
    <div class="form-group"><label>包含模块</label><p>${p.modules||'-'}</p></div>
    <div class="form-group"><label>软件费</label><p>${p.software_fee||'-'}</p></div>
    <div class="form-group"><label>实施费</label><p>${p.impl_fee||'-'}</p></div>
    <div class="form-group"><label>总价</label><p style="font-size:24px;font-weight:700;color:var(--primary)">${p.total_fee||'-'}</p></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">关闭</button></div>
  `;
  openModal();
}

// ==================== CRM 知识库 ====================
async function loadCrmKb() {
  const rows = await api('/crm/knowledge-base');
  const mc = document.getElementById('mainContent');
  const categories = {};
  rows.forEach(r => {
    const cat = r.category || '其他';
    if (!categories[cat]) categories[cat] = [];
    categories[cat].push(r);
  });
  mc.innerHTML = `
    <div class="header"><h1>📚 内部知识库</h1>
      <input id="kbSearch" placeholder="搜索标题/摘要/标签" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')searchCrmKb()">
    </div>
    ${Object.entries(categories).map(([cat, items]) => `
      <div class="card"><div class="card-header"><h3>${cat}</h3></div><div class="card-body">
      <table><tr><th>标题</th><th>标签</th><th>摘要</th><th>更新时间</th><th>操作</th></tr>
      ${items.map(r => `<tr>
        <td><strong>${r.title||''}</strong></td>
        <td>${r.tags||'-'}</td>
        <td style="max-width:300px;font-size:12px">${(r.summary||'').slice(0,80)}</td>
        <td style="font-size:12px">${(r.updated_at||'').slice(0,10)}</td>
        <td>${r.file ? `<button class="btn btn-sm btn-info" onclick="viewCrmKbFile('${r.file.replace(/'/g,"\\'")}')">查看文件</button>` : '-'}</td>
      </tr>`).join('')}</table>
      </div></div>
    `).join('')}
  `;
}

async function searchCrmKb() {
  const kw = document.getElementById('kbSearch').value;
  const rows = await api('/crm/knowledge-base?search=' + encodeURIComponent(kw));
  const mc = document.getElementById('mainContent');
  mc.innerHTML = `
    <div class="header"><h1>📚 内部知识库</h1>
      <input id="kbSearch" value="${kw||''}" placeholder="搜索标题/摘要/标签" style="padding:6px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:220px" onkeyup="if(event.key==='Enter')searchCrmKb()">
    </div>
    <div class="card"><div class="card-body">
    ${rows.length ? `<table><tr><th>标题</th><th>分类</th><th>标签</th><th>摘要</th><th>更新时间</th><th>操作</th></tr>
    ${rows.map(r => `<tr>
      <td><strong>${r.title||''}</strong></td><td>${r.category||'-'}</td><td>${r.tags||'-'}</td>
      <td style="max-width:300px;font-size:12px">${(r.summary||'').slice(0,80)}</td>
      <td style="font-size:12px">${(r.updated_at||'').slice(0,10)}</td>
      <td>${r.file ? `<button class="btn btn-sm btn-info" onclick="viewCrmKbFile('${r.file.replace(/'/g,"\\'")}')">查看文件</button>` : '-'}</td>
    </tr>`).join('')}</table>` : '<div class="empty">未找到匹配结果</div>'}
    </div></div>
  `;
}

function viewCrmKbFile(filepath) {
  // 知识库文件是本地markdown，这里只显示路径
  const m = document.getElementById('modalContent');
  m.innerHTML = `
    <h3>文件路径</h3>
    <div class="form-group"><p style="word-break:break-all;font-family:monospace;font-size:12px;background:#f5f5f5;padding:12px;border-radius:8px">${filepath}</p></div>
    <div class="form-group"><label>提示</label><p style="color:#888;font-size:13px">知识库文件存储在服务器本地，请通过文件管理器或终端访问查看完整内容。</p></div>
    <div class="modal-actions"><button class="btn btn-outline" onclick="closeModal()">关闭</button></div>
  `;
  openModal();
}

// --- 运营报告 ---
async function loadReports() {
  const main = document.getElementById('mainContent');
  main.innerHTML = `<div class="header"><h1>📊 运营报告</h1><div style="display:flex;gap:8px"><button class="btn btn-outline" onclick="generateReport('daily')">生成日报</button><button class="btn btn-outline" onclick="generateReport('weekly')">生成周报</button><button class="btn btn-outline" onclick="generateReport('monthly')">生成月报</button></div></div><div id="reportsStats">加载中...</div><div style="margin:16px 0;display:flex;gap:8px"><select id="reportTypeFilter" onchange="loadReportsList()" style="padding:6px 12px;border:1px solid var(--border);border-radius:6px;background:#fff"><option value="all">全部类型</option><option value="daily">日报</option><option value="weekly">周报</option><option value="monthly">月报</option></select></div><div id="reportsList">加载中...</div>`;
  // 概览统计
  try {
    const s = await api('/reports/overview/stats');
    document.getElementById('reportsStats').innerHTML = `
      <div class="stats">
        <div class="stat-card"><div class="label">总报告数</div><div class="value">${s.total}</div></div>
        <div class="stat-card"><div class="label">日报</div><div class="value">${s.daily}</div></div>
        <div class="stat-card"><div class="label">周报</div><div class="value">${s.weekly}</div></div>
        <div class="stat-card"><div class="label">月报</div><div class="value">${s.monthly}</div></div>
        <div class="stat-card"><div class="label">已推送</div><div class="value">${s.sent}</div></div>
      </div>`;
  } catch(e) { document.getElementById('reportsStats').innerHTML = '<p style="color:#999;padding:16px">统计加载失败</p>'; }
  await loadReportsList();
}

async function loadReportsList() {
  const type = document.getElementById('reportTypeFilter')?.value || 'all';
  const el = document.getElementById('reportsList');
  el.innerHTML = '<p style="color:#999;padding:16px">加载中...</p>';
  try {
    const data = await api(`/reports/list?type=${type}&page=1&limit=50`);
    if (!data.data || data.data.length === 0) {
      el.innerHTML = '<div style="text-align:center;padding:40px;color:#999"><p>📭 暂无报告</p><p style="font-size:13px;margin-top:8px">点击上方按钮手动生成，或等待系统自动生成</p></div>';
      return;
    }
    const typeMap = {daily:'日报',weekly:'周报',monthly:'月报'};
    const typeColor = {daily:'#3b82f6',weekly:'#8b5cf6',monthly:'#f59e0b'};
    const statusMap = {generated:'已生成',sent:'已推送',archived:'已归档'};
    const statusColor = {generated:'#6b7280',sent:'#10b981',archived:'#9ca3af'};
    el.innerHTML = '<table class="data-table"><thead><tr><th>类型</th><th>日期</th><th>标题</th><th>摘要</th><th>状态</th><th>操作</th></tr></thead><tbody>' +
      data.data.map(r => `<tr>
        <td><span style="background:${typeColor[r.report_type]}20;color:${typeColor[r.report_type]};padding:2px 8px;border-radius:99px;font-size:12px">${typeMap[r.report_type]||r.report_type}</span></td>
        <td style="font-size:13px">${r.report_date}</td>
        <td style="font-size:13px;font-weight:600">${r.title}</td>
        <td style="font-size:12px;color:var(--text2);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.summary||'-'}</td>
        <td><span style="background:${statusColor[r.status]}20;color:${statusColor[r.status]};padding:2px 8px;border-radius:99px;font-size:12px">${statusMap[r.status]||r.status}</span></td>
        <td><button class="btn btn-sm btn-outline" onclick="viewReport(${r.id})">查看</button> <button class="btn btn-sm" style="background:#ef4444;color:#fff" onclick="deleteReport(${r.id})">删除</button></td>
      </tr>`).join('') + '</tbody></table>';
  } catch(e) { el.innerHTML = '<p style="color:#f87171;padding:16px">加载失败: '+e.message+'</p>'; }
}

async function generateReport(type) {
  const today = new Date().toISOString().slice(0,10);
  let dateStr = today;
  let label = '今日';
  if (type === 'weekly') { label = '本周'; }
  if (type === 'monthly') { dateStr = new Date().toISOString().slice(0,7); label = '本月'; }
  if (!confirm(`确认生成${type==='daily'?'日报':type==='weekly'?'周报':'月报'}（${label}）？`)) return;
  try {
    const r = await api('/reports/generate', { method:'POST', body: JSON.stringify({ type, date: dateStr }) });
    alert('✅ '+r.message+'\n\n'+r.summary);
    await loadReportsList();
  } catch(e) {
    if (e.message && e.message.includes('已存在')) { alert('⚠️ 该日期的报告已存在，请直接查看'); }
    else { alert('❌ 生成失败: '+(e.message||'未知错误')); }
  }
}

async function viewReport(id) {
  try {
    const r = await api(`/reports/${id}`);
    const typeMap = {daily:'日报',weekly:'周报',monthly:'月报'};
    const m = r.metrics || {};
    const c = r.content || {};
    // 构建报告详情 HTML
    let metricsHtml = '';
    const metricCards = [
      {label:'成交订单', value:m.orders||0, color:'#3b82f6'},
      {label:'营收金额', value:'¥'+(m.revenue||0), color:'#10b981'},
      {label:'新增线索', value:m.newLeads||0, color:'#f59e0b'},
      {label:'转化率', value:m.conversionRate||'0%', color:'#8b5cf6'},
      {label:'活跃用户', value:m.activeUsers||0, color:'#06b6d4'},
      {label:'新增用户', value:m.newUsers||0, color:'#ec4899'},
      {label:'行为事件', value:m.totalEvents||0, color:'#6366f1'},
      {label:'新增入驻', value:m.newOnboardings||0, color:'#14b8a6'},
    ];
    metricsHtml = '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px">' +
      metricCards.map(mc => `<div style="background:#f9fafb;border-radius:8px;padding:12px;text-align:center"><div style="font-size:12px;color:#6b7280;margin-bottom:4px">${mc.label}</div><div style="font-size:20px;font-weight:700;color:${mc.color}">${mc.value}</div></div>`).join('') + '</div>';

    // 转化漏斗
    let funnelHtml = '';
    if (c.behavior && c.behavior.funnel) {
      const f = c.behavior.funnel;
      const stages = [{n:'触达',v:f.reach,c:'#3b82f6'},{n:'兴趣',v:f.interest,c:'#8b5cf6'},{n:'意向',v:f.intent,c:'#f59e0b'},{n:'下单',v:f.order,c:'#ef4444'},{n:'支付',v:f.pay,c:'#10b981'}];
      const max = Math.max(...stages.map(s=>s.v),1);
      funnelHtml = '<div style="margin-bottom:20px"><h3 style="font-size:14px;margin-bottom:10px">转化漏斗</h3>' +
        stages.map(s => `<div style="display:flex;align-items:center;margin-bottom:6px"><span style="width:50px;font-size:12px">${s.n}</span><div style="flex:1;height:24px;background:#f3f4f6;border-radius:4px;overflow:hidden"><div style="height:100%;width:${(s.v/max*100)}%;background:${s.c};display:flex;align-items:center;padding-left:8px;color:#fff;font-size:12px">${s.v}</div></div></div>`).join('') + '</div>';
    }

    // 线索阶段分布
    let contactsHtml = '';
    if (c.contacts && c.contacts.byStage) {
      const stageNames = {new:'新线索',contacted:'已联系',qualified:'已合格',proposal:'方案报价',negotiation:'谈判中',won:'已成交',lost:'已流失'};
      const stageColors = {new:'#3b82f6',contacted:'#8b5cf6',qualified:'#f59e0b',proposal:'#06b6d4',negotiation:'#ec4899',won:'#10b981',lost:'#6b7280'};
      contactsHtml = '<div style="margin-bottom:20px"><h3 style="font-size:14px;margin-bottom:10px">线索阶段分布</h3><div style="display:flex;gap:8px;flex-wrap:wrap">' +
        Object.entries(c.contacts.byStage).map(([k,v]) => `<span style="background:${stageColors[k]}20;color:${stageColors[k]};padding:4px 12px;border-radius:99px;font-size:12px">${stageNames[k]||k}: ${v}</span>`).join('') + '</div></div>';
    }

    // 订单状态
    let ordersHtml = '';
    if (c.orders && c.orders.byStatus) {
      const stNames = {pending:'待支付',paid:'已支付',shipped:'已发货',completed:'已完成',cancelled:'已取消'};
      ordersHtml = '<div style="margin-bottom:20px"><h3 style="font-size:14px;margin-bottom:10px">订单状态分布</h3><div style="display:flex;gap:8px;flex-wrap:wrap">' +
        Object.entries(c.orders.byStatus).map(([k,v]) => `<span style="background:#f3f4f6;padding:4px 12px;border-radius:99px;font-size:12px">${stNames[k]||k}: ${v}</span>`).join('') + '</div></div>';
    }

    // 热门产品
    let topProductsHtml = '';
    if (c.products && c.products.topViewed && c.products.topViewed.length > 0) {
      topProductsHtml = '<div style="margin-bottom:20px"><h3 style="font-size:14px;margin-bottom:10px">热门产品 TOP10</h3><table class="data-table"><thead><tr><th>产品名称</th><th>浏览次数</th></tr></thead><tbody>' +
        c.products.topViewed.map(p => `<tr><td style="font-size:13px">${p.product_title||'-'}</td><td>${p.view_count}</td></tr>`).join('') + '</tbody></table></div>';
    }

    // 热门搜索词
    let searchHtml = '';
    if (c.behavior && c.behavior.topSearchKeywords && c.behavior.topSearchKeywords.length > 0) {
      searchHtml = '<div style="margin-bottom:20px"><h3 style="font-size:14px;margin-bottom:10px">热门搜索词</h3><div style="display:flex;gap:6px;flex-wrap:wrap">' +
        c.behavior.topSearchKeywords.map(([kw,cnt]) => `<span style="background:#dbeafe;color:#1e40af;padding:4px 12px;border-radius:99px;font-size:12px">${kw} (${cnt})</span>`).join('') + '</div></div>';
    }

    // 统计周期
    const periodHtml = `<div style="background:#f9fafb;padding:10px;border-radius:6px;margin-bottom:16px;font-size:13px;color:#6b7280">统计周期: ${r.period_start} ~ ${r.period_end}</div>`;

    document.getElementById('modalContent').innerHTML = `
      <div style="margin-bottom:16px"><h2 style="font-size:18px">${r.title}</h2><p style="font-size:13px;color:#6b7280;margin-top:4px">${r.summary}</p></div>
      ${periodHtml}
      ${metricsHtml}
      ${funnelHtml}
      ${contactsHtml}
      ${ordersHtml}
      ${topProductsHtml}
      ${searchHtml}
      <div style="display:flex;gap:8px;margin-top:20px">
        <button class="btn btn-outline" onclick="closeModal()">关闭</button>
        <button class="btn" onclick="markReportSent(${r.id})" style="background:#10b981;color:#fff">标记已推送</button>
        <button class="btn" onclick="archiveReport(${r.id})" style="background:#6b7280;color:#fff">归档</button>
      </div>
    `;
    openModal();
  } catch(e) { alert('加载失败: '+e.message); }
}

async function deleteReport(id) {
  if (!confirm('确认删除此报告？')) return;
  try {
    await api(`/reports/${id}`, { method:'DELETE' });
    await loadReportsList();
  } catch(e) { alert('删除失败: '+e.message); }
}

async function markReportSent(id) {
  try {
    await api(`/reports/${id}/status`, { method:'PUT', body: JSON.stringify({ status:'sent' }) });
    closeModal();
    await loadReportsList();
    alert('✅ 已标记为已推送');
  } catch(e) { alert('操作失败: '+e.message); }
}

async function archiveReport(id) {
  try {
    await api(`/reports/${id}/status`, { method:'PUT', body: JSON.stringify({ status:'archived' }) });
    closeModal();
    await loadReportsList();
    alert('✅ 已归档');
  } catch(e) { alert('操作失败: '+e.message); }
}

// --- 数字化评估管理 ---
let assessmentFilter = { level: '', industry: '', status: '', keyword: '' };

async function loadAssessments() {
  content.innerHTML = `
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>📋 数字化成熟度评估</h2>
      <button class="btn btn-primary btn-sm" onclick="loadAssessmentStats()">刷新统计</button>
    </div>
    <div id="assessment-stats"></div>
    <div class="card mt-3">
      <div class="card-body">
        <div class="row mb-3">
          <div class="col">
            <select class="form-control form-control-sm" id="asmt-level-filter" onchange="assessmentFilter.level=this.value;loadAssessmentList()">
              <option value="">全部等级</option>
              <option value="beginner">起步期</option>
              <option value="exploring">探索期</option>
              <option value="intermediate">成长期</option>
              <option value="advanced">成熟期</option>
            </select>
          </div>
          <div class="col">
            <input class="form-control form-control-sm" id="asmt-keyword" placeholder="搜索公司/姓名/手机" oninput="assessmentFilter.keyword=this.value;loadAssessmentList()">
          </div>
          <div class="col">
            <select class="form-control form-control-sm" id="asmt-status-filter" onchange="assessmentFilter.status=this.value;loadAssessmentList()">
              <option value="">全部状态</option>
              <option value="completed">待跟进</option>
              <option value="contacted">已联系</option>
              <option value="converted">已转化</option>
            </select>
          </div>
        </div>
        <div id="assessment-list">加载中...</div>
      </div>
    </div>
    <div id="assessment-detail-modal" class="modal-overlay" style="display:none">
      <div class="modal-box" style="max-width:700px">
        <div class="modal-header">
          <h3>评估详情</h3>
          <button class="btn-close" onclick="closeAsmtModal()">×</button>
        </div>
        <div id="assessment-detail-body" style="max-height:70vh;overflow-y:auto"></div>
      </div>
    </div>
  `;
  await loadAssessmentStats();
  await loadAssessmentList();
}

async function loadAssessmentStats() {
  try {
    const stats = await api('/assessments/stats/overview');
    const el = document.getElementById('assessment-stats');
    if (!el) return;
    const levelLabels = { beginner: '起步期', exploring: '探索期', intermediate: '成长期', advanced: '成熟期' };
    const levelColors = { beginner: '#ef4444', exploring: '#f59e0b', intermediate: '#3b82f6', advanced: '#10b981' };
    el.innerHTML = `
      <div class="row mb-2">
        <div class="col-3"><div class="stat-card text-center"><div style="font-size:24px;font-weight:700;color:#2563eb">${stats.total}</div><div style="font-size:12px;color:#999">总评估数</div></div></div>
        <div class="col-3"><div class="stat-card text-center"><div style="font-size:24px;font-weight:700;color:#10b981">${stats.avgScore}</div><div style="font-size:12px;color:#999">平均分</div></div></div>
        <div class="col-3"><div class="stat-card text-center"><div style="font-size:24px;font-weight:700;color:#f59e0b">${stats.recentCount}</div><div style="font-size:12px;color:#999">近7天</div></div></div>
        <div class="col-3"><div class="stat-card text-center"><div style="font-size:24px;font-weight:700;color:#8b5cf6">${stats.conversionRate}%</div><div style="font-size:12px;color:#999">转化率</div></div></div>
      </div>
      <div style="background:#f8f9fb;border-radius:10px;padding:16px;margin-bottom:12px">
        <h5 style="margin-bottom:8px;text-align:center">📊 维度平均分雷达图</h5>
        ${generateRadarSVG(stats.dimensionAverages.map(d => ({label:d.label, icon:d.icon, value:d.avgScore, maxScore:d.maxScore})), '#2563eb')}
      </div>
      <div class="row mb-2">
        ${stats.dimensionAverages.map(d => `<div class="col"><div class="stat-card text-center"><div style="font-size:14px">${d.icon} ${d.label}</div><div style="font-size:18px;font-weight:600;color:${d.avgScore/d.maxScore<0.4?'#ef4444':d.avgScore/d.maxScore<0.7?'#f59e0b':'#10b981'}">${d.avgScore}/${d.maxScore}</div></div></div>`).join('')}
      </div>
      <div class="d-flex gap-2 mb-2">
        ${Object.entries(stats.levelDist).map(([k,v]) => `<span style="background:${levelColors[k]}20;color:${levelColors[k]};padding:4px 12px;border-radius:12px;font-size:12px">${levelLabels[k]||k}: ${v}</span>`).join('')}
      </div>
    `;
  } catch(e) { console.error('stats error', e); }
}

async function loadAssessmentList() {
  try {
    const params = new URLSearchParams();
    if (assessmentFilter.level) params.set('level', assessmentFilter.level);
    if (assessmentFilter.status) params.set('status', assessmentFilter.status);
    if (assessmentFilter.keyword) params.set('keyword', assessmentFilter.keyword);
    params.set('pageSize', '50');
    const data = await api('/assessments/list?' + params.toString());
    const el = document.getElementById('assessment-list');
    if (!el) return;
    if (!data.items || data.items.length === 0) {
      el.innerHTML = '<div style="text-align:center;color:#999;padding:40px">暂无评估记录</div>';
      return;
    }
    const levelColors = { beginner: '#ef4444', exploring: '#f59e0b', intermediate: '#3b82f6', advanced: '#10b981' };
    const levelLabels = { beginner: '起步期', exploring: '探索期', intermediate: '成长期', advanced: '成熟期' };
    const statusLabels = { completed: '待跟进', contacted: '已联系', converted: '已转化', viewed: '已查看' };
    const statusColors = { completed: '#fbbf24', contacted: '#60a5fa', converted: '#34d399', viewed: '#a78bfa' };
    el.innerHTML = `<table class="table table-hover"><thead><tr>
      <th>分数</th><th>等级</th><th>企业</th><th>联系人</th><th>行业</th><th>状态</th><th>时间</th><th>操作</th>
    </tr></thead><tbody>${data.items.map(a => `<tr>
      <td><span style="font-weight:700;font-size:16px;color:${levelColors[a.level]||'#666'}">${a.total_score}</span><span style="color:#999;font-size:12px">/100</span></td>
      <td><span style="background:${levelColors[a.level]||'#666'}20;color:${levelColors[a.level]||'#666'};padding:2px 8px;border-radius:8px;font-size:12px">${levelLabels[a.level]||a.level}</span></td>
      <td>${a.company_name||'-'}</td>
      <td>${a.contact_name||'-'}<br><span style="font-size:12px;color:#999">${a.phone||''}</span></td>
      <td>${a.industry||'-'}</td>
      <td><span style="color:${statusColors[a.status]||'#999'}">${statusLabels[a.status]||a.status}</span></td>
      <td style="font-size:12px;color:#999">${(a.created_at||'').slice(5,16)}</td>
      <td><button class="btn btn-sm btn-outline-primary" onclick="viewAssessment(${a.id})">详情</button></td>
    </tr>`).join('')}</tbody></table>`;
  } catch(e) {
    const el = document.getElementById('assessment-list');
    if (el) el.innerHTML = '<div style="color:red">加载失败: '+e.message+'</div>';
  }
}

async function viewAssessment(id) {
  try {
    const a = await api('/assessments/' + id);
    const body = document.getElementById('assessment-detail-body');
    const levelColors = { beginner: '#ef4444', exploring: '#f59e0b', intermediate: '#3b82f6', advanced: '#10b981' };
    const levelLabels = { beginner: '起步期', exploring: '探索期', intermediate: '成长期', advanced: '成熟期' };
    const dimScores = typeof a.dimension_scores === 'string' ? JSON.parse(a.dimension_scores) : (a.dimension_scores || []);
    const recommendations = typeof a.recommendations === 'string' ? JSON.parse(a.recommendations) : (a.recommendations || []);
    const statusLabels = { completed: '待跟进', contacted: '已联系', converted: '已转化', viewed: '已查看' };
    const themeColor = levelColors[a.level] || '#2563eb';
    
    // 生成 SVG 雷达图
    const radarSvg = generateRadarSVG(dimScores, themeColor);
    
    body.innerHTML = `
      <div style="text-align:center;margin-bottom:20px">
        <div style="font-size:48px;font-weight:800;color:${themeColor}">${a.total_score}</div>
        <div style="font-size:14px;color:#999">/100 分</div>
        <div style="margin-top:8px"><span style="background:${themeColor}20;color:${themeColor};padding:4px 12px;border-radius:12px;font-weight:600">${levelLabels[a.level]||a.level}</span></div>
      </div>
      <div style="background:#f8f9fb;border-radius:10px;padding:16px;margin-bottom:16px">
        <h5 style="margin-bottom:12px;text-align:center">📊 五维能力雷达图</h5>
        ${radarSvg}
      </div>
      <div style="background:#f8f9fb;border-radius:10px;padding:16px;margin-bottom:16px">
        <h5 style="margin-bottom:8px">📋 维度评分明细</h5>
        ${dimScores.map(d => `<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px"><span>${d.icon} ${d.label}</span><span style="font-weight:600;color:${d.levelColor||'#666'}">${d.score}/${d.maxScore} (${d.level})</span></div><div style="height:8px;background:#e5e7eb;border-radius:4px"><div style="height:100%;width:${d.percentage||0}%;background:${d.levelColor||'#2563eb'};border-radius:4px"></div></div></div>`).join('')}
      </div>
      <div style="background:#f8f9fb;border-radius:10px;padding:16px;margin-bottom:16px">
        <h5 style="margin-bottom:8px">📋 诊断报告</h5>
        <p style="font-size:13px;line-height:1.8;color:#4b5563;white-space:pre-wrap">${a.report_summary||'暂无'}</p>
      </div>
      ${recommendations.length > 0 ? `<div style="background:#f8f9fb;border-radius:10px;padding:16px;margin-bottom:16px"><h5 style="margin-bottom:8px">💡 推荐方案</h5>${recommendations.map(r => `<div style="padding:8px 0;border-bottom:1px solid #eee"><span style="font-size:18px">${r.icon||'📦'}</span> <strong>${r.title}</strong><br><span style="font-size:12px;color:#999">${r.reason}</span></div>`).join('')}</div>` : ''}
      <div style="margin-bottom:16px">
        <strong>客户信息</strong><br>
        <span style="font-size:13px;color:#666">企业：${a.company_name||'-'} | 联系人：${a.contact_name||'-'} | 手机：${a.phone||'-'} | 行业：${a.industry||'-'} | 规模：${a.company_size||'-'}</span>
      </div>
      <div class="d-flex gap-2">
        <select class="form-control form-control-sm" id="asmt-status-select" style="width:auto">
          <option value="completed" ${a.status==='completed'?'selected':''}>待跟进</option>
          <option value="contacted" ${a.status==='contacted'?'selected':''}>已联系</option>
          <option value="converted" ${a.status==='converted'?'selected':''}>已转化</option>
        </select>
        <button class="btn btn-sm btn-primary" onclick="updateAsmtStatus(${a.id})">更新状态</button>
        ${a.phone ? `<button class="btn btn-sm btn-outline-success" onclick="window.location.href='tel:${a.phone}'">📞 联系</button>` : ''}
      </div>
    `;
    document.getElementById('assessment-detail-modal').style.display = 'flex';
  } catch(e) { alert('加载失败: '+e.message); }
}

// 生成 SVG 雷达图
function generateRadarSVG(dimScores, themeColor) {
  if (!dimScores || dimScores.length < 3) return '<p style="text-align:center;color:#999">暂无数据</p>';
  const n = dimScores.length;
  const size = 320;
  const cx = size / 2, cy = size / 2;
  const radius = 110;
  const startAngle = -Math.PI / 2;
  const angleStep = (Math.PI * 2) / n;
  const gridLevels = 4;
  
  // 网格
  let grids = '';
  for (let lv = 1; lv <= gridLevels; lv++) {
    const r = (radius * lv) / gridLevels;
    let pts = [];
    for (let i = 0; i <= n; i++) {
      const a = startAngle + angleStep * i;
      pts.push(`${cx + r * Math.cos(a)},${cy + r * Math.sin(a)}`);
    }
    grids += `<polygon points="${pts.join(' ')}" fill="none" stroke="#e5e7eb" stroke-width="1"/>`;
  }
  
  // 轴线
  let axes = '';
  for (let i = 0; i < n; i++) {
    const a = startAngle + angleStep * i;
    const x = cx + radius * Math.cos(a);
    const y = cy + radius * Math.sin(a);
    axes += `<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="#d1d5db" stroke-width="1"/>`;
  }
  
  // 数据多边形
  let dataPts = [];
  let dots = '';
  let labels = '';
  for (let i = 0; i < n; i++) {
    const a = startAngle + angleStep * i;
    const ratio = dimScores[i].maxScore > 0 ? dimScores[i].score / dimScores[i].maxScore : 0;
    const r = radius * ratio;
    const x = cx + r * Math.cos(a);
    const y = cy + r * Math.sin(a);
    dataPts.push(`${x},${y}`);
    dots += `<circle cx="${x}" cy="${y}" r="4" fill="#fff" stroke="${themeColor}" stroke-width="2"/>`;
    
    // 标签
    const labelR = radius + 28;
    const lx = cx + labelR * Math.cos(a);
    const ly = cy + labelR * Math.sin(a);
    labels += `<text x="${lx}" y="${ly - 4}" text-anchor="middle" font-size="11" font-weight="bold" fill="#374151">${dimScores[i].icon || ''} ${dimScores[i].label}</text>`;
    labels += `<text x="${lx}" y="${ly + 10}" text-anchor="middle" font-size="10" fill="${themeColor}">${dimScores[i].score}/${dimScores[i].maxScore}</text>`;
  }
  
  const fillColor = themeColor + '26'; // 15% opacity
  
  return `<svg viewBox="0 0 ${size} ${size}" style="width:100%;max-width:${size}px;height:auto;margin:0 auto;display:block">
    ${grids}
    ${axes}
    <polygon points="${dataPts.join(' ')}" fill="${fillColor}" stroke="${themeColor}" stroke-width="2"/>
    ${dots}
    ${labels}
  </svg>`;
}

function closeAsmtModal() {
  document.getElementById('assessment-detail-modal').style.display = 'none';
}

async function updateAsmtStatus(id) {
  const status = document.getElementById('asmt-status-select').value;
  try {
    await api('/assessments/' + id + '/status', { method: 'PUT', body: JSON.stringify({ status }) });
    closeAsmtModal();
    await loadAssessmentList();
    await loadAssessmentStats();
    alert('✅ 状态已更新');
  } catch(e) { alert('更新失败: '+e.message); }
}

// --- Init ---
if (token) showApp();

// --- Audit Logs ---
let auditCurrentPage = 1;
let auditFilters = {};

async function loadAuditLogs() {
  auditCurrentPage = 1;
  auditFilters = {};
  const main = document.getElementById('mainContent');
  main.innerHTML = `
    <div class="header">
      <h1>🔒 审计日志</h1>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline" onclick="exportAuditLogs()">📥 导出CSV</button>
        <button class="btn btn-outline" onclick="loadAuditStats()">📊 统计概览</button>
      </div>
    </div>
    <div id="audit-stats-section"></div>
    <div class="card">
      <div class="card-header" style="flex-wrap:wrap;gap:8px">
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
          <select id="audit-f-severity" onchange="auditFilterChange()" style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px">
            <option value="">全部级别</option>
            <option value="info">ℹ️ 信息</option>
            <option value="warning">⚠️ 警告</option>
            <option value="critical">🔴 严重</option>
          </select>
          <select id="audit-f-actor" onchange="auditFilterChange()" style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px">
            <option value="">全部来源</option>
            <option value="admin">管理员</option>
            <option value="user">用户</option>
            <option value="system">系统</option>
            <option value="api">API</option>
          </select>
          <select id="audit-f-resource" onchange="auditFilterChange()" style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px">
            <option value="">全部资源</option>
            <option value="order">订单</option>
            <option value="payment">支付</option>
            <option value="product">产品</option>
            <option value="article">文章</option>
            <option value="client_product">甲方产品</option>
            <option value="onboarding">入驻</option>
            <option value="coupon">优惠券</option>
            <option value="booking">预约</option>
          </select>
          <input type="text" id="audit-f-keyword" placeholder="搜索关键词..." onkeyup="if(event.key==='Enter')auditFilterChange()" style="padding:6px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;width:200px">
          <button class="btn btn-sm btn-primary" onclick="auditFilterChange()">搜索</button>
        </div>
      </div>
      <div class="card-body" id="audit-list-body">
        <div class="empty">加载中...</div>
      </div>
    </div>
    <div id="audit-pagination" style="display:flex;justify-content:center;gap:8px;margin-top:16px"></div>
    <div id="audit-detail-modal" class="modal-overlay">
      <div class="modal modal-lg">
        <h3>📋 操作详情</h3>
        <div id="audit-detail-content"></div>
        <div class="modal-actions">
          <button class="btn btn-outline" onclick="closeAuditDetail()">关闭</button>
        </div>
      </div>
    </div>
  `;
  await loadAuditList();
  await loadAuditStats();
}

function auditFilterChange() {
  auditCurrentPage = 1;
  auditFilters = {
    severity: document.getElementById('audit-f-severity').value,
    actor_type: document.getElementById('audit-f-actor').value,
    resource_type: document.getElementById('audit-f-resource').value,
    keyword: document.getElementById('audit-f-keyword').value
  };
  loadAuditList();
}

async function loadAuditList() {
  const params = new URLSearchParams({ page: auditCurrentPage, limit: 20 });
  Object.entries(auditFilters).forEach(([k, v]) => { if (v) params.set(k, v); });
  try {
    const resp = await fetch(API_BASE + '/audit-logs?' + params, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await resp.json();
    const body = document.getElementById('audit-list-body');
    if (!data.data || data.data.length === 0) {
      body.innerHTML = '<div class="empty">📭 暂无审计日志记录</div>';
      document.getElementById('audit-pagination').innerHTML = '';
      return;
    }
    body.innerHTML = `
      <table>
        <thead>
          <tr>
            <th>ID</th><th>时间</th><th>来源</th><th>操作</th><th>资源</th><th>描述</th><th>状态</th><th>级别</th><th>操作</th>
          </tr>
        </thead>
        <tbody>
          ${data.data.map(r => `
            <tr>
              <td>${r.id}</td>
              <td style="white-space:nowrap;font-size:12px">${r.created_at}</td>
              <td><span class="badge badge-${r.actor_type==='admin'?'info':r.actor_type==='system'?'default':'default'}">${r.actor_type}</span><br><span style="font-size:11px;color:var(--text2)">${r.actor_name||r.actor_id||''}</span></td>
              <td style="font-size:12px;font-weight:600">${r.action}</td>
              <td style="font-size:12px">${r.resource_type||'-'}<br><span style="color:var(--text2)">${r.resource_id||''}</span></td>
              <td style="font-size:12px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.description}</td>
              <td>${r.response_status ? `<span class="badge ${r.response_status>=400?'badge-rejected':'badge-approved'}">${r.response_status}</span>` : '-'}</td>
              <td>${severityBadge(r.severity)}</td>
              <td><button class="btn btn-sm btn-outline" onclick="showAuditDetail(${r.id})">查看</button></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
    // 分页
    const pag = document.getElementById('audit-pagination');
    const tp = data.total_pages || 1;
    let html = '';
    if (auditCurrentPage > 1) html += `<button class="btn btn-sm btn-outline" onclick="auditGoPage(${auditCurrentPage-1})">上一页</button>`;
    html += `<span style="padding:4px 12px;font-size:13px">第 ${auditCurrentPage} / ${tp} 页（共 ${data.total} 条）</span>`;
    if (auditCurrentPage < tp) html += `<button class="btn btn-sm btn-outline" onclick="auditGoPage(${auditCurrentPage+1})">下一页</button>`;
    pag.innerHTML = html;
  } catch(e) {
    document.getElementById('audit-list-body').innerHTML = '<div class="empty">❌ 加载失败: ' + e.message + '</div>';
  }
}

function severityBadge(s) {
  const map = { info: '<span class="badge badge-approved">信息</span>', warning: '<span class="badge badge-pending">警告</span>', critical: '<span class="badge badge-rejected">严重</span>' };
  return map[s] || '<span class="badge badge-default">' + s + '</span>';
}

function auditGoPage(p) {
  auditCurrentPage = p;
  loadAuditList();
}

async function showAuditDetail(id) {
  try {
    const resp = await fetch(API_BASE + '/audit-logs?page=1&limit=1&keyword=' + id, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await resp.json();
    const r = data.data && data.data[0];
    if (!r) { alert('未找到记录'); return; }
    const meta = typeof r.metadata === 'object' ? r.metadata : {};
    const body = typeof r.request_body === 'object' ? r.request_body : (safeJsonParseDisplay(r.request_body));
    document.getElementById('audit-detail-content').innerHTML = `
      <div style="display:grid;grid-template-columns:140px 1fr;gap:8px 16px;font-size:13px">
        <div style="color:var(--text2)">ID</div><div>${r.id}</div>
        <div style="color:var(--text2)">时间</div><div>${r.created_at}</div>
        <div style="color:var(--text2)">操作者类型</div><div>${r.actor_type}</div>
        <div style="color:var(--text2)">操作者ID</div><div>${r.actor_id||'-'}</div>
        <div style="color:var(--text2)">操作者名称</div><div>${r.actor_name||'-'}</div>
        <div style="color:var(--text2)">操作</div><div style="font-weight:600">${r.action}</div>
        <div style="color:var(--text2)">资源类型</div><div>${r.resource_type||'-'}</div>
        <div style="color:var(--text2)">资源ID</div><div>${r.resource_id||'-'}</div>
        <div style="color:var(--text2)">描述</div><div>${r.description}</div>
        <div style="color:var(--text2)">IP地址</div><div>${r.ip_address||'-'}</div>
        <div style="color:var(--text2)">User-Agent</div><div style="word-break:break-all;font-size:11px">${r.user_agent||'-'}</div>
        <div style="color:var(--text2)">请求方法</div><div>${r.request_method||'-'}</div>
        <div style="color:var(--text2)">请求路径</div><div>${r.request_path||'-'}</div>
        <div style="color:var(--text2)">响应状态</div><div>${r.response_status||'-'}</div>
        <div style="color:var(--text2)">严重程度</div><div>${severityBadge(r.severity)}</div>
        <div style="color:var(--text2)">请求参数</div><div style="word-break:break-all;font-size:11px;background:#f9fafb;padding:8px;border-radius:6px">${body || '-'}</div>
        <div style="color:var(--text2)">额外信息</div><div style="word-break:break-all;font-size:11px;background:#f9fafb;padding:8px;border-radius:6px">${JSON.stringify(meta,null,2)}</div>
      </div>
    `;
    document.getElementById('audit-detail-modal').style.display = 'flex';
  } catch(e) { alert('加载失败: ' + e.message); }
}

function safeJsonParseDisplay(str) {
  try { return JSON.stringify(JSON.parse(str), null, 2); } catch { return str || '-'; }
}

function closeAuditDetail() {
  document.getElementById('audit-detail-modal').style.display = 'none';
}

async function loadAuditStats() {
  try {
    const resp = await fetch(API_BASE + '/audit-logs/stats?days=7', {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await resp.json();
    const section = document.getElementById('audit-stats-section');
    if (!data || data.total === 0) { section.innerHTML = ''; return; }
    section.innerHTML = `
      <div class="stats">
        <div class="stat-card"><div class="label">总操作数（${data.days}天）</div><div class="value">${data.total}</div></div>
        <div class="stat-card pending"><div class="label">错误操作</div><div class="value">${data.errors}</div></div>
        <div class="stat-card" style="background:#fef2f2"><div class="label" style="color:var(--danger)">高危操作</div><div class="value" style="color:var(--danger)">${data.critical}</div></div>
        <div class="stat-card info"><div class="label">操作类型数</div><div class="value">${data.byAction ? data.byAction.length : 0}</div></div>
      </div>
      ${data.byAction && data.byAction.length > 0 ? `
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><span>📈 操作类型分布（Top 15）</span></div>
          <div class="card-body" style="padding:16px">
            ${data.byAction.map(a => `
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                <span style="font-size:12px;min-width:180px;font-weight:600">${a.action}</span>
                <div style="flex:1;background:#f0f2f5;border-radius:4px;height:20px;overflow:hidden">
                  <div style="width:${Math.min(100, a.count / data.total * 100 * 2)}%;background:var(--primary);height:100%;border-radius:4px"></div>
                </div>
                <span style="font-size:12px;min-width:30px;text-align:right">${a.count}</span>
              </div>
            `).join('')}
          </div>
        </div>
      ` : ''}
      ${data.dailyTrend && data.dailyTrend.length > 0 ? `
        <div class="card" style="margin-bottom:16px">
          <div class="card-header"><span>📅 每日趋势</span></div>
          <div class="card-body" style="padding:16px">
            <table>
              <thead><tr><th>日期</th><th>总操作</th><th>严重</th><th>警告</th><th>错误</th></tr></thead>
              <tbody>
                ${data.dailyTrend.map(d => `
                  <tr>
                    <td>${d.date}</td>
                    <td><strong>${d.count}</strong></td>
                    <td style="color:var(--danger)">${d.critical||0}</td>
                    <td style="color:var(--warning)">${d.warning||0}</td>
                    <td>${d.errors||0}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        </div>
      ` : ''}
    `;
  } catch(e) {
    document.getElementById('audit-stats-section').innerHTML = '';
  }
}

function exportAuditLogs() {
  const params = new URLSearchParams();
  Object.entries(auditFilters).forEach(([k, v]) => { if (v) params.set(k, v); });
  window.open(API_BASE + '/audit-logs/export?' + params + '&token=' + token, '_blank');
}

// ==================== 报价查询 ====================
async function loadQuotes() {
  const content = document.getElementById('content');
  content.innerHTML = `
    <h1>🧮 报价计算器线索</h1>
    <p style="color:#666;margin-bottom:16px">用户通过报价计算器提交的方案需求</p>
    <div id="quotes-list">加载中...</div>
  `;
  try {
    const resp = await fetch(API_BASE + '/quotes?page=1&pageSize=50', {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    const data = await resp.json();
    const items = data.items || [];
    if (items.length === 0) {
      document.getElementById('quotes-list').innerHTML = '<div class="empty">📭 暂无报价记录</div>';
      return;
    }
    let html = '<table class="data-table"><thead><tr>' +
      '<th>ID</th><th>提交时间</th><th>姓名</th><th>手机</th><th>公司</th>' +
      '<th>产品</th><th>版本</th><th>用户数</th><th>模块</th><th>总价</th><th>状态</th><th>操作</th>' +
      '</tr></thead><tbody>';
    items.forEach(q => {
      let modules = [];
      try { modules = JSON.parse(q.modules || '[]'); } catch(e) {}
      const moduleNames = modules.map(m => m.name).join(', ') || '无';
      const statusMap = { new: '🆕 新线索', contacted: '📞 已联系', converted: '🎉 已转化', lost: '❌ 已流失' };
      html += `<tr>
        <td>${q.id}</td>
        <td>${(q.created_at || '').slice(0,16)}</td>
        <td>${q.name}</td>
        <td>${q.phone}</td>
        <td>${q.company || '-'}</td>
        <td>${q.product_title}</td>
        <td>${q.edition_name || q.edition}</td>
        <td>${q.user_count}人</td>
        <td style="max-width:200px;font-size:12px;color:#666">${moduleNames}</td>
        <td style="font-weight:700;color:#2563eb">¥${(q.total_price || 0).toLocaleString()}</td>
        <td><span class="status-tag status-${q.status}">${statusMap[q.status] || q.status}</span></td>
        <td>
          <button class="btn-sm" onclick="updateQuoteStatus(${q.id}, 'contacted')">标记已联系</button>
          <button class="btn-sm btn-success" onclick="updateQuoteStatus(${q.id}, 'converted')">已转化</button>
        </td>
      </tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('quotes-list').innerHTML = html;
  } catch (e) {
    document.getElementById('quotes-list').innerHTML = '<div class="empty">❌ 加载失败: ' + e.message + '</div>';
  }
}

async function updateQuoteStatus(id, status) {
  try {
    const resp = await fetch(API_BASE + '/quotes/' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ status })
    });
    const data = await resp.json();
    if (data.success) {
      loadQuotes();
    } else {
      alert(data.error || '更新失败');
    }
  } catch (e) {
    alert('请求失败: ' + e.message);
  }
}

// --- 定时任务调度器 ---
async function loadScheduler() {
  const main = document.getElementById('main-content');
  main.innerHTML = `
    <h2>⏰ 定时任务调度器</h2>
    <div id="scheduler-status" style="margin-bottom:20px"></div>
    <div id="scheduler-tasks" style="margin-bottom:24px"></div>
    <h3>📋 执行日志（最近 50 条）</h3>
    <div id="scheduler-logs"></div>
  `;
  try {
    const status = await api('/scheduler/status');
    document.getElementById('scheduler-status').innerHTML = `
      <div class="stat-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px">
        <div class="stat-card" style="padding:16px;background:var(--card);border-radius:12px;border:1px solid var(--border)">
          <div style="font-size:24px;font-weight:700;color:#10b981">${status.totalTasks}</div>
          <div style="font-size:12px;color:var(--text-muted)">总任务数</div>
        </div>
        <div class="stat-card" style="padding:16px;background:var(--card);border-radius:12px;border:1px solid var(--border)">
          <div style="font-size:24px;font-weight:700;color:#3b82f6">${status.enabledTasks}</div>
          <div style="font-size:12px;color:var(--text-muted)">已启用</div>
        </div>
        <div class="stat-card" style="padding:16px;background:var(--card);border-radius:12px;border:1px solid var(--border)">
          <div style="font-size:24px;font-weight:700;color:#8b5cf6">${status.totalRuns}</div>
          <div style="font-size:12px;color:var(--text-muted)">总执行次数</div>
        </div>
        <div class="stat-card" style="padding:16px;background:var(--card);border-radius:12px;border:1px solid var(--border)">
          <div style="font-size:24px;font-weight:700;color:#f59e0b">${status.totalErrors}</div>
          <div style="font-size:12px;color:var(--text-muted)">错误次数</div>
        </div>
        <div class="stat-card" style="padding:16px;background:var(--card);border-radius:12px;border:1px solid var(--border)">
          <div style="font-size:24px;font-weight:700;color:#06b6d4">${Math.floor(status.uptime/3600)}h</div>
          <div style="font-size:12px;color:var(--text-muted)">运行时长</div>
        </div>
      </div>
    `;
  } catch(e) {
    document.getElementById('scheduler-status').innerHTML = '<div class="empty">状态加载失败: ' + e.message + '</div>';
  }
  // 加载任务列表
  try {
    const tasks = await api('/scheduler/tasks');
    const statusColors = { idle: '#6b7280', success: '#10b981', error: '#ef4444', skipped: '#f59e0b' };
    const statusText = { idle: '空闲', success: '成功', error: '失败', skipped: '跳过' };
    document.getElementById('scheduler-tasks').innerHTML = `
      <table>
        <thead>
          <tr>
            <th>任务名称</th>
            <th>描述</th>
            <th>频率</th>
            <th>状态</th>
            <th>上次执行</th>
            <th>耗时</th>
            <th>执行/成功/失败/跳过</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          ${tasks.map(t => `
            <tr>
              <td style="font-weight:600">${t.name}</td>
              <td style="font-size:13px">${t.description}</td>
              <td style="font-size:12px">${t.schedule}</td>
              <td>
                ${t.enabled 
                  ? '<span style="color:#10b981">● 启用</span>' 
                  : '<span style="color:#6b7280">○ 禁用</span>'}
              </td>
              <td style="font-size:12px">
                ${t.lastRun ? t.lastRun.slice(0,19).replace('T',' ') : '-'}<br>
                <span style="color:${statusColors[t.lastStatus]||'#999'};font-size:11px">${statusText[t.lastStatus]||t.lastStatus}</span>
              </td>
              <td style="font-size:12px">${t.lastDuration > 0 ? t.lastDuration + 'ms' : '-'}</td>
              <td style="font-size:12px">
                <span style="color:#3b82f6">${t.runCount}</span> /
                <span style="color:#10b981">${t.successCount}</span> /
                <span style="color:#ef4444">${t.errorCount}</span> /
                <span style="color:#f59e0b">${t.skipCount}</span>
              </td>
              <td>
                <button class="btn" style="padding:4px 10px;font-size:12px" onclick="triggerSchedulerTask('${t.name}')">▶ 触发</button>
                <button class="btn" style="padding:4px 10px;font-size:12px;margin-left:4px" onclick="toggleSchedulerTask('${t.name}', ${!t.enabled})">
                  ${t.enabled ? '⏸ 禁用' : '▶ 启用'}
                </button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
      <div style="margin-top:12px;font-size:12px;color:var(--text-muted)">
        下次检查时间: ${tasks[0] ? new Date(tasks[0].nextCheck).toLocaleString('zh-CN') : '-'}
      </div>
    `;
  } catch(e) {
    document.getElementById('scheduler-tasks').innerHTML = '<div class="empty">任务列表加载失败: ' + e.message + '</div>';
  }
  // 加载执行日志
  try {
    const logs = await api('/scheduler/logs?limit=50');
    const logStatusColors = { success: '#10b981', error: '#ef4444', skipped: '#f59e0b' };
    document.getElementById('scheduler-logs').innerHTML = logs.length ? `
      <table>
        <thead>
          <tr>
            <th>时间</th>
            <th>任务</th>
            <th>状态</th>
            <th>耗时</th>
            <th>消息</th>
          </tr>
        </thead>
        <tbody>
          ${logs.map(l => `
            <tr>
              <td style="font-size:12px">${l.executed_at.slice(0,19).replace('T',' ')}</td>
              <td style="font-size:13px;font-weight:600">${l.task_name}</td>
              <td style="color:${logStatusColors[l.status]||'#999'};font-size:12px">${l.status}</td>
              <td style="font-size:12px">${l.duration_ms > 0 ? l.duration_ms + 'ms' : '-'}</td>
              <td style="font-size:12px;max-width:500px;overflow:hidden;text-overflow:ellipsis">${l.message}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    ` : '<div class="empty">暂无执行日志</div>';
  } catch(e) {
    document.getElementById('scheduler-logs').innerHTML = '<div class="empty">日志加载失败: ' + e.message + '</div>';
  }
}

async function triggerSchedulerTask(name) {
  if (!confirm('确认手动触发任务「' + name + '」？')) return;
  try {
    const result = await fetch(API_BASE + '/scheduler/trigger/' + name, {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());
    alert('任务触发完成\n\n结果: ' + JSON.stringify(result.result, null, 2));
    loadScheduler();
  } catch(e) {
    alert('触发失败: ' + e.message);
  }
}

async function toggleSchedulerTask(name, enabled) {
  try {
    await fetch(API_BASE + '/scheduler/toggle/' + name, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ enabled })
    }).then(r => r.json());
    loadScheduler();
  } catch(e) {
    alert('操作失败: ' + e.message);
  }
}

// ==================== 服务交付里程碑管理 ====================

let serviceTrackerFilter = 'all';
let serviceTrackerKeyword = '';

async function loadServiceTracker() {
  const main = document.getElementById('main-content');
  main.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
      <h2>🛠️ 服务交付追踪</h2>
      <div style="display:flex;gap:8px;">
        <button class="btn btn-outline" onclick="loadServiceStats()">📊 统计概览</button>
        <button class="btn btn-primary" onclick="loadServiceTemplates()">📋 模板参考</button>
      </div>
    </div>

    <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;">
      <input type="text" id="st-keyword" placeholder="搜索订单号/产品/客户" value="${serviceTrackerKeyword}"
        style="flex:1;min-width:200px;padding:8px 12px;border:1px solid #ddd;border-radius:6px;"
        onkeydown="if(event.key==='Enter')searchService()" />
      <button class="btn btn-primary" onclick="searchService()">搜索</button>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;">
      <button class="btn ${serviceTrackerFilter==='all'?'btn-primary':'btn-outline'}" onclick="setServiceFilter('all')">全部</button>
      <button class="btn ${serviceTrackerFilter==='active'?'btn-primary':'btn-outline'}" onclick="setServiceFilter('active')">进行中</button>
      <button class="btn ${serviceTrackerFilter==='completed'?'btn-primary':'btn-outline'}" onclick="setServiceFilter('completed')">已完成</button>
      <button class="btn ${serviceTrackerFilter==='pending'?'btn-primary':'btn-outline'}" onclick="setServiceFilter('pending')">待启动</button>
    </div>

    <div id="service-tracker-list">加载中...</div>
    <div id="service-tracker-pagination" style="margin-top:20px;text-align:center;"></div>
    <div id="service-tracker-detail" style="display:none;"></div>
  `;

  await loadServiceList();
}

function setServiceFilter(f) {
  serviceTrackerFilter = f;
  loadServiceTracker();
}

function searchService() {
  serviceTrackerKeyword = document.getElementById('st-keyword')?.value || '';
  loadServiceList();
}

async function loadServiceList() {
  const listEl = document.getElementById('service-tracker-list');
  if (!listEl) return;
  listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">加载中...</div>';

  try {
    const params = new URLSearchParams({ page: 1, limit: 50 });
    if (serviceTrackerFilter !== 'all') params.set('status', serviceTrackerFilter);
    if (serviceTrackerKeyword) params.set('keyword', serviceTrackerKeyword);

    const res = await fetch(API_BASE + '/service-tracker/list?' + params, {
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());

    if (!res.list || res.list.length === 0) {
      listEl.innerHTML = '<div style="text-align:center;padding:60px;color:#999;">📦 暂无服务交付订单</div>';
      return;
    }

    // 概览卡片
    let html = `
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
        <div class="stat-card"><div class="stat-num" style="color:#2563eb;">${res.summary.total_orders}</div><div class="stat-label">总订单</div></div>
        <div class="stat-card"><div class="stat-num" style="color:#f59e0b;">${res.summary.active}</div><div class="stat-label">进行中</div></div>
        <div class="stat-card"><div class="stat-num" style="color:#16a34a;">${res.summary.completed}</div><div class="stat-label">已完成</div></div>
        <div class="stat-card"><div class="stat-num" style="color:#8b5cf6;">${res.summary.avg_progress}%</div><div class="stat-label">平均进度</div></div>
      </div>
    `;

    html += '<div style="display:flex;flex-direction:column;gap:12px;">';
    for (const item of res.list) {
      const progressColor = item.overall_progress >= 100 ? '#16a34a' : (item.overall_progress > 0 ? '#2563eb' : '#94a3b8');
      html += `
        <div style="background:#fff;border-radius:12px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);cursor:pointer;" onclick="viewServiceDetail(${item.order_id})">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
            <div>
              <div style="font-size:16px;font-weight:600;color:#1e293b;">${item.product_title}</div>
              <div style="font-size:12px;color:#94a3b8;margin-top:4px;">${item.order_no} | ${item.buyer_name} ${item.buyer_phone}</div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span style="font-size:12px;padding:4px 10px;border-radius:12px;background:${item.overall_progress>=100?'#f0fdf4':'#eff6ff'};color:${item.overall_progress>=100?'#16a34a':'#2563eb'};">
                ${item.overall_progress>=100?'✅ 已完成':'🔨 进行中'}
              </span>
              <span style="font-size:12px;color:#94a3b8;">¥${item.amount}</span>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="flex:1;height:10px;background:#f1f5f9;border-radius:5px;overflow:hidden;">
              <div style="height:100%;width:${item.overall_progress}%;background:${progressColor};border-radius:5px;transition:width 0.3s;"></div>
            </div>
            <span style="font-size:14px;font-weight:600;color:${progressColor};min-width:40px;text-align:right;">${item.overall_progress}%</span>
          </div>
          <div style="display:flex;justify-content:space-between;margin-top:12px;font-size:12px;color:#64748b;">
            <span>📋 ${item.completed_count}/${item.milestone_count} 阶段完成</span>
            <span>${item.current_title}</span>
            <span>${item.paid_at || ''}</span>
          </div>
        </div>
      `;
    }
    html += '</div>';
    listEl.innerHTML = html;
  } catch(e) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px;color:#ef4444;">加载失败: ' + e.message + '</div>';
  }
}

async function viewServiceDetail(orderId) {
  const detailEl = document.getElementById('service-tracker-detail');
  const listEl = document.getElementById('service-tracker-list');
  if (!detailEl || !listEl) return;

  listEl.style.display = 'none';
  detailEl.style.display = 'block';
  detailEl.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">加载中...</div>';

  try {
    const res = await fetch(API_BASE + '/service-tracker/order/' + orderId, {
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());

    let html = `
      <div style="margin-bottom:16px;">
        <button class="btn btn-outline" onclick="closeServiceDetail()">← 返回列表</button>
      </div>
    `;

    // 订单信息
    html += `
      <div style="background:#fff;border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;">
          <div>
            <div style="font-size:18px;font-weight:600;">${res.order.product_title}</div>
            <div style="font-size:12px;color:#94a3b8;margin-top:4px;">${res.order.order_no}</div>
          </div>
          <div style="display:flex;gap:8px;">
            <button class="btn btn-outline" onclick="addMilestone(${orderId})">➕ 添加里程碑</button>
            <button class="btn btn-primary" onclick="initMilestones(${orderId})">🔄 初始化模板</button>
          </div>
        </div>
        <div style="display:flex;gap:24px;font-size:13px;color:#64748b;">
          <span>金额: <strong style="color:#dc2626;">¥${res.order.amount}</strong></span>
          <span>状态: ${res.order.status}</span>
          <span>支付: ${res.order.paid_at || '-'}</span>
        </div>
      </div>
    `;

    // 总进度
    const stats = res.stats;
    html += `
      <div style="background:#fff;border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">
        <div style="display:flex;justify-content:space-between;margin-bottom:12px;">
          <span style="font-size:16px;font-weight:600;">交付总进度</span>
          <span style="font-size:24px;font-weight:700;color:#2563eb;">${stats.overall_progress}%</span>
        </div>
        <div style="height:16px;background:#f1f5f9;border-radius:8px;overflow:hidden;margin-bottom:12px;">
          <div style="height:100%;width:${stats.overall_progress}%;background:linear-gradient(90deg,#3b82f6,#2563eb);border-radius:8px;"></div>
        </div>
        <div style="display:flex;gap:20px;font-size:13px;">
          <span style="color:#16a34a;">✅ ${stats.completed} 完成</span>
          <span style="color:#2563eb;">🔨 ${stats.in_progress} 进行中</span>
          <span style="color:#94a3b8;">⏳ ${stats.pending} 待开始</span>
          ${stats.skipped > 0 ? `<span style="color:#a855f7;">⏭️ ${stats.skipped} 跳过</span>` : ''}
        </div>
      </div>
    `;

    // 里程碑列表
    html += '<div style="background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">';
    html += '<div style="font-size:16px;font-weight:600;margin-bottom:16px;">交付里程碑</div>';

    if (res.milestones.length === 0) {
      html += '<div style="text-align:center;padding:40px;color:#999;">暂无里程碑，点击「初始化模板」生成默认里程碑</div>';
    } else {
      for (const m of res.milestones) {
        const statusColors = { pending: '#94a3b8', in_progress: '#2563eb', done: '#16a34a', skipped: '#a855f7' };
        const statusLabels = { pending: '⏳ 待开始', in_progress: '🔨 进行中', done: '✅ 已完成', skipped: '⏭️ 已跳过' };
        const color = statusColors[m.status] || '#94a3b8';

        html += `
          <div style="border-left:3px solid ${color};padding:16px;margin-bottom:12px;background:#f8fafc;border-radius:0 8px 8px 0;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;">
              <div>
                <span style="font-size:12px;color:#94a3b8;">第${m.sort_order}步</span>
                <span style="font-size:15px;font-weight:600;margin-left:8px;">${m.title}</span>
              </div>
              <span style="font-size:12px;padding:2px 8px;border-radius:10px;background:${color}20;color:${color};">${statusLabels[m.status]}</span>
            </div>
            <div style="font-size:13px;color:#64748b;margin-bottom:8px;">${m.description || ''}</div>
        `;

        if (m.status === 'in_progress') {
          html += `
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
              <div style="flex:1;height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden;">
                <div style="height:100%;width:${m.progress}%;background:#2563eb;border-radius:3px;"></div>
              </div>
              <span style="font-size:12px;color:#2563eb;font-weight:600;">${m.progress}%</span>
            </div>
          `;
        }

        // 日期信息
        html += '<div style="display:flex;gap:16px;font-size:12px;color:#94a3b8;margin-bottom:8px;flex-wrap:wrap;">';
        if (m.start_date) html += `<span>开始: ${m.start_date}</span>`;
        if (m.expected_date) html += `<span>预计: ${m.expected_date}</span>`;
        if (m.completed_date) html += `<span style="color:#16a34a;">完成: ${m.completed_date}</span>`;
        html += '</div>';

        if (m.notes) {
          html += `<div style="font-size:12px;color:#92400e;background:#fffbeb;padding:8px;border-radius:4px;margin-bottom:8px;">📝 ${m.notes}</div>`;
        }

        // 操作按钮
        html += '<div style="display:flex;gap:6px;flex-wrap:wrap;">';
        if (m.status !== 'in_progress') html += `<button class="btn btn-sm btn-outline" onclick="updateMilestoneStatus(${m.id},'in_progress')">设为进行中</button>`;
        if (m.status !== 'done') html += `<button class="btn btn-sm btn-outline" style="color:#16a34a;border-color:#16a34a;" onclick="updateMilestoneStatus(${m.id},'done')">设为已完成</button>`;
        if (m.status !== 'pending') html += `<button class="btn btn-sm btn-outline" onclick="updateMilestoneStatus(${m.id},'pending')">重置</button>`;
        if (m.status !== 'skipped') html += `<button class="btn btn-sm btn-outline" style="color:#a855f7;" onclick="updateMilestoneStatus(${m.id},'skipped')">跳过</button>`;
        html += `<button class="btn btn-sm btn-outline" onclick="editMilestone(${m.id},${orderId},'${m.title.replace(/'/g,"\\'")}','${(m.description||'').replace(/'/g,"\\'")}','${m.expected_date||''}','${(m.notes||'').replace(/'/g,"\\'")}')">编辑</button>`;
        html += `<button class="btn btn-sm btn-outline" style="color:#ef4444;" onclick="deleteMilestone(${m.id})">删除</button>`;
        html += '</div>';
        html += '</div>';
      }
    }
    html += '</div>';

    detailEl.innerHTML = html;
  } catch(e) {
    detailEl.innerHTML = '<div style="text-align:center;padding:40px;color:#ef4444;">加载失败: ' + e.message + '</div>';
  }
}

function closeServiceDetail() {
  document.getElementById('service-tracker-list').style.display = '';
  document.getElementById('service-tracker-detail').style.display = 'none';
}

async function initMilestones(orderId) {
  if (!confirm('确认为此订单初始化默认里程碑模板？已有里程碑将保留。')) return;
  try {
    const res = await fetch(API_BASE + '/service-tracker/init/' + orderId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());
    alert(res.message || '初始化成功');
    viewServiceDetail(orderId);
  } catch(e) {
    alert('初始化失败: ' + e.message);
  }
}

async function updateMilestoneStatus(id, status) {
  try {
    await fetch(API_BASE + '/service-tracker/milestone/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ status })
    }).then(r => r.json());
    // 重新加载当前详情
    const orderId = document.querySelector('[onclick^="viewServiceDetail"]')?.getAttribute('onclick')?.match(/\d+/)?.[0];
    // 更简单地从面包屑找
    const detailEl = document.getElementById('service-tracker-detail');
    // 刷新整个详情
    location.reload();
  } catch(e) {
    alert('更新失败: ' + e.message);
  }
}

function addMilestone(orderId) {
  const title = prompt('里程碑标题:');
  if (!title) return;
  const description = prompt('描述（可选）:') || '';
  const expected_date = prompt('预计完成日期 (YYYY-MM-DD，可选):') || '';
  const notes = prompt('备注（可选）:') || '';

  fetch(API_BASE + '/service-tracker/milestone', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({ order_id: orderId, title, description, expected_date, notes })
  }).then(r => r.json()).then(res => {
    alert(res.message || '添加成功');
    viewServiceDetail(orderId);
  }).catch(e => alert('添加失败: ' + e.message));
}

function editMilestone(id, orderId, title, description, expectedDate, notes) {
  const newTitle = prompt('标题:', title);
  if (!newTitle) return;
  const newDesc = prompt('描述:', description);
  const newDate = prompt('预计完成日期:', expectedDate);
  const newNotes = prompt('备注:', notes);

  fetch(API_BASE + '/service-tracker/milestone/' + id, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({ title: newTitle, description: newDesc, expected_date: newDate, notes: newNotes })
  }).then(r => r.json()).then(res => {
    viewServiceDetail(orderId);
  }).catch(e => alert('更新失败: ' + e.message));
}

async function deleteMilestone(id) {
  if (!confirm('确定删除此里程碑？')) return;
  try {
    await fetch(API_BASE + '/service-tracker/milestone/' + id, {
      method: 'DELETE',
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());
    location.reload();
  } catch(e) {
    alert('删除失败: ' + e.message);
  }
}

async function loadServiceStats() {
  try {
    const res = await fetch(API_BASE + '/service-tracker/stats', {
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());

    let html = '<div style="background:#fff;border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">';
    html += '<h3 style="margin-bottom:16px;">📊 服务交付统计</h3>';
    html += `
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;">
        <div style="text-align:center;padding:16px;background:#f8fafc;border-radius:8px;"><div style="font-size:24px;font-weight:700;color:#2563eb;">${res.total_orders}</div><div style="font-size:12px;color:#94a3b8;">总订单</div></div>
        <div style="text-align:center;padding:16px;background:#f8fafc;border-radius:8px;"><div style="font-size:24px;font-weight:700;color:#f59e0b;">${res.active_orders}</div><div style="font-size:12px;color:#94a3b8;">进行中</div></div>
        <div style="text-align:center;padding:16px;background:#f8fafc;border-radius:8px;"><div style="font-size:24px;font-weight:700;color:#16a34a;">${res.completed_orders}</div><div style="font-size:12px;color:#94a3b8;">已完成</div></div>
        <div style="text-align:center;padding:16px;background:#f8fafc;border-radius:8px;"><div style="font-size:24px;font-weight:700;color:#8b5cf6;">${res.avg_progress}%</div><div style="font-size:12px;color:#94a3b8;">平均进度</div></div>
      </div>
    `;

    if (res.stage_stats && res.stage_stats.length > 0) {
      html += '<h4 style="margin-bottom:12px;">各阶段统计</h4>';
      html += '<table style="width:100%;border-collapse:collapse;font-size:13px;"><thead><tr style="background:#f8fafc;"><th style="padding:8px;text-align:left;">阶段</th><th>总数</th><th>待开始</th><th>进行中</th><th>已完成</th><th>跳过</th><th>完成率</th></tr></thead><tbody>';
      for (const s of res.stage_stats) {
        html += `<tr style="border-bottom:1px solid #f1f5f9;"><td style="padding:8px;">${s.title}</td><td style="text-align:center;">${s.total}</td><td style="text-align:center;">${s.pending}</td><td style="text-align:center;">${s.in_progress}</td><td style="text-align:center;">${s.done}</td><td style="text-align:center;">${s.skipped}</td><td style="text-align:center;"><span style="color:#16a34a;font-weight:600;">${s.completion_rate}%</span></td></tr>`;
      }
      html += '</tbody></table>';
    }
    html += '</div>';

    // 插入到列表前面
    const listEl = document.getElementById('service-tracker-list');
    if (listEl) {
      const div = document.createElement('div');
      div.innerHTML = html;
      listEl.insertBefore(div.firstChild, listEl.firstChild);
    }
  } catch(e) {
    alert('加载统计失败: ' + e.message);
  }
}

async function loadServiceTemplates() {
  try {
    const res = await fetch(API_BASE + '/service-tracker/templates', {
      headers: { 'Authorization': 'Bearer ' + token }
    }).then(r => r.json());

    let html = '<div style="background:#fff;border-radius:12px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,0.04);">';
    html += '<h3 style="margin-bottom:16px;">📋 默认里程碑模板</h3>';

    for (const [type, templates] of Object.entries(res)) {
      html += `<h4 style="margin-bottom:8px;color:#2563eb;">${type === 'product' ? '我方数字化产品' : '甲方严选产品'}</h4>`;
      html += '<ol style="margin-bottom:16px;padding-left:20px;">';
      for (const t of templates) {
        html += `<li style="margin-bottom:6px;"><strong>${t.title}</strong> (${t.expected_days}天) — ${t.description}</li>`;
      }
      html += '</ol>';
    }
    html += '</div>';

    const listEl = document.getElementById('service-tracker-list');
    if (listEl) {
      const div = document.createElement('div');
      div.innerHTML = html;
      listEl.insertBefore(div.firstChild, listEl.firstChild);
    }
  } catch(e) {
    alert('加载模板失败: ' + e.message);
  }
}

// --- Banner管理 ---
async function loadBanners() {
  mainEl.innerHTML = `
    <div class="d-flex justify-between items-center mb-20">
      <div>
        <h2 style="margin:0">🖼️ Banner管理</h2>
        <p style="color:#888;font-size:13px;margin:4px 0 0">管理小程序首页轮播Banner，支持定时上下架、点击统计、排序</p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn" onclick="seedBanners()">📦 初始化默认</button>
        <button class="btn btn-primary" onclick="showBannerEditor()">+ 新建Banner</button>
      </div>
    </div>
    <div id="banner-stats" style="display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:20px"></div>
    <div class="card">
      <div class="d-flex justify-between items-center mb-12">
        <h3 style="margin:0">Banner列表</h3>
        <select id="banner-filter" onchange="loadBannerList()" class="form-control" style="width:auto">
          <option value="all">全部状态</option>
          <option value="active">已上架</option>
          <option value="inactive">已下架</option>
        </select>
      </div>
      <div id="banner-list">加载中...</div>
    </div>
  `;
  loadBannerStats();
  loadBannerList();
}

async function loadBannerStats() {
  try {
    const data = await api('/banners');
    const s = data.stats || {};
    const ctr = s.totalImpressions > 0 ? ((s.totalClicks / s.totalImpressions) * 100).toFixed(1) : '0.0';
    document.getElementById('banner-stats').innerHTML = [
      { label: '总数', value: s.total || 0, color: '#2563eb' },
      { label: '生效中', value: s.active || 0, color: '#059669' },
      { label: '待生效', value: s.scheduled || 0, color: '#fbbf24' },
      { label: '已过期', value: s.expired || 0, color: '#f87171' },
      { label: '总点击', value: s.totalClicks || 0, color: '#7c3aed' },
      { label: '点击率', value: ctr + '%', color: '#ec4899' }
    ].map(item => `
      <div class="card" style="text-align:center;padding:16px">
        <div style="font-size:24px;font-weight:700;color:${item.color}">${item.value}</div>
        <div style="font-size:12px;color:#888;margin-top:4px">${item.label}</div>
      </div>
    `).join('');
  } catch(e) { console.error('banner stats error', e); }
}

async function loadBannerList() {
  const filter = document.getElementById('banner-filter')?.value || 'all';
  try {
    const data = await api('/banners?status=' + filter + '&pageSize=100');
    const items = data.items || [];
    if (!items.length) {
      document.getElementById('banner-list').innerHTML = '<div style="text-align:center;padding:40px;color:#999">暂无Banner数据，点击"初始化默认"快速创建</div>';
      return;
    }
    document.getElementById('banner-list').innerHTML = items.map(b => {
      const today = new Date().toISOString().slice(0, 10);
      let statusBadge = '';
      if (b.status === 'inactive') {
        statusBadge = '<span style="color:#f87171">已下架</span>';
      } else if (b.start_date && b.start_date > today) {
        statusBadge = '<span style="color:#fbbf24">待生效</span>';
      } else if (b.end_date && b.end_date < today) {
        statusBadge = '<span style="color:#f87171">已过期</span>';
      } else {
        statusBadge = '<span style="color:#059669">生效中</span>';
      }
      const ctr = (b.impression_count || 0) > 0 ? ((b.click_count / b.impression_count) * 100).toFixed(1) : '0.0';
      return `
        <div style="display:flex;align-items:center;gap:16px;padding:16px;border:1px solid #eee;border-radius:8px;margin-bottom:12px">
          <div style="width:120px;height:60px;border-radius:8px;background:linear-gradient(135deg,${b.bg_color || '#2563eb'},${(b.bg_color || '#2563eb')}dd);display:flex;align-items:center;justify-content:center;flex-shrink:0">
            <span style="color:${b.text_color || '#fff'};font-size:12px;font-weight:600;text-align:center;padding:0 8px">${(b.title || '').slice(0, 10)}</span>
          </div>
          <div style="flex:1">
            <div style="font-weight:600;font-size:15px">${b.title || ''} ${statusBadge}</div>
            <div style="font-size:12px;color:#888;margin-top:4px">${b.subtitle || '无副标题'}</div>
            <div style="font-size:12px;color:#aaa;margin-top:4px">
              排序: ${b.sort_order || 0} | 
              点击: ${b.click_count || 0} | 
              曝光: ${b.impression_count || 0} | 
              CTR: ${ctr}% | 
              日期: ${b.start_date || '不限'} ~ ${b.end_date || '不限'}
            </div>
          </div>
          <div style="display:flex;gap:6px;flex-shrink:0">
            <button class="btn" style="font-size:12px;padding:4px 10px" onclick="toggleBannerStatus(${b.id}, '${b.status === 'active' ? 'inactive' : 'active'}')">${b.status === 'active' ? '下架' : '上架'}</button>
            <button class="btn" style="font-size:12px;padding:4px 10px" onclick="showBannerEditor(${b.id})">编辑</button>
            <button class="btn" style="font-size:12px;padding:4px 10px;color:#f87171" onclick="deleteBanner(${b.id})">删除</button>
          </div>
        </div>
      `;
    }).join('');
  } catch(e) {
    document.getElementById('banner-list').innerHTML = '<div style="text-align:center;padding:40px;color:#f87171">加载失败: ' + e.message + '</div>';
  }
}

async function showBannerEditor(id) {
  let banner = null;
  if (id) {
    try { banner = await api('/banners/' + id); } catch(e) { alert('加载失败'); return; }
  }
  const linkTypes = [
    { value: 'page', label: '小程序页面' },
    { value: 'webview', label: '网页链接' },
    { value: 'miniapp', label: '其他小程序' },
    { value: 'none', label: '仅展示（不可点）' }
  ];
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;padding:24px;width:560px;max-height:85vh;overflow-y:auto">
      <h3 style="margin:0 0 16px">${id ? '编辑Banner' : '新建Banner'}</h3>
      <div style="display:grid;gap:12px">
        <div>
          <label style="font-size:13px;color:#666">标题 *</label>
          <input type="text" id="bn-title" class="form-control" value="${(banner && banner.title) || ''}" placeholder="如：限时免费诊断" style="width:100%">
        </div>
        <div>
          <label style="font-size:13px;color:#666">副标题</label>
          <input type="text" id="bn-subtitle" class="form-control" value="${(banner && banner.subtitle) || ''}" placeholder="如：专家1对1诊断" style="width:100%">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div>
            <label style="font-size:13px;color:#666">背景色</label>
            <input type="color" id="bn-bg-color" class="form-control" value="${(banner && banner.bg_color) || '#2563eb'}" style="width:100%;height:38px">
          </div>
          <div>
            <label style="font-size:13px;color:#666">文字色</label>
            <input type="color" id="bn-text-color" class="form-control" value="${(banner && banner.text_color) || '#ffffff'}" style="width:100%;height:38px">
          </div>
        </div>
        <div>
          <label style="font-size:13px;color:#666">跳转类型</label>
          <select id="bn-link-type" class="form-control" style="width:100%">
            ${linkTypes.map(t => `<option value="${t.value}" ${(banner && banner.link_type) === t.value ? 'selected' : ''}>${t.label}</option>`).join('')}
          </select>
        </div>
        <div>
          <label style="font-size:13px;color:#666">跳转地址</label>
          <input type="text" id="bn-link-url" class="form-control" value="${(banner && banner.link_url) || ''}" placeholder="页面路径/webview URL/AppID" style="width:100%">
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
          <div>
            <label style="font-size:13px;color:#666">排序（数字越小越靠前）</label>
            <input type="number" id="bn-sort" class="form-control" value="${(banner && banner.sort_order) || 0}" style="width:100%">
          </div>
          <div>
            <label style="font-size:13px;color:#666">开始日期</label>
            <input type="date" id="bn-start" class="form-control" value="${(banner && banner.start_date) || ''}" style="width:100%">
          </div>
          <div>
            <label style="font-size:13px;color:#666">结束日期</label>
            <input type="date" id="bn-end" class="form-control" value="${(banner && banner.end_date) || ''}" style="width:100%">
          </div>
        </div>
        <div>
          <label style="font-size:13px;color:#666">状态</label>
          <select id="bn-status" class="form-control" style="width:100%">
            <option value="active" ${(banner && banner.status) === 'active' ? 'selected' : ''}>上架</option>
            <option value="inactive" ${(banner && banner.status) === 'inactive' ? 'selected' : ''}>下架</option>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px">
        <button class="btn" onclick="this.closest('.modal-overlay')?.remove();this.parentElement.parentElement.parentElement.remove()">取消</button>
        <button class="btn btn-primary" onclick="saveBanner(${id || 0}, this)">保存</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function saveBanner(id, btn) {
  const title = document.getElementById('bn-title').value.trim();
  if (!title) { alert('请填写标题'); return; }
  const payload = {
    title,
    subtitle: document.getElementById('bn-subtitle').value.trim(),
    bg_color: document.getElementById('bn-bg-color').value,
    text_color: document.getElementById('bn-text-color').value,
    link_type: document.getElementById('bn-link-type').value,
    link_url: document.getElementById('bn-link-url').value.trim(),
    sort_order: Number(document.getElementById('bn-sort').value) || 0,
    start_date: document.getElementById('bn-start').value,
    end_date: document.getElementById('bn-end').value,
    status: document.getElementById('bn-status').value
  };
  btn.disabled = true;
  btn.textContent = '保存中...';
  try {
    const method = id ? 'PUT' : 'POST';
    const url = id ? '/api/banners/' + id : '/api/banners';
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json', ...authHeaders() },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    btn.closest('.modal-overlay')?.remove();
    btn.parentElement.parentElement.parentElement.remove();
    alert(id ? '更新成功' : '创建成功');
    loadBannerStats();
    loadBannerList();
  } catch(e) {
    alert('保存失败: ' + e.message);
    btn.disabled = false;
    btn.textContent = '保存';
  }
}

async function deleteBanner(id) {
  if (!confirm('确定删除此Banner？此操作不可撤销。')) return;
  try {
    await api('/banners/' + id, { method: 'DELETE' });
    alert('删除成功');
    loadBannerStats();
    loadBannerList();
  } catch(e) { alert('删除失败: ' + e.message); }
}

async function toggleBannerStatus(id, newStatus) {
  try {
    await api('/banners/' + id, { method: 'PUT', body: JSON.stringify({ status: newStatus }) });
    loadBannerStats();
    loadBannerList();
  } catch(e) { alert('操作失败: ' + e.message); }
}

async function seedBanners() {
  if (!confirm('将初始化3条默认Banner数据，如果已有数据将跳过。继续？')) return;
  try {
    const res = await api('/banners/seed', { method: 'POST' });
    alert(res.message || '初始化成功');
    loadBannerStats();
    loadBannerList();
  } catch(e) { alert('初始化失败: ' + e.message); }
}

// ==================== 帮助中心 FAQ 管理 ====================

async function loadFaqs() {
  content.innerHTML = `
    <div class="page-header">
      <h2>❓ 帮助中心管理</h2>
      <div>
        <button class="btn btn-sm btn-outline" onclick="seedFaqs()">📋 初始化默认数据</button>
        <button class="btn btn-sm" onclick="showFaqEditor()">➕ 新建FAQ</button>
        <button class="btn btn-sm btn-outline" onclick="showCategoryEditor()">📁 新建分类</button>
      </div>
    </div>

    <!-- 统计卡片 -->
    <div id="faq-stats" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:20px"></div>

    <!-- 分类概览 -->
    <div id="faq-cat-stats" style="margin-bottom:20px"></div>

    <!-- 筛选 -->
    <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap">
      <select id="faq-filter-cat" class="form-control" style="width:auto" onchange="loadFaqList()">
        <option value="0">全部分类</option>
        <option value="all">全部（含草稿）</option>
      </select>
      <select id="faq-filter-status" class="form-control" style="width:auto" onchange="loadFaqList()">
        <option value="all">全部状态</option>
        <option value="published">已发布</option>
        <option value="draft">草稿</option>
      </select>
      <input id="faq-search" class="form-control" style="flex:1;min-width:200px" placeholder="搜索问题关键词..." oninput="loadFaqList()">
    </div>

    <!-- FAQ列表 -->
    <div id="faq-list-container">加载中...</div>

    <!-- 分类管理 -->
    <div style="margin-top:24px">
      <h3 style="margin-bottom:12px">📁 分类管理</h3>
      <div id="faq-categories-container">加载中...</div>
    </div>
  `;
  loadFaqStats();
  loadFaqCategories();
  loadFaqList();
}

async function loadFaqStats() {
  try {
    const data = await api('/faqs/admin/stats');
    const s = data.data || data;
    const el = document.getElementById('faq-stats');
    if (!el) return;
    const cards = [
      { label: 'FAQ总数', value: s.total_faqs || 0, color: '#2563eb' },
      { label: '已发布', value: s.published_faqs || 0, color: '#10b981' },
      { label: '草稿', value: s.draft_faqs || 0, color: '#f59e0b' },
      { label: '置顶', value: s.pinned_faqs || 0, color: '#8b5cf6' },
      { label: '分类数', value: s.total_categories || 0, color: '#06b6d4' },
      { label: '总浏览', value: s.total_views || 0, color: '#6366f1' },
      { label: '满意度', value: (s.satisfaction_rate || 0) + '%', color: '#ec4899' }
    ];
    el.innerHTML = cards.map(c => `
      <div class="stat-card" style="background:#fff;border-radius:12px;padding:16px;text-align:center;border-top:3px solid ${c.color}">
        <div style="font-size:24px;font-weight:700;color:${c.color}">${c.value}</div>
        <div style="font-size:12px;color:#666;margin-top:4px">${c.label}</div>
      </div>
    `).join('');

    // 分类概览表格
    const catEl = document.getElementById('faq-cat-stats');
    if (catEl && s.category_stats) {
      catEl.innerHTML = `
        <table class="table" style="background:#fff;border-radius:8px;overflow:hidden">
          <thead><tr><th>分类</th><th>总数</th><th>已发布</th><th>浏览量</th></tr></thead>
          <tbody>
            ${s.category_stats.map(c => `<tr>
              <td>${c.icon} ${c.name}</td>
              <td>${c.total}</td>
              <td>${c.published}</td>
              <td>${c.views}</td>
            </tr>`).join('')}
          </tbody>
        </table>
      `;
    }
  } catch(e) { console.error('FAQ stats error:', e); }
}

async function loadFaqCategories() {
  try {
    const data = await api('/faqs/admin/categories');
    const cats = data.data || data || [];
    const el = document.getElementById('faq-categories-container');
    if (!el) return;

    // 更新筛选下拉
    const filterEl = document.getElementById('faq-filter-cat');
    if (filterEl) {
      const cur = filterEl.value;
      filterEl.innerHTML = '<option value="0">全部分类</option><option value="all">全部（含草稿）</option>' +
        cats.map(c => `<option value="${c.id}">${c.icon} ${c.name} (${c.article_count})</option>`).join('');
      filterEl.value = cur;
    }

    if (cats.length === 0) {
      el.innerHTML = '<p style="color:#999;padding:16px">暂无分类，点击「新建分类」创建</p>';
      return;
    }

    el.innerHTML = `
      <table class="table" style="background:#fff;border-radius:8px;overflow:hidden">
        <thead><tr><th>ID</th><th>图标</th><th>名称</th><th>描述</th><th>排序</th><th>状态</th><th>条目数</th><th>操作</th></tr></thead>
        <tbody>
          ${cats.map(c => `<tr>
            <td>${c.id}</td>
            <td>${c.icon}</td>
            <td>${c.name}</td>
            <td style="color:#888;font-size:13px">${c.description || '-'}</td>
            <td>${c.sort_order}</td>
            <td><span class="badge ${c.status === 'active' ? 'badge-success' : 'badge-secondary'}">${c.status === 'active' ? '启用' : '禁用'}</span></td>
            <td>${c.article_count}</td>
            <td>
              <button class="btn btn-sm btn-outline" onclick="showCategoryEditor(${c.id})">编辑</button>
              <button class="btn btn-sm btn-danger" onclick="deleteCategory(${c.id}, '${c.name}')">删除</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table>
    `;
  } catch(e) { console.error('FAQ categories error:', e); }
}

async function loadFaqList() {
  const catFilter = document.getElementById('faq-filter-cat')?.value || '0';
  const statusFilter = document.getElementById('faq-filter-status')?.value || 'all';
  const keyword = document.getElementById('faq-search')?.value || '';

  let url = '/faqs/admin/list?page=1&page_size=50';
  if (catFilter !== '0' && catFilter !== 'all') url += `&category_id=${catFilter}`;
  if (statusFilter !== 'all') url += `&status=${statusFilter}`;
  if (keyword) url += `&keyword=${encodeURIComponent(keyword)}`;

  try {
    const data = await api(url);
    const result = data.data || data;
    const list = result.list || [];
    const el = document.getElementById('faq-list-container');
    if (!el) return;

    if (list.length === 0) {
      el.innerHTML = '<p style="color:#999;padding:24px;text-align:center">暂无FAQ数据</p>';
      return;
    }

    el.innerHTML = `
      <table class="table" style="background:#fff;border-radius:8px;overflow:hidden">
        <thead><tr><th>ID</th><th>分类</th><th>问题</th><th>状态</th><th>置顶</th><th>浏览</th><th>有用</th><th>无用</th><th>排序</th><th>操作</th></tr></thead>
        <tbody>
          ${list.map(f => `<tr>
            <td>${f.id}</td>
            <td style="font-size:12px">${f.category_name || '-'}</td>
            <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${f.question}</td>
            <td><span class="badge ${f.status === 'published' ? 'badge-success' : 'badge-secondary'}">${f.status === 'published' ? '已发布' : '草稿'}</span></td>
            <td>${f.is_pinned ? '📌' : '-'}</td>
            <td>${f.view_count || 0}</td>
            <td style="color:#10b981">${f.helpful_count || 0}</td>
            <td style="color:#ef4444">${f.unhelpful_count || 0}</td>
            <td>${f.sort_order}</td>
            <td>
              <button class="btn btn-sm btn-outline" onclick="showFaqEditor(${f.id})">编辑</button>
              <button class="btn btn-sm btn-danger" onclick="deleteFaq(${f.id})">删除</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table>
      <p style="color:#888;font-size:13px;margin-top:8px">共 ${result.total || list.length} 条</p>
    `;
  } catch(e) {
    console.error('FAQ list error:', e);
    document.getElementById('faq-list-container').innerHTML = '<p style="color:#f44336;padding:16px">加载失败</p>';
  }
}

async function showFaqEditor(id) {
  let faq = { category_id: 0, question: '', answer: '', tags: [], status: 'published', is_pinned: 0, sort_order: 0 };
  let categories = [];

  try {
    const catData = await api('/faqs/admin/categories');
    categories = catData.data || catData || [];
  } catch(e) {}

  if (id) {
    try {
      const data = await api(`/faqs/admin/list?keyword=&page=1&page_size=50`);
      const allFaqs = (data.data || data).list || [];
      faq = allFaqs.find(f => f.id === id) || faq;
    } catch(e) {}
  }

  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;padding:24px;max-width:600px;width:100%;max-height:80vh;overflow-y:auto">
      <h3 style="margin:0 0 20px">${id ? '编辑FAQ' : '新建FAQ'}</h3>
      <div style="display:flex;flex-direction:column;gap:16px">
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">分类</label>
          <select id="edit-cat" class="form-control">
            <option value="0">未分类</option>
            ${categories.map(c => `<option value="${c.id}" ${c.id === faq.category_id ? 'selected' : ''}>${c.icon} ${c.name}</option>`).join('')}
          </select>
        </div>
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">问题 *</label>
          <input id="edit-question" class="form-control" value="${faq.question.replace(/"/g, '&quot;')}" placeholder="输入问题">
        </div>
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">答案 *</label>
          <textarea id="edit-answer" class="form-control" rows="6" placeholder="输入答案，支持换行">${faq.answer}</textarea>
        </div>
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">标签（逗号分隔）</label>
          <input id="edit-tags" class="form-control" value="${(faq.tags || []).join(', ')}" placeholder="如: 支付, 退款">
        </div>
        <div style="display:flex;gap:12px">
          <div style="flex:1">
            <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">状态</label>
            <select id="edit-status" class="form-control">
              <option value="published" ${faq.status === 'published' ? 'selected' : ''}>已发布</option>
              <option value="draft" ${faq.status === 'draft' ? 'selected' : ''}>草稿</option>
            </select>
          </div>
          <div style="flex:1">
            <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">排序</label>
            <input id="edit-sort" type="number" class="form-control" value="${faq.sort_order || 0}">
          </div>
          <div style="flex:1">
            <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">置顶</label>
            <select id="edit-pinned" class="form-control">
              <option value="0" ${!faq.is_pinned ? 'selected' : ''}>否</option>
              <option value="1" ${faq.is_pinned ? 'selected' : ''}>是</option>
            </select>
          </div>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:24px;justify-content:flex-end">
        <button class="btn btn-outline" onclick="this.closest('div[style*=fixed]').remove()">取消</button>
        <button class="btn" onclick="saveFaq(${id || 0})">保存</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function saveFaq(id) {
  const category_id = parseInt(document.getElementById('edit-cat').value);
  const question = document.getElementById('edit-question').value.trim();
  const answer = document.getElementById('edit-answer').value.trim();
  const tagsStr = document.getElementById('edit-tags').value.trim();
  const status = document.getElementById('edit-status').value;
  const sort_order = parseInt(document.getElementById('edit-sort').value) || 0;
  const is_pinned = parseInt(document.getElementById('edit-pinned').value);

  if (!question || !answer) {
    alert('问题和答案不能为空');
    return;
  }

  const tags = tagsStr ? tagsStr.split(',').map(t => t.trim()).filter(Boolean) : [];
  const body = { category_id, question, answer, tags, status, sort_order, is_pinned };

  try {
    if (id) {
      await api(`/faqs/admin/update/${id}`, { method: 'PUT', body: JSON.stringify(body) });
    } else {
      await api('/faqs/admin/create', { method: 'POST', body: JSON.stringify(body) });
    }
    document.querySelector('div[style*="fixed"]')?.remove();
    loadFaqList();
    loadFaqStats();
    loadFaqCategories();
    alert(id ? '更新成功' : '创建成功');
  } catch(e) {
    alert('保存失败: ' + e.message);
  }
}

async function deleteFaq(id) {
  if (!confirm('确认删除这条FAQ？')) return;
  try {
    await api(`/faqs/admin/delete/${id}`, { method: 'DELETE' });
    loadFaqList();
    loadFaqStats();
    loadFaqCategories();
    alert('删除成功');
  } catch(e) { alert('删除失败: ' + e.message); }
}

async function showCategoryEditor(id) {
  let cat = { name: '', icon: '📋', description: '', sort_order: 0, status: 'active' };

  if (id) {
    try {
      const data = await api('/faqs/admin/categories');
      const cats = data.data || data || [];
      cat = cats.find(c => c.id === id) || cat;
    } catch(e) {}
  }

  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;padding:24px;max-width:440px;width:100%">
      <h3 style="margin:0 0 20px">${id ? '编辑分类' : '新建分类'}</h3>
      <div style="display:flex;flex-direction:column;gap:16px">
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">图标</label>
          <input id="cat-icon" class="form-control" value="${cat.icon}" style="width:60px;text-align:center;font-size:24px">
        </div>
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">名称 *</label>
          <input id="cat-name" class="form-control" value="${cat.name}" placeholder="如：平台服务">
        </div>
        <div>
          <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">描述</label>
          <input id="cat-desc" class="form-control" value="${cat.description || ''}" placeholder="分类描述">
        </div>
        <div style="display:flex;gap:12px">
          <div style="flex:1">
            <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">排序</label>
            <input id="cat-sort" type="number" class="form-control" value="${cat.sort_order || 0}">
          </div>
          <div style="flex:1">
            <label style="font-size:13px;color:#666;display:block;margin-bottom:4px">状态</label>
            <select id="cat-status" class="form-control">
              <option value="active" ${cat.status === 'active' ? 'selected' : ''}>启用</option>
              <option value="inactive" ${cat.status === 'inactive' ? 'selected' : ''}>禁用</option>
            </select>
          </div>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:24px;justify-content:flex-end">
        <button class="btn btn-outline" onclick="this.closest('div[style*=fixed]').remove()">取消</button>
        <button class="btn" onclick="saveCategory(${id || 0})">保存</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function saveCategory(id) {
  const name = document.getElementById('cat-name').value.trim();
  const icon = document.getElementById('cat-icon').value.trim() || '📋';
  const description = document.getElementById('cat-desc').value.trim();
  const sort_order = parseInt(document.getElementById('cat-sort').value) || 0;
  const status = document.getElementById('cat-status').value;

  if (!name) { alert('名称不能为空'); return; }

  const body = { name, icon, description, sort_order, status };

  try {
    if (id) {
      await api(`/faqs/admin/categories/${id}`, { method: 'PUT', body: JSON.stringify(body) });
    } else {
      await api('/faqs/admin/categories', { method: 'POST', body: JSON.stringify(body) });
    }
    document.querySelector('div[style*="fixed"]')?.remove();
    loadFaqCategories();
    loadFaqStats();
    alert(id ? '更新成功' : '创建成功');
  } catch(e) { alert('保存失败: ' + e.message); }
}

async function deleteCategory(id, name) {
  if (!confirm(`确认删除分类「${name}」？该分类下的所有FAQ也将被删除！`)) return;
  try {
    const res = await api(`/faqs/admin/categories/${id}`, { method: 'DELETE' });
    loadFaqCategories();
    loadFaqStats();
    loadFaqList();
    alert(res.message || '删除成功');
  } catch(e) { alert('删除失败: ' + e.message); }
}

async function seedFaqs() {
  if (!confirm('将初始化6个分类和21条默认FAQ数据。如果已有数据将跳过。继续？')) return;
  try {
    const res = await api('/faqs/admin/seed', { method: 'POST' });
    alert(res.msg || res.message || '初始化成功');
    loadFaqStats();
    loadFaqCategories();
    loadFaqList();
  } catch(e) { alert('初始化失败: ' + e.message); }
}

// ==================== 发票管理 ====================
async function loadInvoices() {
  const c = document.getElementById('content');
  c.innerHTML = `
    <h2>🧾 发票管理</h2>
    <div id="inv-stats" class="stats-grid"></div>
    <div class="filter-bar" style="margin:16px 0;display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
      <select id="inv-status" onchange="loadInvoiceList()" style="padding:8px;border-radius:6px;border:1px solid #ddd;">
        <option value="">全部状态</option>
        <option value="pending">待开票</option>
        <option value="issued">已开票</option>
        <option value="rejected">已拒绝</option>
        <option value="voided">已作废</option>
      </select>
      <select id="inv-type" onchange="loadInvoiceList()" style="padding:8px;border-radius:6px;border:1px solid #ddd;">
        <option value="">全部类型</option>
        <option value="normal">增值税普通电子发票</option>
        <option value="special">增值税专用发票</option>
        <option value="paper">纸质发票</option>
      </select>
      <input id="inv-keyword" placeholder="搜索抬头/编号/订单号/手机号" onkeyup="if(event.key==='Enter')loadInvoiceList()" style="padding:8px;border-radius:6px;border:1px solid #ddd;flex:1;min-width:200px;">
      <button onclick="loadInvoiceList()" style="padding:8px 20px;border-radius:6px;background:#2563eb;color:#fff;border:none;cursor:pointer;">搜索</button>
    </div>
    <div id="inv-trend" style="margin:16px 0;padding:16px;background:#fff;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,0.04);"></div>
    <div id="inv-list"></div>
    <div id="inv-pagination" style="text-align:center;padding:20px;"></div>
  `;
  loadInvoiceStats();
  loadInvoiceTrend();
  loadInvoiceList();
}

async function loadInvoiceStats() {
  try {
    const res = await api('/invoices/admin/stats');
    const d = res.data || res;
    const el = document.getElementById('inv-stats');
    if (!el) return;
    el.innerHTML = `
      <div class="stat-card"><div class="stat-num">${d.total||0}</div><div class="stat-label">总申请</div></div>
      <div class="stat-card" style="border-left:4px solid #f59e0b;"><div class="stat-num" style="color:#f59e0b;">${d.pending||0}</div><div class="stat-label">待开票</div></div>
      <div class="stat-card" style="border-left:4px solid #10b981;"><div class="stat-num" style="color:#10b981;">${d.issued||0}</div><div class="stat-label">已开票</div></div>
      <div class="stat-card" style="border-left:4px solid #ef4444;"><div class="stat-num" style="color:#ef4444;">${d.rejected||0}</div><div class="stat-label">已拒绝</div></div>
      <div class="stat-card" style="border-left:4px solid #9ca3af;"><div class="stat-num" style="color:#9ca3af;">${d.voided||0}</div><div class="stat-label">已作废</div></div>
      <div class="stat-card" style="border-left:4px solid #2563eb;"><div class="stat-num" style="color:#2563eb;">¥${(d.totalAmount||0).toFixed(2)}</div><div class="stat-label">已开票金额</div></div>
      <div class="stat-card" style="border-left:4px solid #f59e0b;"><div class="stat-num" style="color:#f59e0b;">¥${(d.pendingAmount||0).toFixed(2)}</div><div class="stat-label">待开票金额</div></div>
    `;
  } catch(e) { console.error('发票统计失败:', e); }
}

async function loadInvoiceTrend() {
  try {
    const res = await api('/invoices/admin/stats');
    const d = res.data || res;
    const trend = d.trend30 || [];
    if (!trend.length) return;
    const el = document.getElementById('inv-trend');
    if (!el) return;
    const maxCount = Math.max(...trend.map(t => t.count), 1);
    const barWidth = Math.max(100 / trend.length, 1.5);
    el.innerHTML = '<div style="font-size:14px;font-weight:600;margin-bottom:12px;color:#374151;">近30天发票申请趋势</div>' +
      '<div style="display:flex;align-items:flex-end;height:120px;gap:2px;">' +
      trend.map(t => {
        const h = (t.count / maxCount) * 100;
        return `<div title="${t.date}: ${t.count}笔 ¥${t.amount.toFixed(2)}" style="flex:1;height:${h}%;min-height:2px;background:linear-gradient(to top,#2563eb,#60a5fa);border-radius:2px 2px 0 0;"></div>`;
      }).join('') +
      '</div>';
  } catch(e) { console.error('趋势加载失败:', e); }
}

let invPage = 1;
async function loadInvoiceList(page) {
  if (page) invPage = page;
  const status = document.getElementById('inv-status')?.value || '';
  const type = document.getElementById('inv-type')?.value || '';
  const keyword = document.getElementById('inv-keyword')?.value || '';
  const el = document.getElementById('inv-list');
  if (!el) return;
  el.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">加载中...</div>';
  try {
    const params = new URLSearchParams({ page: invPage, pageSize: 15 });
    if (status) params.set('status', status);
    if (type) params.set('invoice_type', type);
    if (keyword) params.set('keyword', keyword);
    const res = await api(`/invoices/admin/list?${params}`);
    const list = res.data || [];
    const total = res.total || 0;
    const stats = res.stats || {};
    if (!list.length) {
      el.innerHTML = '<div style="text-align:center;padding:40px;color:#999;">暂无发票记录</div>';
      document.getElementById('inv-pagination').innerHTML = '';
      return;
    }
    const typeMap = { normal: '普票电子', special: '专票', paper: '纸质' };
    const statusMap = { pending: '待开票', issued: '已开票', rejected: '已拒绝', voided: '已作废' };
    const statusColor = { pending: '#f59e0b', issued: '#10b981', rejected: '#ef4444', voided: '#9ca3af' };
    el.innerHTML = list.map(inv => `
      <div class="card" style="background:#fff;border-radius:10px;padding:16px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,0.04);border-left:4px solid ${statusColor[inv.status]||'#ccc'};">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <div>
            <span style="font-size:12px;padding:2px 8px;border-radius:4px;background:#e0e7ff;color:#4f46e5;margin-right:8px;">${typeMap[inv.invoice_type]||inv.invoice_type}</span>
            <span style="font-weight:600;font-size:16px;">${inv.title_name}</span>
          </div>
          <span style="padding:4px 12px;border-radius:12px;font-size:13px;background:${statusColor[inv.status]}20;color:${statusColor[inv.status]};">${statusMap[inv.status]||inv.status}</span>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:16px;font-size:13px;color:#666;">
          <span>编号：${inv.invoice_no}</span>
          <span>订单：${inv.order_no}</span>
          <span>金额：¥${(inv.amount||0).toFixed(2)}</span>
          <span>申请人：${inv.applicant_name} ${inv.applicant_phone}</span>
          <span>时间：${(inv.created_at||'').slice(0,19)}</span>
        </div>
        ${inv.invoice_number ? `<div style="font-size:13px;color:#059669;margin-top:6px;">发票号码：${inv.invoice_number} | 开票时间：${(inv.issued_at||'').slice(0,19)}</div>` : ''}
        ${inv.reject_reason ? `<div style="font-size:13px;color:#ef4444;margin-top:6px;">拒绝原因：${inv.reject_reason}</div>` : ''}
        <div style="display:flex;gap:8px;margin-top:12px;">
          <button onclick="viewInvoiceDetail(${inv.id})" style="padding:6px 16px;border-radius:6px;background:#f3f4f6;color:#374151;border:none;cursor:pointer;font-size:13px;">详情</button>
          ${inv.status === 'pending' ? `<button onclick="showIssueModal(${inv.id})" style="padding:6px 16px;border-radius:6px;background:#10b981;color:#fff;border:none;cursor:pointer;font-size:13px;">开票</button>` : ''}
          ${inv.status === 'pending' ? `<button onclick="showRejectModal(${inv.id})" style="padding:6px 16px;border-radius:6px;background:#ef4444;color:#fff;border:none;cursor:pointer;font-size:13px;">拒绝</button>` : ''}
          ${inv.status === 'issued' ? `<button onclick="showVoidModal(${inv.id})" style="padding:6px 16px;border-radius:6px;background:#9ca3af;color:#fff;border:none;cursor:pointer;font-size:13px;">作废</button>` : ''}
        </div>
      </div>
    `).join('');
    // 分页
    const totalPages = Math.ceil(total / 15);
    const pgEl = document.getElementById('inv-pagination');
    if (totalPages > 1) {
      let html = '';
      for (let i = 1; i <= totalPages; i++) {
        html += `<button onclick="loadInvoiceList(${i})" style="padding:6px 12px;margin:0 2px;border-radius:4px;border:1px solid #ddd;background:${i===invPage?'#2563eb':'#fff'};color:${i===invPage?'#fff':'#374151'};cursor:pointer;">${i}</button>`;
      }
      pgEl.innerHTML = html;
    } else {
      pgEl.innerHTML = '';
    }
  } catch(e) {
    el.innerHTML = '<div style="text-align:center;padding:40px;color:#ef4444;">加载失败: ' + e.message + '</div>';
  }
}

async function viewInvoiceDetail(id) {
  try {
    const res = await api(`/invoices/${id}`);
    const inv = res.data || res;
    const typeMap = { normal: '增值税普通电子发票', special: '增值税专用发票', paper: '纸质发票' };
    const statusMap = { pending: '待开票', issued: '已开票', rejected: '已拒绝', voided: '已作废' };
    let html = '<div style="font-size:14px;line-height:2;">';
    html += `<div><b>申请编号：</b>${inv.invoice_no}</div>`;
    html += `<div><b>状态：</b>${statusMap[inv.status]||inv.status}</div>`;
    html += `<div><b>发票类型：</b>${typeMap[inv.invoice_type]||inv.invoice_type}</div>`;
    html += `<div><b>抬头类型：</b>${inv.title_type==='enterprise'?'企业':'个人'}</div>`;
    html += `<div><b>发票抬头：</b>${inv.title_name}</div>`;
    if (inv.tax_no) html += `<div><b>税号：</b>${inv.tax_no}</div>`;
    if (inv.bank_name) html += `<div><b>开户银行：</b>${inv.bank_name}</div>`;
    if (inv.bank_account) html += `<div><b>银行账号：</b>${inv.bank_account}</div>`;
    if (inv.company_address) html += `<div><b>公司地址：</b>${inv.company_address}</div>`;
    if (inv.company_phone) html += `<div><b>公司电话：</b>${inv.company_phone}</div>`;
    if (inv.email) html += `<div><b>接收邮箱：</b>${inv.email}</div>`;
    if (inv.receiving_name) html += `<div><b>收件人：</b>${inv.receiving_name} ${inv.receiving_phone} ${inv.receiving_address}</div>`;
    html += `<div><b>开票金额：</b>¥${(inv.amount||0).toFixed(2)}</div>`;
    html += `<div><b>开票内容：</b>${inv.content||'—'}</div>`;
    html += `<div><b>订单号：</b>${inv.order_no}</div>`;
    html += `<div><b>申请人：</b>${inv.applicant_name} ${inv.applicant_phone}</div>`;
    if (inv.invoice_number) html += `<div><b>发票号码：</b>${inv.invoice_number}</div>`;
    if (inv.issued_at) html += `<div><b>开票时间：</b>${inv.issued_at}</div>`;
    if (inv.issued_by) html += `<div><b>开票人：</b>${inv.issued_by}</div>`;
    if (inv.reject_reason) html += `<div><b>拒绝原因：</b>${inv.reject_reason}</div>`;
    if (inv.voided_reason) html += `<div><b>作废原因：</b>${inv.voided_reason}</div>`;
    if (inv.remark) html += `<div><b>备注：</b>${inv.remark}</div>`;
    html += `<div><b>申请时间：</b>${inv.created_at}</div>`;
    html += '</div>';
    showModal('发票详情', html);
  } catch(e) { alert('获取详情失败: ' + e.message); }
}

function showIssueModal(id) {
  const html = `
    <div style="margin-bottom:12px;">
      <label style="display:block;margin-bottom:6px;font-weight:600;">发票号码（选填，留空自动生成）</label>
      <input id="issue-number" placeholder="如：044001900111" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;">
    </div>
    <div style="margin-bottom:12px;">
      <label style="display:block;margin-bottom:6px;font-weight:600;">发票文件URL（选填）</label>
      <input id="issue-url" placeholder="https://..." style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;">
    </div>
    <div style="text-align:right;">
      <button onclick="closeModal()" style="padding:8px 20px;border-radius:6px;background:#f5f5f5;border:none;cursor:pointer;margin-right:8px;">取消</button>
      <button onclick="doIssue(${id})" style="padding:8px 20px;border-radius:6px;background:#10b981;color:#fff;border:none;cursor:pointer;">确认开票</button>
    </div>
  `;
  showModal('确认开票', html);
}

async function doIssue(id) {
  const number = document.getElementById('issue-number')?.value.trim() || '';
  const url = document.getElementById('issue-url')?.value.trim() || '';
  try {
    await api(`/invoices/admin/${id}/issue`, { method: 'POST', body: JSON.stringify({ invoice_number: number, invoice_file_url: url }) });
    closeModal();
    loadInvoiceList();
    loadInvoiceStats();
  } catch(e) { alert('开票失败: ' + e.message); }
}

function showRejectModal(id) {
  const html = `
    <div style="margin-bottom:12px;">
      <label style="display:block;margin-bottom:6px;font-weight:600;">拒绝原因 <span style="color:#ef4444;">*</span></label>
      <textarea id="reject-reason" placeholder="如：抬头信息有误、税号不正确等" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;min-height:80px;resize:vertical;"></textarea>
    </div>
    <div style="text-align:right;">
      <button onclick="closeModal()" style="padding:8px 20px;border-radius:6px;background:#f5f5f5;border:none;cursor:pointer;margin-right:8px;">取消</button>
      <button onclick="doReject(${id})" style="padding:8px 20px;border-radius:6px;background:#ef4444;color:#fff;border:none;cursor:pointer;">确认拒绝</button>
    </div>
  `;
  showModal('拒绝开票', html);
}

async function doReject(id) {
  const reason = document.getElementById('reject-reason')?.value.trim();
  if (!reason) { alert('请填写拒绝原因'); return; }
  try {
    await api(`/invoices/admin/${id}/reject`, { method: 'POST', body: JSON.stringify({ reason }) });
    closeModal();
    loadInvoiceList();
    loadInvoiceStats();
  } catch(e) { alert('操作失败: ' + e.message); }
}

function showVoidModal(id) {
  const html = `
    <div style="margin-bottom:12px;">
      <label style="display:block;margin-bottom:6px;font-weight:600;">作废原因 <span style="color:#ef4444;">*</span></label>
      <textarea id="void-reason" placeholder="如：开票信息错误需重开等" style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;min-height:80px;resize:vertical;"></textarea>
    </div>
    <div style="text-align:right;">
      <button onclick="closeModal()" style="padding:8px 20px;border-radius:6px;background:#f5f5f5;border:none;cursor:pointer;margin-right:8px;">取消</button>
      <button onclick="doVoid(${id})" style="padding:8px 20px;border-radius:6px;background:#9ca3af;color:#fff;border:none;cursor:pointer;">确认作废</button>
    </div>
  `;
  showModal('作废发票', html);
}

async function doVoid(id) {
  const reason = document.getElementById('void-reason')?.value.trim();
  if (!reason) { alert('请填写作废原因'); return; }
  try {
    await api(`/invoices/admin/${id}/void`, { method: 'POST', body: JSON.stringify({ reason }) });
    closeModal();
    loadInvoiceList();
    loadInvoiceStats();
  } catch(e) { alert('操作失败: ' + e.message); }
}

// --- 售后工单管理 ---
async function loadTickets() {
  const stats = await api('/tickets/admin/stats').catch(() => ({}));
  const sd = stats.data || stats;
  const statCards = [
    { label: '总工单', val: sd.total || 0, color: '#3b82f6' },
    { label: '待处理', val: (sd.byStatus||{}).open || 0, color: '#f59e0b' },
    { label: '处理中', val: (sd.byStatus||{}).in_progress || 0, color: '#3b82f6' },
    { label: '已解决', val: (sd.byStatus||{}).resolved || 0, color: '#10b981' },
    { label: '已关闭', val: (sd.byStatus||{}).closed || 0, color: '#9ca3af' },
    { label: '紧急', val: (sd.byPriority||{}).urgent || 0, color: '#ef4444' },
    { label: '平均满意度', val: sd.avgSatisfaction || 0, color: '#fbbf24', suffix: '⭐' },
    { label: '平均响应(h)', val: sd.avgResponseHours || 0, color: '#8b5cf6' }
  ];

  let statsHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:20px">';
  statCards.forEach(s => {
    statsHtml += `<div style="background:#fff;border-radius:12px;padding:16px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,.06)">
      <div style="font-size:28px;font-weight:700;color:${s.color}">${s.val}${s.suffix||''}</div>
      <div style="font-size:12px;color:#888;margin-top:4px">${s.label}</div>
    </div>`;
  });
  statsHtml += '</div>';

  // 近7天趋势
  const trend = sd.trend || [];
  let trendHtml = '<div style="background:#fff;border-radius:12px;padding:20px;margin-bottom:20px"><h3 style="margin:0 0 12px;font-size:16px">近7天工单趋势</h3>';
  trendHtml += '<div style="display:flex;gap:8px;align-items:flex-end;height:120px">';
  const maxVal = Math.max(...trend.map(t => Math.max(t.created, t.resolved)), 1);
  trend.forEach(t => {
    const h1 = (t.created / maxVal) * 100;
    const h2 = (t.resolved / maxVal) * 100;
    trendHtml += `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px">
      <div style="display:flex;gap:2px;align-items:flex-end;height:100px">
        <div style="width:16px;height:${h1}%;background:#3b82f6;border-radius:3px 3px 0 0" title="新增${t.created}"></div>
        <div style="width:16px;height:${h2}%;background:#10b981;border-radius:3px 3px 0 0" title="解决${t.resolved}"></div>
      </div>
      <div style="font-size:10px;color:#888">${t.date.slice(5)}</div>
    </div>`;
  });
  trendHtml += '</div><div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:#888"><span>🔵 新增</span><span>🟢 解决</span></div></div>';

  document.getElementById('content').innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <div>
        <h2 style="margin:0">🎫 售后工单管理</h2>
        <p style="color:#888;font-size:13px;margin:4px 0 0">用户提交的售后工单，支持分配处理、回复、状态管理</p>
      </div>
    </div>
    ${statsHtml}
    ${trendHtml}
    <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap">
      <select id="ticket-status-filter" class="form-control" style="width:auto" onchange="loadTicketList()">
        <option value="all">全部状态</option>
        <option value="open">待处理</option>
        <option value="in_progress">处理中</option>
        <option value="resolved">已解决</option>
        <option value="closed">已关闭</option>
        <option value="reopened">已重开</option>
      </select>
      <select id="ticket-priority-filter" class="form-control" style="width:auto" onchange="loadTicketList()">
        <option value="all">全部优先级</option>
        <option value="urgent">紧急</option>
        <option value="high">高</option>
        <option value="medium">中</option>
        <option value="low">低</option>
      </select>
      <select id="ticket-category-filter" class="form-control" style="width:auto" onchange="loadTicketList()">
        <option value="all">全部类型</option>
        <option value="bug">缺陷报告</option>
        <option value="feature">需求变更</option>
        <option value="question">使用咨询</option>
        <option value="complaint">投诉</option>
        <option value="other">其他</option>
      </select>
      <input id="ticket-search" class="form-control" placeholder="搜索工单..." style="width:240px" onkeyup="if(event.key==='Enter')loadTicketList()">
      <button class="btn" onclick="loadTicketList()">搜索</button>
    </div>
    <div id="ticket-list-container"></div>
    <div id="ticket-pagination" style="margin-top:16px;text-align:center"></div>
  `;
  loadTicketList();
}

let ticketPage = 1;
async function loadTicketList(page) {
  if (page) ticketPage = page;
  const status = document.getElementById('ticket-status-filter')?.value || 'all';
  const priority = document.getElementById('ticket-priority-filter')?.value || 'all';
  const category = document.getElementById('ticket-category-filter')?.value || 'all';
  const keyword = document.getElementById('ticket-search')?.value || '';
  const data = await api(`/tickets/admin/list?status=${status}&priority=${priority}&category=${category}&keyword=${encodeURIComponent(keyword)}&page=${ticketPage}&pageSize=10`);
  const d = data.data || data;
  const list = d.list || [];
  const stats = d.stats || {};

  const catLabels = { bug:'缺陷报告', feature:'需求变更', question:'使用咨询', complaint:'投诉', other:'其他' };
  const priLabels = { low:'低', medium:'中', high:'高', urgent:'紧急' };
  const priColors = { low:'#9ca3af', medium:'#3b82f6', high:'#f59e0b', urgent:'#ef4444' };
  const stLabels = { open:'待处理', in_progress:'处理中', resolved:'已解决', closed:'已关闭', reopened:'已重开' };
  const stColors = { open:'#f59e0b', in_progress:'#3b82f6', resolved:'#10b981', closed:'#9ca3af', reopened:'#8b5cf6' };

  let html = '';
  if (list.length === 0) {
    html = '<div style="text-align:center;padding:60px;color:#999">暂无工单</div>';
  } else {
    list.forEach(t => {
      html += `<div style="background:#fff;border-radius:12px;padding:16px;margin-bottom:12px;box-shadow:0 1px 4px rgba(0,0,0,.04);border-left:4px solid ${priColors[t.priority]||'#ccc'}">
        <div style="display:flex;justify-content:space-between;align-items:flex-start">
          <div style="flex:1">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
              <span style="font-size:12px;color:#999;font-family:monospace">${t.ticket_no}</span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:${stColors[t.status]}20;color:${stColors[t.status]}">${stLabels[t.status]}</span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;background:#f3f4f6;color:#6b7280">${catLabels[t.category]||t.category}</span>
              <span style="font-size:11px;padding:2px 8px;border-radius:4px;border:1px solid ${priColors[t.priority]}40;color:${priColors[t.priority]}">${priLabels[t.priority]}优先级</span>
            </div>
            <div style="font-size:16px;font-weight:600;color:#1f2937;margin-bottom:4px">${t.title}</div>
            <div style="font-size:13px;color:#666;line-height:1.5;max-height:40px;overflow:hidden">${(t.description||'').slice(0,100)}</div>
            <div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:#999">
              <span>👤 ${t.applicant_name || '匿名'}</span>
              <span>📱 ${t.applicant_phone}</span>
              ${t.order_no ? `<span>📦 ${t.order_no}</span>` : ''}
              ${t.product_title ? `<span>🏷️ ${t.product_title}</span>` : ''}
              ${t.assignee ? `<span>🔧 ${t.assignee}</span>` : ''}
              <span>💬 ${t.reply_count||0}</span>
              <span>🕐 ${(t.created_at||'').slice(0,16)}</span>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px">
            <button class="btn btn-sm btn-primary" onclick="viewTicketDetail(${t.id})">详情</button>
          </div>
        </div>
      </div>`;
    });
  }
  document.getElementById('ticket-list-container').innerHTML = html;

  // 分页
  const total = d.total || 0;
  const totalPages = Math.ceil(total / 10);
  let pgHtml = '';
  for (let i = 1; i <= Math.min(totalPages, 10); i++) {
    pgHtml += `<button class="btn btn-sm ${i===ticketPage?'btn-primary':''}" onclick="loadTicketList(${i})" style="margin:0 2px">${i}</button>`;
  }
  document.getElementById('ticket-pagination').innerHTML = pgHtml;
}

async function viewTicketDetail(id) {
  const data = await api(`/tickets/admin/${id}`);
  const d = data.data || data;
  const t = d.ticket;
  const replies = d.replies || [];
  const catLabels = { bug:'缺陷报告', feature:'需求变更', question:'使用咨询', complaint:'投诉', other:'其他' };
  const priLabels = { low:'低', medium:'中', high:'高', urgent:'紧急' };
  const stLabels = { open:'待处理', in_progress:'处理中', resolved:'已解决', closed:'已关闭', reopened:'已重开' };

  let repliesHtml = '';
  replies.forEach(r => {
    const isAdmin = r.replier_role === 'admin';
    repliesHtml += `<div style="background:${isAdmin?'#eff6ff':'#f9fafb'};border-left:3px solid ${isAdmin?'#2563eb':'#9ca3af'};padding:10px 14px;border-radius:8px;margin-bottom:8px">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <strong style="font-size:13px">${r.replier_name}</strong>
        ${isAdmin?'<span style="font-size:10px;background:#2563eb;color:#fff;padding:1px 6px;border-radius:3px">官方</span>':''}
        ${r.is_internal?'<span style="font-size:10px;background:#fbbf24;color:#fff;padding:1px 6px;border-radius:3px">内部备注</span>':''}
        <span style="font-size:11px;color:#999;margin-left:auto">${(r.created_at||'').slice(0,16)}</span>
      </div>
      <div style="font-size:14px;color:#374151;line-height:1.5">${r.content}</div>
    </div>`;
  });

  const html = `
    <div style="max-width:700px">
      <div style="margin-bottom:16px">
        <div style="font-size:12px;color:#999;font-family:monospace">${t.ticket_no}</div>
        <div style="font-size:20px;font-weight:700;color:#1f2937;margin:4px 0">${t.title}</div>
        <div style="display:flex;gap:8px;margin-top:8px">
          <span style="font-size:12px;padding:3px 10px;border-radius:4px;background:#f3f4f6">${catLabels[t.category]}</span>
          <span style="font-size:12px;padding:3px 10px;border-radius:4px;background:#f3f4f6">${priLabels[t.priority]}优先级</span>
          <span style="font-size:12px;padding:3px 10px;border-radius:4px;background:#dbeafe;color:#1e40af">${stLabels[t.status]}</span>
        </div>
      </div>
      <div style="background:#f9fafb;border-radius:8px;padding:14px;margin-bottom:16px;font-size:14px;color:#4b5563;line-height:1.6">${t.description}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;font-size:13px">
        <div>👤 申请人: ${t.applicant_name||'-'}</div>
        <div>📱 电话: ${t.applicant_phone}</div>
        <div>📦 订单: ${t.order_no||'-'}</div>
        <div>🏷️ 产品: ${t.product_title||'-'}</div>
        <div>🔧 处理人: ${t.assignee||'未分配'}</div>
        <div>🕐 提交: ${(t.created_at||'').slice(0,16)}</div>
        ${t.resolved_at?`<div>✅ 解决: ${t.resolved_at.slice(0,16)}</div>`:''}
      </div>
      ${t.resolution?`<div style="background:#ecfdf5;border:1px solid #a7f3d0;border-radius:8px;padding:14px;margin-bottom:16px"><strong>解决方案:</strong><br>${t.resolution}</div>`:''}
      ${t.satisfaction>0?`<div style="margin-bottom:16px">满意度: ${'⭐'.repeat(t.satisfaction)} ${t.satisfaction_comment?'— '+t.satisfaction_comment:''}</div>`:''}
      <h4 style="margin:20px 0 10px">沟通记录</h4>
      ${repliesHtml || '<div style="color:#999;text-align:center;padding:20px">暂无回复</div>'}
      <div style="margin-top:20px;padding-top:16px;border-top:1px solid #eee">
        <textarea id="ticket-reply-content" placeholder="输入回复内容..." style="width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;min-height:80px;resize:vertical;margin-bottom:10px"></textarea>
        <div style="display:flex;gap:8px;margin-bottom:12px">
          <select id="ticket-status-select" class="form-control" style="width:auto">
            <option value="" ${t.status===t.status?'':'selected'}>不更改状态</option>
            <option value="open" ${t.status==='open'?'selected':''}>待处理</option>
            <option value="in_progress" ${t.status==='in_progress'?'selected':''}>处理中</option>
            <option value="resolved" ${t.status==='resolved'?'selected':''}>已解决</option>
            <option value="closed" ${t.status==='closed'?'selected':''}>已关闭</option>
            <option value="reopened" ${t.status==='reopened'?'selected':''}>已重开</option>
          </select>
          <label style="display:flex;align-items:center;gap:4px;font-size:13px"><input type="checkbox" id="ticket-internal"> 内部备注</label>
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn" onclick="closeModal()">关闭</button>
          <button class="btn btn-primary" onclick="submitTicketReply(${t.id})">回复</button>
        </div>
      </div>
    </div>
  `;
  showModal(`工单详情 - ${t.ticket_no}`, html, 'large');
}

async function submitTicketReply(id) {
  const content = document.getElementById('ticket-reply-content')?.value.trim();
  const status = document.getElementById('ticket-status-select')?.value;
  const isInternal = document.getElementById('ticket-internal')?.checked;
  if (!content) { alert('请输入回复内容'); return; }
  try {
    await api(`/tickets/admin/${id}/reply`, { method: 'POST', body: JSON.stringify({ content, is_internal: isInternal }) });
    if (status) {
      await api(`/tickets/admin/${id}`, { method: 'PUT', body: JSON.stringify({ status }) });
    }
    closeModal();
    loadTicketList(ticketPage);
  } catch(e) { alert('操作失败: ' + e.message); }
}

// --- Partners ---
let partnerPage = 1, partnerTab = 'partners';
async function loadPartners() {
  partnerPage = 1;
  partnerTab = 'partners';
  loadPartnerList();
}
async function loadPartnerList() {
  let url = `/partners/admin/list?page=${partnerPage}&page_size=20`;
  const status = document.getElementById('partner-status-filter')?.value || '';
  const keyword = document.getElementById('partner-keyword')?.value || '';
  if (status) url += `&status=${status}`;
  if (keyword) url += `&keyword=${encodeURIComponent(keyword)}`;
  try {
    const d = await api(url);
    const stats = d.stats || {};
    let html = `<div class="stats-grid">
      <div class="stat-card"><div class="stat-num">${stats.total||0}</div><div class="stat-label">总伙伴</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--warning)">${stats.pending||0}</div><div class="stat-label">待审核</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--success)">${stats.approved||0}</div><div class="stat-label">已通过</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--info)">¥${(stats.totalCommission||0).toFixed(0)}</div><div class="stat-label">总佣金</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--primary)">¥${(stats.totalPaid||0).toFixed(0)}</div><div class="stat-label">已提现</div></div>
    </div>`;
    // Tab bar
    html += `<div style="display:flex;gap:10px;margin:20px 0">
      <button class="btn ${partnerTab==='partners'?'btn-primary':'btn-default'}" onclick="partnerTab='partners';loadPartnerList()">合作伙伴</button>
      <button class="btn ${partnerTab==='referrals'?'btn-primary':'btn-default'}" onclick="partnerTab='referrals';loadPartnerList()">推荐记录</button>
      <button class="btn ${partnerTab==='commissions'?'btn-primary':'btn-default'}" onclick="partnerTab='commissions';loadPartnerList()">佣金记录</button>
      <button class="btn ${partnerTab==='withdrawals'?'btn-primary':'btn-default'}" onclick="partnerTab='withdrawals';loadPartnerList()">提现审核</button>
      <button class="btn ${partnerTab==='stats'?'btn-primary':'btn-default'}" onclick="partnerTab='stats';loadPartnerStats()">统计</button>
    </div>`;
    if (partnerTab === 'partners') {
      html += `<div style="display:flex;gap:10px;margin-bottom:15px">
        <select id="partner-status-filter" class="input" style="width:120px" onchange="loadPartnerList()">
          <option value="">全部状态</option><option value="pending" ${status==='pending'?'selected':''}>待审核</option><option value="approved" ${status==='approved'?'selected':''}>已通过</option><option value="rejected" ${status==='rejected'?'selected':''}>已拒绝</option><option value="suspended" ${status==='suspended'?'selected':''}>已暂停</option>
        </select>
        <input id="partner-keyword" class="input" style="flex:1" placeholder="搜索姓名/手机/公司/编号" value="${keyword}" onkeydown="if(event.key==='Enter')loadPartnerList()"/>
        <button class="btn btn-default" onclick="loadPartnerList()">搜索</button>
      </div>`;
      const items = d.items || [];
      const levelLabels = {standard:'标准',silver:'银牌',gold:'金牌',platinum:'白金'};
      const statusLabels = {pending:'待审核',approved:'已通过',rejected:'已拒绝',suspended:'已暂停'};
      const statusColors = {pending:'#f59e0b',approved:'#10b981',rejected:'#ef4444',suspended:'#6b7280'};
      html += '<table class="table"><thead><tr><th>编号</th><th>姓名</th><th>公司</th><th>手机</th><th>等级</th><th>佣金率</th><th>推荐数</th><th>成交数</th><th>总佣金</th><th>状态</th><th>操作</th></tr></thead><tbody>';
      window._partnerCache = {};
      items.forEach(p => {
        window._partnerCache[p.id] = p;
        html += `<tr><td style="font-size:12px">${p.partner_no}</td><td>${p.name}</td><td>${p.company||'-'}</td><td>${p.phone}</td><td>${levelLabels[p.level]||p.level}</td><td>${p.commission_rate}%</td><td>${p.total_referrals||0}</td><td>${p.successful_referrals||0}</td><td>¥${(p.total_commission||0).toFixed(2)}</td><td style="color:${statusColors[p.status]||''}">${statusLabels[p.status]||p.status}</td><td><button class="btn btn-sm btn-default" onclick="showPartnerDetail(${p.id})">管理</button></td></tr>`;
      });
      html += '</tbody></table>';
      html += renderPagination(d.total, d.page, d.page_size, 'loadPartnerList');
    } else if (partnerTab === 'referrals') {
      html += loadPartnerReferralsHTML();
    } else if (partnerTab === 'commissions') {
      html += loadPartnerCommissionsHTML();
    } else if (partnerTab === 'withdrawals') {
      html += loadPartnerWithdrawalsHTML();
    }
    document.getElementById('content').innerHTML = html;
    if (partnerTab === 'referrals') loadPartnerReferrals();
    if (partnerTab === 'commissions') loadPartnerCommissions();
    if (partnerTab === 'withdrawals') loadPartnerWithdrawals();
  } catch(e) {
    document.getElementById('content').innerHTML = '<p>加载失败: ' + e.message + '</p>';
  }
}
function loadPartnerReferralsHTML() {
  return `<div style="display:flex;gap:10px;margin-bottom:15px">
    <select id="ref-status-filter" class="input" style="width:120px" onchange="loadPartnerReferrals()">
      <option value="">全部状态</option><option value="pending">待联系</option><option value="contacted">已联系</option><option value="qualified">意向确认</option><option value="converted">已成交</option><option value="lost">已流失</option>
    </select>
    <input id="ref-keyword" class="input" style="flex:1" placeholder="搜索线索姓名/手机/公司/推荐人" onkeydown="if(event.key==='Enter')loadPartnerReferrals()"/>
    <button class="btn btn-default" onclick="loadPartnerReferrals()">搜索</button>
  </div><div id="ref-list">加载中...</div>`;
}
async function loadPartnerReferrals() {
  let url = '/partners/admin/referrals?page=1&page_size=50';
  const status = document.getElementById('ref-status-filter')?.value || '';
  const keyword = document.getElementById('ref-keyword')?.value || '';
  if (status) url += `&status=${status}`;
  if (keyword) url += `&keyword=${encodeURIComponent(keyword)}`;
  try {
    const d = await api(url);
    const statusLabels = {pending:'待联系',contacted:'已联系',qualified:'意向确认',converted:'已成交',lost:'已流失'};
    const statusColors = {pending:'#f59e0b',contacted:'#3b82f6',qualified:'#a78bfa',converted:'#10b981',lost:'#ef4444'};
    let html = '<table class="table"><thead><tr><th>编号</th><th>推荐人</th><th>线索信息</th><th>公司</th><th>产品</th><th>状态</th><th>订单金额</th><th>佣金</th><th>时间</th><th>操作</th></tr></thead><tbody>';
    (d.items||[]).forEach(r => {
      html += `<tr><td style="font-size:12px">${r.referral_no}</td><td>${r.partner_name}</td><td>${r.lead_name}<br><span style="font-size:12px;color:#6b7280">${r.lead_phone}</span></td><td>${r.lead_company||'-'}</td><td style="font-size:12px">${r.product_title||'-'}</td><td style="color:${statusColors[r.status]||''}">${statusLabels[r.status]||r.status}</td><td>${r.order_amount?'¥'+r.order_amount:'-'}</td><td>${r.commission_amount?'¥'+r.commission_amount:'-'}</td><td style="font-size:12px">${(r.created_at||'').slice(0,16)}</td><td><button class="btn btn-sm btn-default" onclick="showReferralDetail(${r.id})">管理</button></td></tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('ref-list').innerHTML = html || '<p style="text-align:center;color:#999">暂无记录</p>';
  } catch(e) { document.getElementById('ref-list').innerHTML = '<p>加载失败</p>'; }
}
function loadPartnerCommissionsHTML() {
  return `<div style="display:flex;gap:10px;margin-bottom:15px">
    <select id="comm-status-filter" class="input" style="width:120px" onchange="loadPartnerCommissions()">
      <option value="">全部状态</option><option value="estimated">预估中</option><option value="confirmed">已确认</option><option value="paid">已提现</option><option value="cancelled">已取消</option>
    </select>
  </div><div id="comm-list">加载中...</div>`;
}
async function loadPartnerCommissions() {
  let url = '/partners/admin/commissions?page=1&page_size=50';
  const status = document.getElementById('comm-status-filter')?.value || '';
  if (status) url += `&status=${status}`;
  try {
    const d = await api(url);
    const statusLabels = {estimated:'预估中',confirmed:'已确认',paid:'已提现',cancelled:'已取消'};
    const statusColors = {estimated:'#f59e0b',confirmed:'#3b82f6',paid:'#10b981',cancelled:'#ef4444'};
    let html = '<table class="table"><thead><tr><th>推荐编号</th><th>伙伴</th><th>订单号</th><th>订单金额</th><th>比例</th><th>佣金</th><th>状态</th><th>时间</th><th>操作</th></tr></thead><tbody>';
    (d.items||[]).forEach(c => {
      html += `<tr><td style="font-size:12px">${c.referral_no}</td><td>${c.partner_name}</td><td style="font-size:12px">${c.order_no||'-'}</td><td>¥${c.order_amount}</td><td>${c.rate}%</td><td style="font-weight:600;color:var(--primary)">¥${c.amount}</td><td style="color:${statusColors[c.status]||''}">${statusLabels[c.status]||c.status}</td><td style="font-size:12px">${(c.created_at||'').slice(0,16)}</td>`;
      if (c.status === 'estimated') html += `<td><button class="btn btn-sm btn-success" onclick="confirmCommission(${c.id})">确认</button></td>`;
      else html += '<td>-</td>';
      html += '</tr>';
    });
    html += '</tbody></table>';
    document.getElementById('comm-list').innerHTML = html || '<p style="text-align:center;color:#999">暂无记录</p>';
  } catch(e) { document.getElementById('comm-list').innerHTML = '<p>加载失败</p>'; }
}
function loadPartnerWithdrawalsHTML() {
  return '<div id="wd-list">加载中...</div>';
}
async function loadPartnerWithdrawals() {
  try {
    const d = await api('/partners/admin/withdrawals?page=1&page_size=50');
    const statusLabels = {pending:'待审核',approved:'审核通过',rejected:'已拒绝',paid:'已打款',failed:'打款失败'};
    const statusColors = {pending:'#f59e0b',approved:'#3b82f6',rejected:'#ef4444',paid:'#10b981',failed:'#ef4444'};
    let html = '<table class="table"><thead><tr><th>编号</th><th>伙伴</th><th>金额</th><th>手续费</th><th>实到</th><th>方式</th><th>状态</th><th>时间</th><th>操作</th></tr></thead><tbody>';
    (d.items||[]).forEach(w => {
      html += `<tr><td style="font-size:12px">${w.withdrawal_no}</td><td>${w.partner_name}</td><td>¥${w.amount}</td><td>¥${w.fee}</td><td>¥${w.actual_amount}</td><td>${w.method==='alipay'?'支付宝':'银行卡'}</td><td style="color:${statusColors[w.status]||''}">${statusLabels[w.status]||w.status}</td><td style="font-size:12px">${(w.created_at||'').slice(0,16)}</td>`;
      if (w.status === 'pending') html += `<td><button class="btn btn-sm btn-success" onclick="processWithdrawal(${w.id},'paid')">打款</button> <button class="btn btn-sm btn-danger" onclick="processWithdrawal(${w.id},'rejected')">拒绝</button></td>`;
      else html += '<td>-</td>';
      html += '</tr>';
    });
    html += '</tbody></table>';
    document.getElementById('wd-list').innerHTML = html || '<p style="text-align:center;color:#999">暂无记录</p>';
  } catch(e) { document.getElementById('wd-list').innerHTML = '<p>加载失败</p>'; }
}
async function loadPartnerStats() {
  try {
    const d = await api('/partners/admin/stats');
    const o = d.overview || {};
    const f = d.funnel || {};
    let html = `<div class="stats-grid">
      <div class="stat-card"><div class="stat-num">${o.totalPartners||0}</div><div class="stat-label">总伙伴</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--success)">${o.activePartners||0}</div><div class="stat-label">活跃伙伴</div></div>
      <div class="stat-card"><div class="stat-num">${o.totalReferrals||0}</div><div class="stat-label">总推荐</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--success)">${o.convertedReferrals||0}</div><div class="stat-label">已成交</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--info)">${o.conversionRate||0}%</div><div class="stat-label">转化率</div></div>
      <div class="stat-card"><div class="stat-num" style="color:var(--primary)">¥${(o.totalCommission||0).toFixed(0)}</div><div class="stat-label">总佣金</div></div>
    </div>`;
    // 漏斗
    html += '<div class="card" style="margin-top:20px;padding:20px"><h3>转化漏斗</h3>';
    const funnelItems = [['总推荐',f.referrals],['已联系',f.contacted],['意向确认',f.qualified],['已成交',f.converted]];
    funnelItems.forEach(([label,val]) => {
      const pct = f.referrals ? (val/f.referrals*100).toFixed(1) : 0;
      html += `<div style="margin:10px 0"><span style="display:inline-block;width:80px">${label}</span><span style="display:inline-block;width:60px;font-weight:600">${val}</span><div style="display:inline-block;background:var(--primary);height:20px;border-radius:4px;width:${pct}%"></div><span style="margin-left:8px;color:#6b7280;font-size:12px">${pct}%</span></div>`;
    });
    html += '</div>';
    // 等级分布
    const ld = d.levelDistribution || {};
    html += '<div class="card" style="margin-top:20px;padding:20px"><h3>等级分布</h3>';
    Object.keys(ld).forEach(k => {
      html += `<div style="margin:8px 0"><span style="display:inline-block;width:100px">${ld[k].label}</span><span style="font-weight:600">${ld[k].count} 人</span></div>`;
    });
    html += '</div>';
    document.getElementById('content').innerHTML = html;
  } catch(e) { document.getElementById('content').innerHTML = '<p>加载失败: ' + e.message + '</p>'; }
}
function showPartnerDetail(id) {
  const p = window._partnerCache?.[id];
  if (!p) { alert('数据未缓存，请刷新'); return; }
  const levelOpts = ['standard','silver','gold','platinum'];
  const statusOpts = ['pending','approved','rejected','suspended'];
  let html = `<div class="modal-header"><h2>合作伙伴管理 - ${p.name}</h2><span class="modal-close" onclick="closeModal()">✕</span></div>`;
  html += '<div class="modal-body"><div style="display:grid;grid-template-columns:1fr 1fr;gap:15px">';
  html += `<div><label>编号</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.partner_no}</div></div>`;
  html += `<div><label>姓名</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.name}</div></div>`;
  html += `<div><label>手机</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.phone}</div></div>`;
  html += `<div><label>公司</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.company||'-'}</div></div>`;
  html += `<div><label>总推荐</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.total_referrals||0}</div></div>`;
  html += `<div><label>成交数</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">${p.successful_referrals||0}</div></div>`;
  html += `<div><label>总佣金</label><div style="padding:8px;background:#f5f5f5;border-radius:4px;color:var(--primary);font-weight:600">¥${(p.total_commission||0).toFixed(2)}</div></div>`;
  html += `<div><label>已提现</label><div style="padding:8px;background:#f5f5f5;border-radius:4px">¥${(p.paid_commission||0).toFixed(2)}</div></div>`;
  html += '</div>';
  html += '<div style="margin-top:20px;display:flex;gap:10px;flex-wrap:wrap">';
  html += '<select id="partner-level-select" class="input" style="width:120px">';
  levelOpts.forEach(l => html += `<option value="${l}" ${p.level===l?'selected':''}>${l}</option>`);
  html += '</select>';
  html += '<select id="partner-status-select" class="input" style="width:120px">';
  statusOpts.forEach(s => html += `<option value="${s}" ${p.status===s?'selected':''}>${s}</option>`);
  html += '</select>';
  html += '<input id="partner-rate-input" class="input" style="width:80px" type="number" value="'+p.commission_rate+'" placeholder="佣金率%"/>';
  html += '<button class="btn btn-primary" onclick="updatePartner('+id+')">保存</button>';
  html += '</div></div>';
  showModal(html);
}
async function updatePartner(id) {
  const level = document.getElementById('partner-level-select').value;
  const status = document.getElementById('partner-status-select').value;
  const rate = parseInt(document.getElementById('partner-rate-input').value);
  try {
    await api(`/partners/admin/${id}`, { method: 'PUT', body: JSON.stringify({ level, status, commission_rate: rate }) });
    alert('更新成功');
    closeModal();
    loadPartnerList();
  } catch(e) { alert('更新失败: ' + e.message); }
}
async function confirmCommission(id) {
  if (!confirm('确认此佣金记录？')) return;
  try {
    await api(`/partners/admin/commissions/${id}`, { method: 'PUT', body: JSON.stringify({ status: 'confirmed' }) });
    alert('确认成功');
    loadPartnerCommissions();
  } catch(e) { alert('操作失败: ' + e.message); }
}
async function processWithdrawal(id, action) {
  if (action === 'rejected') {
    const reason = prompt('拒绝原因：');
    if (!reason) return;
    try { await api(`/partners/admin/withdrawals/${id}`, { method: 'PUT', body: JSON.stringify({ status: 'rejected', reject_reason: reason }) }); }
    catch(e) { alert('操作失败'); return; }
  } else {
    const txn = prompt('银行流水号（选填）：') || '';
    try { await api(`/partners/admin/withdrawals/${id}`, { method: 'PUT', body: JSON.stringify({ status: 'paid', transaction_no: txn }) }); }
    catch(e) { alert('操作失败'); return; }
  }
  alert('处理成功');
  loadPartnerWithdrawals();
}
function showReferralDetail(id) {
  alert('推荐详情ID: ' + id + '\n请使用状态更新功能跟进此推荐');
}

// ==================== 智能客服机器人 ====================

async function loadChatbot() {
  const c = document.getElementById('content');
  c.innerHTML = `
    <h2>🤖 智能客服机器人</h2>
    <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap">
      <div class="stat-card" id="chatbot-stat-cards">加载中...</div>
    </div>
    <div class="tabs" style="margin-bottom:16px">
      <button class="tab active" onclick="switchChatbotTab('sessions')" id="chatbot-tab-sessions">会话记录</button>
      <button class="tab" onclick="switchChatbotTab('knowledge')" id="chatbot-tab-knowledge">知识库</button>
      <button class="tab" onclick="switchChatbotTab('feedback')" id="chatbot-tab-feedback">反馈统计</button>
    </div>
    <div id="chatbot-sessions-section">
      <div style="margin-bottom:12px;display:flex;gap:8px;align-items:center">
        <select id="chatbot-session-status" onchange="loadChatbotSessions()">
          <option value="">全部状态</option>
          <option value="active">进行中</option>
          <option value="closed">已关闭</option>
          <option value="taken_over">已接管</option>
        </select>
      </div>
      <table class="data-table" id="chatbot-sessions-table">
        <thead><tr><th>ID</th><th>用户</th><th>消息数</th><th>转人工</th><th>评分</th><th>状态</th><th>最后消息</th><th>时间</th><th>操作</th></tr></thead>
        <tbody id="chatbot-sessions-body"></tbody>
      </table>
    </div>
    <div id="chatbot-knowledge-section" style="display:none">
      <p style="color:#666;margin-bottom:12px">机器人内置知识库规则，通过关键词匹配自动回复。FAQ库在「帮助中心」管理。</p>
      <div id="chatbot-knowledge-list"></div>
    </div>
    <div id="chatbot-feedback-section" style="display:none">
      <div id="chatbot-feedback-stats"></div>
    </div>
  `;
  loadChatbotStats();
  loadChatbotSessions();
}

async function loadChatbotStats() {
  try {
    const res = await api('/chatbot/admin/stats');
    const d = res.data;
    const cards = [
      {label:'总会话',value:d.overview.total_sessions,color:'#3498db'},
      {label:'今日会话',value:d.overview.today_sessions,color:'#2ecc71'},
      {label:'今日消息',value:d.overview.today_messages,color:'#9b59b6'},
      {label:'转人工率',value:d.overview.transfer_rate,color:'#e67e22'},
      {label:'平均评分',value:d.overview.avg_rating + '⭐',color:'#f1c40f'},
      {label:'有用率',value:d.overview.helpful_rate,color:'#1abc9c'}
    ];
    document.getElementById('chatbot-stat-cards').innerHTML = cards.map(s => 
      `<div style="background:#fff;border-radius:8px;padding:16px 20px;min-width:120px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.06)">
        <div style="font-size:24px;font-weight:700;color:${s.color}">${s.value}</div>
        <div style="font-size:13px;color:#888;margin-top:4px">${s.label}</div>
      </div>`
    ).join('');
    
    // 7天趋势
    const trendHtml = d.trend_7days.map(t => 
      `<div style="display:flex;gap:4px;align-items:flex-end;height:60px">
        <div style="width:24px;background:#3498db;border-radius:3px 3px 0 0;height:${Math.min(t.sessions*20,50)}px" title="${t.date}: ${t.sessions}会话"></div>
        <div style="width:24px;background:#2ecc71;border-radius:3px 3px 0 0;height:${Math.min(t.messages*2,50)}px" title="${t.date}: ${t.messages}消息"></div>
      </div>`
    ).join('');
    
    const trendSection = `<div style="background:#fff;border-radius:8px;padding:16px;margin-top:12px">
      <div style="font-weight:600;margin-bottom:8px">📈 7天趋势</div>
      <div style="display:flex;gap:8px">${trendHtml}</div>
      <div style="display:flex;gap:8px;margin-top:4px">
        ${d.trend_7days.map(t => `<div style="width:52px;text-align:center;font-size:11px;color:#999">${t.date.slice(5)}</div>`).join('')}
      </div>
      <div style="margin-top:8px;font-size:12px;color:#999">🔵 会话数　🟢 消息数</div>
    </div>`;
    
    document.getElementById('chatbot-stat-cards').parentElement.insertAdjacentHTML('beforeend', trendSection);
  } catch(e) {
    console.error('loadChatbotStats error', e);
  }
}

async function loadChatbotSessions() {
  const status = document.getElementById('chatbot-session-status')?.value || '';
  try {
    const res = await api(`/chatbot/admin/sessions?status=${status}&limit=50`);
    const rows = res.data.list.map(s => `
      <tr>
        <td>${s.id}</td>
        <td>${s.openid ? s.openid.substring(0,12) : '匿名'}</td>
        <td>${s.message_count || 0}</td>
        <td>${s.transfer_requested ? '🔴 是' : '否'}</td>
        <td>${s.rating ? s.rating + '⭐' : '-'}</td>
        <td><span class="badge badge-${s.status==='active'?'green':s.status==='closed'?'gray':'orange'}">${s.status}</span></td>
        <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${s.last_message || '-'}</td>
        <td>${(s.created_at||'').replace('T',' ').substring(0,16)}</td>
        <td><button onclick="viewChatbotSession(${s.id})" class="btn-sm">查看</button></td>
      </tr>
    `).join('');
    document.getElementById('chatbot-sessions-body').innerHTML = rows || '<tr><td colspan="9" style="text-align:center;padding:20px;color:#999">暂无数据</td></tr>';
  } catch(e) {
    console.error('loadChatbotSessions error', e);
  }
}

async function viewChatbotSession(id) {
  try {
    const res = await api(`/chatbot/admin/sessions/${id}/messages`);
    const msgs = res.data;
    const html = msgs.map(m => {
      const isBot = m.role === 'bot';
      return `<div style="margin-bottom:12px;padding:12px;background:${isBot?'#f0f4f8':'#e8f5e9'};border-radius:8px;border-left:3px solid ${isBot?'#3498db':'#2ecc71'}">
        <div style="font-size:12px;color:#888;margin-bottom:4px">${isBot?'🤖 机器人':'👤 用户'} · ${(m.created_at||'').replace('T',' ').substring(0,16)}</div>
        <div style="white-space:pre-wrap;font-size:14px">${m.content}</div>
        ${m.matched_faq ? '<div style="font-size:12px;color:#aaa;margin-top:4px">匹配FAQ: '+m.matched_faq.question+'</div>' : ''}
        ${m.suggestions && m.suggestions.length ? '<div style="margin-top:4px">'+m.suggestions.map(s=>'<span style="display:inline-block;padding:2px 8px;background:#fff;border-radius:10px;font-size:12px;margin-right:4px">'+s+'</span>').join('')+'</div>' : ''}
        ${m.helpful !== null && m.helpful !== undefined ? '<div style="font-size:12px;margin-top:4px;color:'+(m.helpful?'#27ae60':'#e74c3c')+'">反馈: '+(m.helpful?'有用':'无用')+'</div>' : ''}
      </div>`;
    }).join('');
    
    // 接管按钮
    const takeoverHtml = msgs[0] && msgs[0].session_id ? `
      <div style="margin-top:16px;text-align:center">
        <button onclick="takeoverChatbotSession(${id})" class="btn btn-primary">接管会话</button>
      </div>
    ` : '';
    
    showModal(`会话 #${id} 详情`, `<div style="max-height:500px;overflow-y:auto">${html}${takeoverHtml}</div>`);
  } catch(e) {
    console.error('viewChatbotSession error', e);
    alert('加载失败');
  }
}

async function takeoverChatbotSession(id) {
  const msg = prompt('输入接管消息（可选）：');
  if (msg === null) return;
  try {
    await api(`/chatbot/admin/takeover`, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ session_id: id, admin_message: msg || '人工客服已接管，请稍候~' })
    });
    alert('接管成功');
    closeModal();
    loadChatbotSessions();
  } catch(e) {
    alert('接管失败');
  }
}

function switchChatbotTab(tab) {
  ['sessions','knowledge','feedback'].forEach(t => {
    document.getElementById('chatbot-tab-'+t).classList.toggle('active', t === tab);
    document.getElementById('chatbot-'+t+'-section').style.display = t === tab ? '' : 'none';
  });
  if (tab === 'knowledge') loadChatbotKnowledge();
  if (tab === 'feedback') loadChatbotFeedback();
}

async function loadChatbotKnowledge() {
  try {
    const res = await api('/chatbot/admin/knowledge');
    const html = res.data.map((k, i) => `
      <div style="background:#fff;border-radius:8px;padding:16px;margin-bottom:12px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <span style="font-weight:600;font-size:14px">#${i+1} [${k.type}]</span>
          ${k.action ? '<span style="color:#e67e22;font-size:12px">动作: '+k.action+'</span>' : ''}
        </div>
        <div style="margin-bottom:8px"><span style="color:#888;font-size:12px">关键词:</span> 
          ${k.keywords.map(kw => '<span style="display:inline-block;padding:2px 8px;background:#f0f4f8;border-radius:10px;font-size:12px;margin:2px">'+kw+'</span>').join('') || '<span style="color:#ccc">(默认)</span>'}
        </div>
        <div style="white-space:pre-wrap;font-size:13px;color:#333;background:#f8f9fa;padding:8px;border-radius:6px">${k.answer}</div>
        ${k.suggestions ? '<div style="margin-top:8px"><span style="color:#888;font-size:12px">建议:</span> '+k.suggestions.map(s=>'<span style="display:inline-block;padding:2px 8px;background:#e8f5e9;border-radius:10px;font-size:12px;margin:2px">'+s+'</span>').join('')+'</div>' : ''}
      </div>
    `).join('');
    document.getElementById('chatbot-knowledge-list').innerHTML = html;
  } catch(e) {
    console.error('loadChatbotKnowledge error', e);
  }
}

async function loadChatbotFeedback() {
  try {
    const res = await api('/chatbot/admin/stats');
    const d = res.data;
    const helpful = d.helpful_stats.helpful;
    const unhelpful = d.helpful_stats.unhelpful;
    const total = helpful + unhelpful;
    const helpfulPct = total > 0 ? (helpful / total * 100).toFixed(1) : 0;
    const unhelpfulPct = total > 0 ? (unhelpful / total * 100).toFixed(1) : 0;
    
    document.getElementById('chatbot-feedback-stats').innerHTML = `
      <div style="display:flex;gap:16px;margin-bottom:20px">
        <div style="flex:1;background:#fff;border-radius:8px;padding:20px;text-align:center">
          <div style="font-size:36px;color:#27ae60">${helpful}</div>
          <div style="color:#888">👍 有用反馈</div>
        </div>
        <div style="flex:1;background:#fff;border-radius:8px;padding:20px;text-align:center">
          <div style="font-size:36px;color:#e74c3c">${unhelpful}</div>
          <div style="color:#888">👎 无用反馈</div>
        </div>
      </div>
      <div style="background:#fff;border-radius:8px;padding:20px">
        <div style="font-weight:600;margin-bottom:12px">反馈分布</div>
        <div style="background:#f0f0f0;border-radius:8px;height:30px;overflow:hidden;display:flex">
          <div style="background:#27ae60;width:${helpfulPct}%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px">${helpfulPct}%</div>
          <div style="background:#e74c3c;width:${unhelpfulPct}%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px">${unhelpfulPct}%</div>
        </div>
      </div>
    `;
  } catch(e) {
    console.error('loadChatbotFeedback error', e);
  }
}

// --- Contracts (合同管理) ---
let contractTab = 'list';
async function loadContracts() {
  const [statsRes, listRes] = await Promise.all([
    api('/contracts/admin/stats/overview'),
    api('/contracts/admin/list?page=1&page_size=50')
  ]);
  const stats = statsRes.data || statsRes;
  const list = (listRes.data || listRes).items || [];
  const stLabels = {draft:'草稿',pending_sign:'待签署',signed:'已签署',effective:'生效中',expired:'已到期',terminated:'已终止',cancelled:'已取消'};
  const stColors = {draft:'#8b95a5',pending_sign:'#f59e0b',signed:'#3b82f6',effective:'#10b981',expired:'#6b7280',terminated:'#ef4444',cancelled:'#9ca3af'};
  const typeLabels = {service:'服务合同',purchase:'采购合同',customization:'定制开发合同',nda:'保密协议',agency:'代理合同',other:'其他合同'};

  contentArea.innerHTML = `
    <h2>📄 合同管理</h2>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px">
      <div class="card" style="padding:16px;text-align:center">
        <div style="font-size:28px;font-weight:700;color:#2563eb">${stats.total||0}</div>
        <div style="color:#888;font-size:13px">合同总数</div>
      </div>
      <div class="card" style="padding:16px;text-align:center">
        <div style="font-size:28px;font-weight:700;color:#f59e0b">${stats.by_status?.pending_sign||0}</div>
        <div style="color:#888;font-size:13px">待签署</div>
      </div>
      <div class="card" style="padding:16px;text-align:center">
        <div style="font-size:28px;font-weight:700;color:#10b981">${stats.by_status?.effective||0}</div>
        <div style="color:#888;font-size:13px">生效中</div>
      </div>
      <div class="card" style="padding:16px;text-align:center">
        <div style="font-size:28px;font-weight:700;color:#e74c3c">¥${(stats.total_amount||0).toLocaleString()}</div>
        <div style="color:#888;font-size:13px">生效合同总额</div>
      </div>
    </div>
    ${stats.expiring_soon > 0 ? `<div style="background:#fff3cd;border:1px solid #ffc107;border-radius:8px;padding:12px 16px;margin-bottom:16px">⚠️ 有 <b>${stats.expiring_soon}</b> 份合同将在30天内到期，请及时续签</div>` : ''}

    <div class="tabs">
      <div class="tab ${contractTab==='list'?'active':''}" onclick="contractTab='list';loadContracts()">合同列表</div>
      <div class="tab ${contractTab==='templates'?'active':''}" onclick="contractTab='templates';loadContractTemplates()">合同模板</div>
      <div class="tab ${contractTab==='create'?'active':''}" onclick="contractTab='create';showContractCreateForm()">创建合同</div>
    </div>

    <div id="contract-tab-content">
      <table class="data-table">
        <thead><tr><th>合同编号</th><th>标题</th><th>类型</th><th>甲方</th><th>金额</th><th>状态</th><th>签署</th><th>创建时间</th><th>操作</th></tr></thead>
        <tbody>
          ${list.length === 0 ? '<tr><td colspan="9" style="text-align:center;color:#999">暂无合同</td></tr>' : list.map(c => `
            <tr>
              <td style="font-size:12px">${c.contract_no}</td>
              <td>${c.title}</td>
              <td>${typeLabels[c.type]||c.type}</td>
              <td>${c.party_a_name}<br><span style="font-size:12px;color:#888">${c.party_a_phone}</span></td>
              <td>¥${(c.amount||0).toLocaleString()}</td>
              <td><span style="color:${stColors[c.status]||''};font-weight:600">${stLabels[c.status]||c.status}</span></td>
              <td style="font-size:12px">甲${c.party_a_signed?'✓':'○'} 乙${c.party_b_signed?'✓':'○'}</td>
              <td style="font-size:12px">${(c.created_at||'').slice(0,16)}</td>
              <td>
                <button onclick="viewContractDetail(${c.id})" style="font-size:12px;padding:4px 8px">查看</button>
                ${c.status==='draft' ? `<button onclick="sendContractSign(${c.id})" style="font-size:12px;padding:4px 8px;background:#2563eb;color:#fff;border:none;border-radius:4px">发起签署</button>` : ''}
                ${c.status==='pending_sign' && !c.party_b_signed ? `<button onclick="signContractB(${c.id})" style="font-size:12px;padding:4px 8px;background:#10b981;color:#fff;border:none;border-radius:4px">乙方签署</button>` : ''}
                ${c.status==='effective' ? `<button onclick="terminateContract(${c.id})" style="font-size:12px;padding:4px 8px;background:#ef4444;color:#fff;border:none;border-radius:4px">终止</button>` : ''}
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;
}

async function viewContractDetail(id) {
  const res = await api(`/contracts/admin/${id}`);
  const c = res.data || res;
  const stLabels = {draft:'草稿',pending_sign:'待签署',signed:'已签署',effective:'生效中',expired:'已到期',terminated:'已终止',cancelled:'已取消'};
  const typeLabels = {service:'服务合同',purchase:'采购合同',customization:'定制开发合同',nda:'保密协议',agency:'代理合同',other:'其他合同'};
  
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;display:flex;align-items:center;justify-content:center';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;width:700px;max-height:80vh;overflow-y:auto;padding:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h3 style="margin:0">合同详情</h3>
        <button onclick="this.closest('div[style*=fixed]').remove()" style="border:none;background:none;font-size:20px;cursor:pointer">✕</button>
      </div>
      <div style="background:#f8f9fa;padding:12px;border-radius:8px;margin-bottom:16px">
        <div style="font-size:20px;font-weight:700;margin-bottom:8px">${c.title}</div>
        <div style="color:#888;font-size:13px">编号：${c.contract_no} | ${typeLabels[c.type]||c.type}</div>
      </div>
      <table class="data-table" style="margin-bottom:16px">
        <tr><td style="width:120px;color:#888">甲方</td><td>${c.party_a_name}</td></tr>
        <tr><td style="color:#888">联系方式</td><td>${c.party_a_phone}</td></tr>
        <tr><td style="color:#888">乙方</td><td>${c.party_b_name}</td></tr>
        <tr><td style="color:#888">产品/服务</td><td>${c.product_title||'-'}</td></tr>
        <tr><td style="color:#888">合同金额</td><td style="font-weight:600;color:#e74c3c">¥${(c.amount||0).toLocaleString()}</td></tr>
        <tr><td style="color:#888">服务期限</td><td>${c.service_period||'-'}个月</td></tr>
        <tr><td style="color:#888">状态</td><td>${stLabels[c.status]||c.status}</td></tr>
        <tr><td style="color:#888">甲方签署</td><td>${c.party_a_signed ? '✓ ' + (c.party_a_signed_at||'').slice(0,19) : '未签署'}</td></tr>
        <tr><td style="color:#888">乙方签署</td><td>${c.party_b_signed ? '✓ ' + (c.party_b_signed_at||'').slice(0,19) : '未签署'}</td></tr>
        <tr><td style="color:#888">生效日期</td><td>${c.effective_at ? c.effective_at.slice(0,10) : '-'}</td></tr>
        <tr><td style="color:#888">到期日期</td><td>${c.expired_at ? c.expired_at.slice(0,10) : '-'}</td></tr>
        ${c.terminate_reason ? `<tr><td style="color:#888">终止原因</td><td>${c.terminate_reason}</td></tr>` : ''}
      </table>
      ${c.custom_terms ? `<div style="margin-bottom:16px"><div style="font-weight:600;margin-bottom:8px">补充条款</div><div style="background:#f8f9fa;padding:12px;border-radius:8px;font-size:13px;white-space:pre-wrap">${c.custom_terms}</div></div>` : ''}
      ${c.content ? `<div style="margin-bottom:16px"><div style="font-weight:600;margin-bottom:8px">合同正文</div><div style="background:#f8f9fa;padding:12px;border-radius:8px;font-size:13px;white-space:pre-wrap;max-height:300px;overflow-y:auto">${c.content}</div></div>` : ''}
    </div>
  `;
  document.body.appendChild(modal);
}

async function sendContractSign(id) {
  if (!confirm('确认发起签署流程？将通知甲方进行签署。')) return;
  const res = await api(`/contracts/admin/${id}/status`, 'PUT', { status: 'pending_sign' });
  if (res.code === 0) { alert('已发起签署'); loadContracts(); } else { alert(res.error || '操作失败'); }
}

async function signContractB(id) {
  if (!confirm('确认乙方签署？如甲方已签署，合同将自动生效。')) return;
  const res = await api(`/contracts/admin/${id}/sign-b`, 'POST', {});
  if (res.code === 0) { alert(res.message || '签署成功'); loadContracts(); } else { alert(res.error || '操作失败'); }
}

async function terminateContract(id) {
  const reason = prompt('请输入终止原因：');
  if (!reason) return;
  const res = await api(`/contracts/admin/${id}/status`, 'PUT', { status: 'terminated', terminate_reason: reason });
  if (res.code === 0) { alert('合同已终止'); loadContracts(); } else { alert(res.error || '操作失败'); }
}

async function loadContractTemplates() {
  const res = await api('/contracts/templates');
  const items = (res.data || res).items || [];
  contentArea.innerHTML = `
    <h2>📄 合同模板管理</h2>
    <div class="tabs">
      <div class="tab" onclick="contractTab='list';loadContracts()">合同列表</div>
      <div class="tab active">合同模板</div>
      <div class="tab" onclick="contractTab='create';showContractCreateForm()">创建合同</div>
    </div>
    <button onclick="showTemplateCreateForm()" style="margin-bottom:16px;padding:8px 16px;background:#2563eb;color:#fff;border:none;border-radius:6px;cursor:pointer">+ 新建模板</button>
    <table class="data-table">
      <thead><tr><th>模板名称</th><th>编号</th><th>类型</th><th>版本</th><th>状态</th><th>创建时间</th><th>操作</th></tr></thead>
      <tbody>
        ${items.length === 0 ? '<tr><td colspan="7" style="text-align:center;color:#999">暂无模板</td></tr>' : items.map(t => `
          <tr>
            <td>${t.name}</td>
            <td style="font-size:12px">${t.code||'-'}</td>
            <td>${t.category_label||t.category}</td>
            <td>${t.version||'1.0'}</td>
            <td>${t.status===1?'<span style="color:#10b981">启用</span>':'<span style="color:#999">停用</span>'}</td>
            <td style="font-size:12px">${(t.created_at||'').slice(0,16)}</td>
            <td>
              <button onclick="toggleTemplateStatus(${t.id}, ${t.status})" style="font-size:12px;padding:4px 8px">${t.status===1?'停用':'启用'}</button>
              <button onclick="deleteTemplate(${t.id})" style="font-size:12px;padding:4px 8px;color:#e74c3c">删除</button>
            </td>
          </tr>
        `).join('')}
      </tbody>
    </table>
  `;
}

async function toggleTemplateStatus(id, currentStatus) {
  const res = await api(`/contracts/templates/${id}`, 'PUT', { status: currentStatus === 1 ? 0 : 1 });
  if (res.code === 0) { loadContractTemplates(); } else { alert(res.error || '操作失败'); }
}

async function deleteTemplate(id) {
  if (!confirm('确认删除此模板？')) return;
  const res = await api(`/contracts/templates/${id}`, 'DELETE');
  if (res.code === 0) { alert('已删除'); loadContractTemplates(); } else { alert(res.error || '删除失败'); }
}

function showTemplateCreateForm() {
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;display:flex;align-items:center;justify-content:center';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;width:600px;max-height:80vh;overflow-y:auto;padding:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h3 style="margin:0">新建合同模板</h3>
        <button onclick="this.closest('div[style*=fixed]').remove()" style="border:none;background:none;font-size:20px;cursor:pointer">✕</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div><label>模板名称 *</label><input id="tpl-name" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px" placeholder="如：标准服务合同模板"></div>
        <div><label>模板编号</label><input id="tpl-code" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px" placeholder="如：TPL-001"></div>
        <div><label>合同类型</label><select id="tpl-category" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px">
          <option value="service">服务合同</option><option value="purchase">采购合同</option><option value="customization">定制开发合同</option><option value="nda">保密协议</option><option value="agency">代理合同</option><option value="other">其他合同</option>
        </select></div>
        <div><label>版本</label><input id="tpl-version" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px" value="1.0"></div>
        <div><label>合同正文模板</label><textarea id="tpl-content" style="width:100%;min-height:200px;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px" placeholder="输入合同正文模板..."></textarea></div>
        <button onclick="submitNewTemplate()" style="padding:10px;background:#2563eb;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:14px">创建模板</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function submitNewTemplate() {
  const name = document.getElementById('tpl-name').value.trim();
  if (!name) { alert('请输入模板名称'); return; }
  const res = await api('/contracts/templates', 'POST', {
    name,
    code: document.getElementById('tpl-code').value.trim(),
    category: document.getElementById('tpl-category').value,
    version: document.getElementById('tpl-version').value.trim() || '1.0',
    content: document.getElementById('tpl-content').value
  });
  if (res.code === 0) {
    alert('模板创建成功');
    document.querySelector('div[style*=fixed]').remove();
    loadContractTemplates();
  } else {
    alert(res.error || '创建失败');
  }
}

function showContractCreateForm() {
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;display:flex;align-items:center;justify-content:center';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;width:600px;max-height:85vh;overflow-y:auto;padding:24px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
        <h3 style="margin:0">创建合同</h3>
        <button onclick="this.closest('div[style*=fixed]').remove()" style="border:none;background:none;font-size:20px;cursor:pointer">✕</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        <div><label>合同标题 *</label><input id="ct-title" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
        <div><label>合同类型</label><select id="ct-type" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px">
          <option value="service">服务合同</option><option value="purchase">采购合同</option><option value="customization">定制开发合同</option><option value="nda">保密协议</option><option value="agency">代理合同</option><option value="other">其他合同</option>
        </select></div>
        <div style="display:flex;gap:12px">
          <div style="flex:1"><label>甲方名称 *</label><input id="ct-pa-name" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
          <div style="flex:1"><label>甲方电话 *</label><input id="ct-pa-phone" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
        </div>
        <div style="display:flex;gap:12px">
          <div style="flex:1"><label>甲方联系人</label><input id="ct-pa-contact" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
          <div style="flex:1"><label>甲方地址</label><input id="ct-pa-address" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
        </div>
        <div style="display:flex;gap:12px">
          <div style="flex:1"><label>产品/服务名称</label><input id="ct-product" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
          <div style="flex:1"><label>合同金额</label><input id="ct-amount" type="number" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
        </div>
        <div style="display:flex;gap:12px">
          <div style="flex:1"><label>服务期限（月）</label><input id="ct-period" type="number" value="12" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
          <div style="flex:1"><label>关联订单号</label><input id="ct-order-no" style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px"></div>
        </div>
        <div><label>补充条款</label><textarea id="ct-terms" style="width:100%;min-height:100px;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px"></textarea></div>
        <div><label>合同正文</label><textarea id="ct-content" style="width:100%;min-height:150px;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:13px" placeholder="可留空，将使用默认模板..."></textarea></div>
        <button onclick="submitCreateContract()" style="padding:10px;background:#2563eb;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:14px">创建合同</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function submitCreateContract() {
  const title = document.getElementById('ct-title').value.trim();
  const paName = document.getElementById('ct-pa-name').value.trim();
  const paPhone = document.getElementById('ct-pa-phone').value.trim();
  if (!title) { alert('请输入合同标题'); return; }
  if (!paName) { alert('请输入甲方名称'); return; }
  if (!paPhone) { alert('请输入甲方电话'); return; }

  const res = await api('/contracts/admin/create', 'POST', {
    title,
    type: document.getElementById('ct-type').value,
    party_a_name: paName,
    party_a_phone: paPhone,
    party_a_contact: document.getElementById('ct-pa-contact').value.trim(),
    party_a_address: document.getElementById('ct-pa-address').value.trim(),
    product_title: document.getElementById('ct-product').value.trim(),
    amount: parseFloat(document.getElementById('ct-amount').value) || 0,
    service_period: document.getElementById('ct-period').value.trim() || '12',
    order_no: document.getElementById('ct-order-no').value.trim(),
    custom_terms: document.getElementById('ct-terms').value.trim(),
    content: document.getElementById('ct-content').value.trim()
  });

  if (res.code === 0) {
    alert('合同创建成功：' + res.data.contract_no);
    document.querySelector('div[style*=fixed]').remove();
    loadContracts();
  } else {
    alert(res.error || '创建失败');
  }
}

// --- 营销活动管理 ---
let campaignTab = 'list';
let campaignPage = 1;

async function loadCampaigns() {
  campaignTab = 'list';
  campaignPage = 1;
  renderCampaignPage();
}

async function renderCampaignPage() {
  const main = document.getElementById('mainContent');
  main.innerHTML = `
    <div class="page-header">
      <h1>🎉 营销活动管理</h1>
      <button class="btn btn-primary" onclick="showCampaignCreate()">+ 创建活动</button>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap">
      <button class="btn ${campaignTab==='list'?'btn-primary':'btn-default'}" onclick="campaignTab='list';renderCampaignPage()">活动列表</button>
      <button class="btn ${campaignTab==='stats'?'btn-primary':'btn-default'}" onclick="campaignTab='stats';renderCampaignStats()">数据统计</button>
    </div>
    <div id="campaignContent"><p style="text-align:center;color:#999">加载中...</p></div>
  `;
  if (campaignTab === 'list') loadCampaignList();
  if (campaignTab === 'stats') renderCampaignStats();
}

async function loadCampaignList() {
  const el = document.getElementById('campaignContent');
  el.innerHTML = '<p style="text-align:center;color:#999">加载中...</p>';
  const res = await api('/campaigns/admin/list?page=' + campaignPage + '&pageSize=20');
  if (res.code !== 0) { el.innerHTML = '<p style="color:red">加载失败</p>'; return; }
  const { list, total, stats } = res.data;
  
  let statsHtml = `
    <div class="stats-row">
      <div class="stat-card"><div class="stat-val">${stats.total}</div><div class="stat-label">总活动数</div></div>
      <div class="stat-card stat-green"><div class="stat-val">${stats.active}</div><div class="stat-label">进行中</div></div>
      <div class="stat-card stat-gray"><div class="stat-val">${stats.draft}</div><div class="stat-label">草稿</div></div>
      <div class="stat-card stat-orange"><div class="stat-val">${stats.ended}</div><div class="stat-label">已结束</div></div>
      <div class="stat-card stat-blue"><div class="stat-val">${stats.total_used}</div><div class="stat-label">总参与次数</div></div>
      <div class="stat-card stat-purple"><div class="stat-val">¥${(stats.total_discount||0).toFixed(0)}</div><div class="stat-label">总优惠金额</div></div>
    </div>
  `;
  
  if (list.length === 0) {
    el.innerHTML = statsHtml + '<div style="text-align:center;padding:60px;color:#999">暂无活动，点击右上角创建</div>';
    return;
  }
  
  let html = statsHtml + `
    <table class="data-table">
      <thead><tr>
        <th>活动编号</th><th>名称</th><th>类型</th><th>优惠</th>
        <th>时间</th><th>状态</th><th>参与</th><th>操作</th>
      </tr></thead>
      <tbody>
  `;
  for (const c of list) {
    const isActive = c.is_active;
    html += `<tr>
      <td style="font-size:12px;color:#666">${c.campaign_no}</td>
      <td style="font-weight:600">${c.name}</td>
      <td><span class="badge badge-${c.type==='flash'?'danger':c.type==='gift'?'warning':c.type==='bundle'?'success':'info'}">${c.type_label}</span></td>
      <td style="font-size:13px">
        ${c.type==='discount'?(c.discount_type==='percent'?c.discount_value+'% off':'减¥'+c.discount_value):''}
        ${c.type==='gift'?'🎁 '+c.gift_product_title:''}
        ${c.type==='flash'?'⚡ 闪购':''}
        ${c.type==='bundle'?'📦 套餐':''}
      </td>
      <td style="font-size:12px;color:#666">${(c.start_time||'').slice(0,10)} ~ ${(c.end_time||'').slice(0,10)}</td>
      <td>${isActive?'<span style="color:#10b981;font-weight:600">进行中</span>':'<span style="color:#999">'+c.status_label+'</span>'}</td>
      <td>${c.used_count}${c.usage_limit>0?'/'+c.usage_limit:''}</td>
      <td>
        <button class="btn btn-sm btn-default" onclick="showCampaignDetail(${c.id})">详情</button>
        ${c.status==='draft'||c.status==='paused'?'<button class="btn btn-sm btn-primary" onclick="setCampaignStatus('+c.id+',\'active\')">启动</button>':''}
        ${c.status==='active'?'<button class="btn btn-sm btn-warning" onclick="setCampaignStatus('+c.id+',\'paused\')">暂停</button>':''}
        ${c.status!=='ended'&&c.status!=='expired'?'<button class="btn btn-sm btn-danger" onclick="setCampaignStatus('+c.id+',\'ended\')">结束</button>':''}
        <button class="btn btn-sm btn-danger" onclick="deleteCampaign(${c.id})">删</button>
      </td>
    </tr>`;
  }
  html += '</tbody></table>';
  html += renderPagination(total, 20, campaignPage, 'campaignPage', 'loadCampaignList');
  el.innerHTML = html;
}

async function renderCampaignStats() {
  const el = document.getElementById('campaignContent');
  el.innerHTML = '<p style="text-align:center;color:#999">加载中...</p>';
  const res = await api('/campaigns/admin/stats');
  if (res.code !== 0) { el.innerHTML = '<p style="color:red">加载失败</p>'; return; }
  const d = res.data;
  
  let html = `
    <div class="stats-row">
      <div class="stat-card"><div class="stat-val">${d.overview.total_campaigns}</div><div class="stat-label">总活动数</div></div>
      <div class="stat-card stat-green"><div class="stat-val">${d.overview.active_campaigns}</div><div class="stat-label">进行中</div></div>
      <div class="stat-card stat-blue"><div class="stat-val">${d.overview.total_records}</div><div class="stat-label">总参与人次</div></div>
      <div class="stat-card stat-purple"><div class="stat-val">¥${(d.overview.total_discount||0).toFixed(0)}</div><div class="stat-label">总优惠金额</div></div>
      <div class="stat-card stat-orange"><div class="stat-val">¥${(d.overview.avg_discount||0).toFixed(0)}</div><div class="stat-label">平均优惠</div></div>
    </div>
  `;
  
  // 类型分布
  html += '<h3 style="margin:20px 0 10px">按类型分布</h3><div style="display:flex;gap:16px;flex-wrap:wrap">';
  const typeMap = {discount:'折扣活动',gift:'赠品活动',flash:'闪购活动',bundle:'套餐捆绑'};
  for (const [t, n] of Object.entries(d.by_type)) {
    html += `<div class="stat-card" style="flex:0 0 auto"><div class="stat-val">${n}</div><div class="stat-label">${typeMap[t]||t}</div></div>`;
  }
  html += '</div>';
  
  // 7天趋势
  html += '<h3 style="margin:20px 0 10px">7天参与趋势</h3><table class="data-table"><thead><tr><th>日期</th><th>参与次数</th><th>优惠金额</th></tr></thead><tbody>';
  for (const t of d.trend_7d) {
    html += `<tr><td>${t.date}</td><td>${t.count}</td><td>¥${(t.discount||0).toFixed(0)}</td></tr>`;
  }
  html += '</tbody></table>';
  
  // 活动排行
  if (d.ranking.length > 0) {
    html += '<h3 style="margin:20px 0 10px">活动效果排行 Top10</h3><table class="data-table"><thead><tr><th>排名</th><th>活动名称</th><th>类型</th><th>参与人次</th><th>优惠金额</th><th>状态</th></tr></thead><tbody>';
    d.ranking.forEach((r, i) => {
      html += `<tr><td>${i+1}</td><td>${r.name}</td><td>${typeMap[r.type]||r.type}</td><td>${r.records}</td><td>¥${(r.total_discount||0).toFixed(0)}</td><td>${r.status}</td></tr>`;
    });
    html += '</tbody></table>';
  }
  
  el.innerHTML = html;
}

function showCampaignCreate() {
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;padding:30px;max-width:600px;width:100%;max-height:85vh;overflow-y:auto">
      <h2 style="margin:0 0 20px">创建营销活动</h2>
      <div style="display:grid;gap:14px">
        <div><label>活动名称 *</label><input id="cp-name" class="input" placeholder="如：年中大促" style="width:100%"></div>
        <div><label>活动描述</label><textarea id="cp-desc" class="input" rows="2" style="width:100%"></textarea></div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>活动类型</label><select id="cp-type" class="input" style="width:100%">
            <option value="discount">折扣活动</option><option value="gift">赠品活动</option><option value="flash">闪购活动</option><option value="bundle">套餐捆绑</option>
          </select></div>
          <div style="flex:1"><label>折扣方式</label><select id="cp-dtype" class="input" style="width:100%">
            <option value="percent">百分比</option><option value="fixed">固定金额</option>
          </select></div>
        </div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>折扣值(%)或减免(元)</label><input id="cp-dval" class="input" type="number" style="width:100%"></div>
          <div style="flex:1"><label>最低消费(元)</label><input id="cp-min" class="input" type="number" style="width:100%"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>最大优惠(元,0=不限)</label><input id="cp-max" class="input" type="number" value="0" style="width:100%"></div>
          <div style="flex:1"><label>赠品名称(gift类型)</label><input id="cp-gift" class="input" placeholder="如：行业白皮书" style="width:100%"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>开始时间 *</label><input id="cp-start" class="input" type="datetime-local" style="width:100%"></div>
          <div style="flex:1"><label>结束时间 *</label><input id="cp-end" class="input" type="datetime-local" style="width:100%"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>适用范围</label><select id="cp-scope" class="input" style="width:100%">
            <option value="all">全部产品</option><option value="products">指定产品</option><option value="categories">指定分类</option>
          </select></div>
          <div style="flex:1"><label>优先级</label><input id="cp-priority" class="input" type="number" value="0" style="width:100%"></div>
        </div>
        <div style="display:flex;gap:10px">
          <div style="flex:1"><label>总参与限额(0=不限)</label><input id="cp-usage" class="input" type="number" value="0" style="width:100%"></div>
          <div style="flex:1"><label>每人限参与</label><input id="cp-per" class="input" type="number" value="1" style="width:100%"></div>
        </div>
        <div><label>活动规则(每行一条)</label><textarea id="cp-rules" class="input" rows="3" placeholder="如：仅限新用户参与\n不可与其他优惠叠加" style="width:100%"></textarea></div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:20px">
        <button class="btn btn-default" onclick="this.closest('div[style*=fixed]').remove()">取消</button>
        <button class="btn btn-primary" onclick="createCampaign()">创建</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function createCampaign() {
  const name = document.getElementById('cp-name').value.trim();
  const startTime = document.getElementById('cp-start').value;
  const endTime = document.getElementById('cp-end').value;
  if (!name || !startTime || !endTime) { alert('请填写必填项'); return; }
  
  const rules = document.getElementById('cp-rules').value.trim().split('\n').filter(Boolean);
  const res = await api('/campaigns/admin/create', 'POST', {
    name,
    description: document.getElementById('cp-desc').value.trim(),
    type: document.getElementById('cp-type').value,
    discount_type: document.getElementById('cp-dtype').value,
    discount_value: parseFloat(document.getElementById('cp-dval').value) || 0,
    min_amount: parseFloat(document.getElementById('cp-min').value) || 0,
    max_discount: parseFloat(document.getElementById('cp-max').value) || 0,
    gift_product_title: document.getElementById('cp-gift').value.trim(),
    start_time: startTime.replace('T', ' '),
    end_time: endTime.replace('T', ' '),
    applicable_scope: document.getElementById('cp-scope').value,
    priority: parseInt(document.getElementById('cp-priority').value) || 0,
    usage_limit: parseInt(document.getElementById('cp-usage').value) || 0,
    per_user_limit: parseInt(document.getElementById('cp-per').value) || 1,
    rules
  });
  if (res.code === 0) {
    alert('活动创建成功：' + res.data.campaign_no);
    document.querySelector('div[style*=fixed]').remove();
    loadCampaignList();
  } else {
    alert(res.message || '创建失败');
  }
}

async function setCampaignStatus(id, status) {
  const res = await api('/campaigns/admin/' + id + '/status', 'POST', { status });
  if (res.code === 0) {
    loadCampaignList();
  } else {
    alert(res.message || '操作失败');
  }
}

async function deleteCampaign(id) {
  if (!confirm('确定删除此活动？关联的参与记录也将被删除。')) return;
  const res = await api('/campaigns/admin/' + id, 'DELETE');
  if (res.code === 0) {
    loadCampaignList();
  } else {
    alert(res.message || '删除失败');
  }
}

async function showCampaignDetail(id) {
  const res = await api('/campaigns/admin/' + id + '/records?page=1&pageSize=20');
  const campaignRes = await api('/campaigns/' + id);
  if (campaignRes.code !== 0) { alert('活动不存在'); return; }
  const c = campaignRes.data;
  const records = res.code === 0 ? res.data : { list: [], total: 0, stats: {} };
  
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
  
  let html = `<div style="background:#fff;border-radius:12px;padding:30px;max-width:700px;width:100%;max-height:85vh;overflow-y:auto">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <h2 style="margin:0">${c.name}</h2>
      <span class="modal-close" style="cursor:pointer;font-size:24px" onclick="this.closest('div[style*=fixed]').remove()">✕</span>
    </div>
    <div style="display:grid;gap:12px;margin-bottom:20px">
      <div><strong>编号：</strong>${c.campaign_no} | <strong>类型：</strong>${c.type} | <strong>状态：</strong>${c.status}</div>
      <div><strong>时间：</strong>${c.start_time} ~ ${c.end_time}</div>
      <div><strong>优惠：</strong>${c.discount_type==='percent'?c.discount_value+'% off':'减¥'+c.discount_value} ${c.min_amount?'满¥'+c.min_amount:''}</div>
      <div><strong>参与：</strong>${c.used_count}${c.usage_limit>0?'/'+c.usage_limit:''} 次</div>
    </div>`;
  
  if (records.list && records.list.length > 0) {
    html += `<h3>参与记录 (${records.total})</h3>
      <div style="margin-bottom:10px;color:#666;font-size:14px">总优惠：¥${(records.stats.total_discount||0).toFixed(0)} | 关联订单：${records.stats.total_orders||0}</div>
      <table class="data-table"><thead><tr><th>用户</th><th>订单号</th><th>原价</th><th>优惠</th><th>实付</th><th>时间</th></tr></thead><tbody>`;
    for (const r of records.list) {
      html += `<tr><td>${r.user_phone||r.user_openid||'-'}</td><td>${r.order_no||'-'}</td><td>¥${r.original_amount}</td><td>¥${r.discount_amount}</td><td>¥${r.final_amount}</td><td>${(r.created_at||'').slice(0,16)}</td></tr>`;
    }
    html += '</tbody></table>';
  } else {
    html += '<p style="text-align:center;color:#999;padding:30px">暂无参与记录</p>';
  }
  
  html += '</div>';
  modal.innerHTML = html;
  document.body.appendChild(modal);
}

// --- Policies (政策追踪) ---
let policyFilter = { level: 'all', category: 'all', page: 1, limit: 20 };

async function loadPolicies() {
  const main = document.getElementById('main-content');
  main.innerHTML = `
    <div class="header">
      <h1>📜 政策追踪管理</h1>
      <div>
        <button class="btn btn-primary" onclick="showPolicyEditor()">+ 添加政策</button>
      </div>
    </div>
    <div class="stats" id="policy-stats"></div>
    <div style="background:#fff;padding:16px;border-radius:12px;margin-bottom:16px;display:flex;gap:12px;flex-wrap:wrap;align-items:center">
      <label>层级：</label>
      <select id="policy-filter-level" onchange="policyFilter.level=this.value;policyFilter.page=1;loadPoliciesList()" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px">
        <option value="all">全部</option>
        <option value="national">国家</option>
        <option value="shandong">山东</option>
        <option value="ningxia">宁夏</option>
      </select>
      <label>类型：</label>
      <select id="policy-filter-category" onchange="policyFilter.category=this.value;policyFilter.page=1;loadPoliciesList()" style="padding:6px 12px;border:1px solid #ddd;border-radius:6px">
        <option value="all">全部</option>
        <option value="digital">数字化转型</option>
        <option value="industry">产业</option>
        <option value="tax">财税</option>
        <option value="talent">人才</option>
        <option value="other">其他</option>
      </select>
      <input id="policy-search" placeholder="搜索政策..." style="padding:6px 12px;border:1px solid #ddd;border-radius:6px;flex:1;min-width:200px" onkeypress="if(event.key==='Enter'){policySearch()}">
      <button class="btn btn-outline btn-sm" onclick="policySearch()">搜索</button>
    </div>
    <div id="policy-list">加载中...</div>
  `;
  
  // 加载统计
  try {
    const stats = await api('/policies/stats');
    document.getElementById('policy-stats').innerHTML = `
      <div class="stat-card"><div class="label">政策总数</div><div class="value">${stats.total}</div></div>
      <div class="stat-card"><div class="label">已发布</div><div class="value">${stats.published}</div></div>
      <div class="stat-card"><div class="label">国家政策</div><div class="value">${stats.byLevel.national||0}</div></div>
      <div class="stat-card"><div class="label">山东政策</div><div class="value">${stats.byLevel.shandong||0}</div></div>
      <div class="stat-card"><div class="label">宁夏政策</div><div class="value">${stats.byLevel.ningxia||0}</div></div>
    `;
  } catch(e) {}
  
  loadPoliciesList();
}

async function loadPoliciesList() {
  const { level, category, page, limit } = policyFilter;
  let url = `/policies?page=${page}&limit=${limit}`;
  if (level !== 'all') url += `&level=${level}`;
  if (category !== 'all') url += `&category=${category}`;
  
  try {
    const data = await api(url);
    const list = data.list || [];
    if (list.length === 0) {
      document.getElementById('policy-list').innerHTML = '<div style="text-align:center;color:#999;padding:40px">暂无政策数据</div>';
      return;
    }
    
    const levelColors = { national: '#dc2626', shandong: '#2563eb', ningxia: '#d97706' };
    const levelLabels = { national: '国家', shandong: '山东', ningxia: '宁夏' };
    const catLabels = { digital: '数字化转型', industry: '产业', tax: '财税', talent: '人才', other: '其他' };
    
    let html = '<table class="data-table" style="width:100%;background:#fff;border-radius:12px;overflow:hidden"><thead><tr style="background:#f8f9fb">';
    html += '<th style="padding:12px;text-align:left">ID</th>';
    html += '<th style="padding:12px;text-align:left">标题</th>';
    html += '<th style="padding:12px;text-align:left">层级</th>';
    html += '<th style="padding:12px;text-align:left">类型</th>';
    html += '<th style="padding:12px;text-align:left">发文机构</th>';
    html += '<th style="padding:12px;text-align:left">发布日期</th>';
    html += '<th style="padding:12px;text-align:left">浏览</th>';
    html += '<th style="padding:12px;text-align:left">操作</th>';
    html += '</tr></thead><tbody>';
    
    list.forEach(p => {
      const lc = levelColors[p.level] || '#666';
      html += `<tr style="border-bottom:1px solid #f0f0f0">`;
      html += `<td style="padding:12px">${p.id}</td>`;
      html += `<td style="padding:12px;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(p.title)}</td>`;
      html += `<td style="padding:12px"><span style="background:${lc}20;color:${lc};padding:2px 8px;border-radius:4px;font-size:12px">${levelLabels[p.level]||p.level}</span></td>`;
      html += `<td style="padding:12px;font-size:13px;color:#666">${catLabels[p.category]||p.category||'-'}</td>`;
      html += `<td style="padding:12px;font-size:13px;color:#666">${escapeHtml(p.issuing_authority||'-')}</td>`;
      html += `<td style="padding:12px;font-size:13px;color:#666">${p.publish_date||'-'}</td>`;
      html += `<td style="padding:12px;font-size:13px;color:#999">${p.views||0}</td>`;
      html += `<td style="padding:12px"><div style="display:flex;gap:4px"><button class="btn btn-info btn-sm" onclick="showPolicyEditor(${p.id})">编辑</button><button class="btn btn-danger btn-sm" onclick="deletePolicy(${p.id})">删除</button></div></td>`;
      html += '</tr>';
    });
    html += '</tbody></table>';
    
    // 分页
    const totalPages = data.totalPages || 1;
    if (totalPages > 1) {
      html += '<div style="display:flex;justify-content:center;gap:8px;margin-top:16px">';
      for (let i = 1; i <= totalPages; i++) {
        html += `<button class="btn ${i===page?'btn-primary':'btn-outline'} btn-sm" onclick="policyFilter.page=${i};loadPoliciesList()">${i}</button>`;
      }
      html += '</div>';
    }
    
    document.getElementById('policy-list').innerHTML = html;
  } catch(e) {
    document.getElementById('policy-list').innerHTML = '<div style="color:#ef4444;padding:20px">加载失败: '+escapeHtml(e.message||'')+'</div>';
  }
}

function policySearch() {
  const q = document.getElementById('policy-search').value.trim();
  if (!q) { loadPoliciesList(); return; }
  api('/policies/search?q=' + encodeURIComponent(q)).then(data => {
    const list = data.list || [];
    if (list.length === 0) {
      document.getElementById('policy-list').innerHTML = '<div style="text-align:center;color:#999;padding:40px">未找到匹配的政策</div>';
      return;
    }
    const levelLabels = { national: '国家', shandong: '山东', ningxia: '宁夏' };
    let html = '<table class="data-table" style="width:100%;background:#fff;border-radius:12px;overflow:hidden"><thead><tr style="background:#f8f9fb">';
    html += '<th style="padding:12px;text-align:left">ID</th><th style="padding:12px;text-align:left">标题</th><th style="padding:12px;text-align:left">层级</th><th style="padding:12px;text-align:left">发文机构</th><th style="padding:12px;text-align:left">发布日期</th><th style="padding:12px;text-align:left">操作</th>';
    html += '</tr></thead><tbody>';
    list.forEach(p => {
      html += `<tr style="border-bottom:1px solid #f0f0f0"><td style="padding:12px">${p.id}</td><td style="padding:12px">${escapeHtml(p.title)}</td><td style="padding:12px">${levelLabels[p.level]||p.level}</td><td style="padding:12px;font-size:13px;color:#666">${escapeHtml(p.issuing_authority||'-')}</td><td style="padding:12px;font-size:13px;color:#666">${p.publish_date||'-'}</td><td style="padding:12px"><button class="btn btn-info btn-sm" onclick="showPolicyEditor(${p.id})">编辑</button></td></tr>`;
    });
    html += '</tbody></table>';
    document.getElementById('policy-list').innerHTML = html;
  });
}

async function showPolicyEditor(id) {
  let policy = { title: '', subtitle: '', level: 'national', category: 'digital', issuing_authority: '', document_no: '', publish_date: '', effective_date: '', expiry_date: '', summary: '', content: '', key_points: [], support_measures: [], applicable_industries: [], tags: [] };
  let isEdit = false;
  if (id) {
    isEdit = true;
    try {
      policy = await api('/policies/' + id);
    } catch(e) { alert('加载政策失败'); return; }
  }
  
  const modal = document.createElement('div');
  modal.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center;overflow-y:auto;padding:20px';
  
  modal.innerHTML = `
    <div style="background:#fff;border-radius:12px;width:700px;max-width:95vw;max-height:90vh;overflow-y:auto;padding:24px">
      <h2 style="margin-bottom:20px">${isEdit?'编辑政策':'添加政策'}</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">标题 *</label>
          <input id="pol-title" value="${escapeHtml(policy.title)}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">副标题</label>
          <input id="pol-subtitle" value="${escapeHtml(policy.subtitle||'')}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div>
          <label style="font-size:13px;color:#666">层级</label>
          <select id="pol-level" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
            <option value="national" ${policy.level==='national'?'selected':''}>国家</option>
            <option value="shandong" ${policy.level==='shandong'?'selected':''}>山东</option>
            <option value="ningxia" ${policy.level==='ningxia'?'selected':''}>宁夏</option>
          </select>
        </div>
        <div>
          <label style="font-size:13px;color:#666">类型</label>
          <select id="pol-category" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
            <option value="digital" ${policy.category==='digital'?'selected':''}>数字化转型</option>
            <option value="industry" ${policy.category==='industry'?'selected':''}>产业</option>
            <option value="tax" ${policy.category==='tax'?'selected':''}>财税</option>
            <option value="talent" ${policy.category==='talent'?'selected':''}>人才</option>
            <option value="other" ${policy.category==='other'?'selected':''}>其他</option>
          </select>
        </div>
        <div>
          <label style="font-size:13px;color:#666">发文机构</label>
          <input id="pol-authority" value="${escapeHtml(policy.issuing_authority||'')}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div>
          <label style="font-size:13px;color:#666">文号</label>
          <input id="pol-docno" value="${escapeHtml(policy.document_no||'')}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div>
          <label style="font-size:13px;color:#666">发布日期</label>
          <input id="pol-pubdate" type="date" value="${policy.publish_date||''}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div>
          <label style="font-size:13px;color:#666">生效日期</label>
          <input id="pol-effdate" type="date" value="${policy.effective_date||''}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">摘要</label>
          <textarea id="pol-summary" rows="3" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">${escapeHtml(policy.summary||'')}</textarea>
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">正文内容</label>
          <textarea id="pol-content" rows="6" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">${escapeHtml(policy.content||'')}</textarea>
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">关键要点（每行一条）</label>
          <textarea id="pol-keypoints" rows="4" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">${(policy.key_points||[]).join('\n')}</textarea>
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">扶持措施（每行一条）</label>
          <textarea id="pol-measures" rows="4" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">${(policy.support_measures||[]).join('\n')}</textarea>
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">适用行业（逗号分隔）</label>
          <input id="pol-industries" value="${(policy.applicable_industries||[]).join(', ')}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
        <div style="grid-column:1/-1">
          <label style="font-size:13px;color:#666">标签（逗号分隔）</label>
          <input id="pol-tags" value="${(policy.tags||[]).join(', ')}" style="width:100%;padding:8px 12px;border:1px solid #ddd;border-radius:6px;margin-top:4px">
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:20px;justify-content:flex-end">
        <button class="btn btn-outline" onclick="this.closest('div[style*=fixed]').remove()">取消</button>
        <button class="btn btn-primary" onclick="savePolicy(${id||0})">保存</button>
      </div>
    </div>
  `;
  document.body.appendChild(modal);
}

async function savePolicy(id) {
  const title = document.getElementById('pol-title').value.trim();
  if (!title) { alert('标题不能为空'); return; }
  
  const keyPoints = document.getElementById('pol-keypoints').value.split('\n').map(s=>s.trim()).filter(Boolean);
  const measures = document.getElementById('pol-measures').value.split('\n').map(s=>s.trim()).filter(Boolean);
  const industries = document.getElementById('pol-industries').value.split(',').map(s=>s.trim()).filter(Boolean);
  const tags = document.getElementById('pol-tags').value.split(',').map(s=>s.trim()).filter(Boolean);
  
  const body = {
    title,
    subtitle: document.getElementById('pol-subtitle').value.trim(),
    level: document.getElementById('pol-level').value,
    category: document.getElementById('pol-category').value,
    issuing_authority: document.getElementById('pol-authority').value.trim(),
    document_no: document.getElementById('pol-docno').value.trim(),
    publish_date: document.getElementById('pol-pubdate').value,
    effective_date: document.getElementById('pol-effdate').value,
    summary: document.getElementById('pol-summary').value.trim(),
    content: document.getElementById('pol-content').value.trim(),
    key_points: keyPoints,
    support_measures: measures,
    applicable_industries: industries,
    tags: tags
  };
  
  try {
    if (id) {
      await api('/policies/' + id, 'PUT', body);
    } else {
      await api('/policies', 'POST', body);
    }
    document.querySelector('div[style*="position:fixed"]').remove();
    loadPoliciesList();
  } catch(e) {
    alert('保存失败: ' + (e.message||''));
  }
}

async function deletePolicy(id) {
  if (!confirm('确定删除此政策？')) return;
  try {
    await api('/policies/' + id, 'DELETE');
    loadPoliciesList();
  } catch(e) {
    alert('删除失败: ' + (e.message||''));
  }
}

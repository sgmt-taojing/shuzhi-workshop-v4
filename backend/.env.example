# 数造工坊后端环境变量配置模板
# 使用方法：复制本文件为 .env，填入真实值
# cp .env.example .env

# ===== 微信小程序 =====
# 注意：代码中使用 WX_APPID / WX_SECRET（或 WX_MINI_APPID / WX_MINI_SECRET）
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_app_secret
WX_APPID=wx_your_appid
WX_SECRET=your_app_secret

# ===== 微信支付 V3（模拟模式，无需真实证书）=====
WX_PAY_APPID=wx_your_appid
WX_PAY_MCHID=your_mch_id
WX_PAY_API_KEY_V3=your_v3_api_key_32_bytes
WX_PAY_SERIAL_NO=your_serial_number
WX_PAY_PRIVATE_KEY=./certs/apiclient_key.pem
WX_PAY_NOTIFY_URL=http://localhost:3004/api/pay/notify

# ===== 企业微信客服 =====
WECOM_CORP_ID=your_corp_id
WECOM_CUSTOMSERVICE_URL=
WECOM_CUSTOMSERVICE_SECRET=
WECOM_AGENT_ID=
WECOM_CUSTOMSERVICE_TOKEN=
WECOM_CUSTOMSERVICE_AES_KEY=
WECOM_CUSTOMSERVICE_AVATAR=
WECOM_CUSTOMSERVICE_NAME=数造工坊客服

# ===== 公众号模板消息（线索通知）=====
WECHAT_TEMPLATE_ID=your_template_id
WECHAT_ADMIN_OPENID=your_admin_openid
WECHAT_TEMPLATE_LEAD_URL=http://localhost:3004/admin

# ===== 服务端 =====
PORT=3004
NODE_ENV=development

# ===== 云开发（可选）=====
CLOUD_ENV=

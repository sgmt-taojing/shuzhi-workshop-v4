# 数造工坊环境变量配置
# 部署时修改为真实值

PORT=3004
NODE_ENV=production

# 微信小程序
WX_APPID=your_appid
WX_SECRET=your_secret

# 微信支付 V3
WX_PAY_APPID=your_appid
WX_PAY_MCHID=your_mchid
WX_PAY_API_KEY_V3=your_api_key_v3
WX_PAY_SERIAL_NO=your_serial_no
WX_PAY_PRIVATE_KEY=./certs/apiclient_key.pem
WX_PAY_NOTIFY_URL=http://your-domain/api/pay/notify

# 模板消息
WECHAT_TEMPLATE_ID=your_template_id
WECHAT_ADMIN_OPENID=your_admin_openid
WECHAT_TEMPLATE_LEAD_URL=http://your-domain/admin

# 企业微信
WECOM_CORP_ID=your_corp_id
WECOM_CUSTOMSERVICE_SECRET=your_secret
